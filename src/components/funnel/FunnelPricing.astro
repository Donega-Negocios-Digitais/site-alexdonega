---
interface TierFeature {
  included: boolean;
  highlight?: boolean;
  text: string;
}

interface Tier {
  id: string;
  badge: string;
  badgeVariant: string;
  name: string;
  tagline: string;
  priceParcelado: { installments: string; value: string };
  priceAvista: { value: string; full: string };
  featured?: boolean;
  featuredBadge?: string;
  scarcity?: string;
  features: TierFeature[];
  supportDays: number;
  guaranteeDays: number;
  ctaText: string;
  ctaVariant: string;
  dataPacote: string;
}

interface ComparisonRow {
  feature: string;
  diagnostico: string;
  estrategia: string;
  implementacao: string;
}

interface TrustSignal {
  icon: string;
  text: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  tiers?: Tier[];
  comparisonRows?: ComparisonRow[];
  trustSignals?: TrustSignal[];
}

const checkSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>';
const xSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>';
const arrowSvg = '<svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>';
const clockSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>';
const shieldSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>';

const {
  eyebrow = 'Escolha seu pacote',
  title = '3 opções para validar seu funil',
  subtitle = 'Do diagnóstico inicial à implementação completa — escolha o nível de suporte que você precisa',
  tiers = [
    {
      id: 'diagnostico',
      badge: 'Para Começar',
      badgeVariant: 'starter',
      name: 'Diagnóstico',
      tagline: 'Visão geral do seu funil',
      priceParcelado: { installments: '6x de', value: '166' },
      priceAvista: { value: '847', full: 'R$ 997' },
      features: [
        { included: true, text: 'Questionário de briefing estruturado' },
        { included: true, text: 'Mapa visual simplificado do funil' },
        { included: true, text: 'Simulação com <strong>1 cenário</strong> (provável)' },
        { included: true, text: 'Relatório PDF com vazamentos identificados' },
        { included: false, text: 'Vídeo de estratégia personalizado' },
        { included: true, text: '<strong>1 hora</strong> de mentoria individual' },
        { included: false, text: 'Implementação de copy e design' },
      ],
      supportDays: 7,
      guaranteeDays: 7,
      ctaText: 'Começar Diagnóstico',
      ctaVariant: 'outline',
      dataPacote: 'Mapa Funil - Diagnóstico',
    },
    {
      id: 'estrategia',
      badge: 'Recomendado',
      badgeVariant: 'popular',
      name: 'Estratégia Completa',
      tagline: 'Análise profunda + mentoria',
      priceParcelado: { installments: '6x de', value: '406' },
      priceAvista: { value: '2.070', full: 'R$ 2.436' },
      featured: true,
      featuredBadge: 'Mais Popular',
      scarcity: '6 vagas disponíveis este mês',
      features: [
        { included: true, text: '<strong>Tudo do Diagnóstico</strong> +' },
        { included: true, text: 'Mapa visual <strong>completo e detalhado</strong>' },
        { included: true, text: 'Simulação com <strong>3 cenários</strong>' },
        { included: true, text: '<strong>Vídeo</strong> explicando a estratégia' },
        { included: true, text: '<strong>2 horas</strong> de mentoria individual' },
        { included: true, text: '<strong>1 reunião</strong> de revisão e ajustes' },
        { included: false, text: 'Implementação de copy e design' },
      ],
      supportDays: 30,
      guaranteeDays: 30,
      ctaText: 'Garantir Minha Vaga',
      ctaVariant: 'primary',
      dataPacote: 'Mapa Funil - Estratégia Completa',
    },
    {
      id: 'implementacao',
      badge: 'Máximo Valor',
      badgeVariant: 'premium',
      name: 'Implementação Total',
      tagline: 'Tudo pronto para lançar',
      priceParcelado: { installments: '12x de', value: '990' },
      priceAvista: { value: '10.098', full: 'R$ 11.880' },
      scarcity: 'Últimas 2 vagas para Implementação',
      features: [
        { included: true, text: '<strong>Tudo do Diagnóstico</strong> +' },
        { included: true, text: 'Mapa com <strong>múltiplas versões</strong>' },
        { included: true, text: '<strong>6 horas</strong> de mentoria individual' },
        { included: true, text: '<strong>3 reuniões</strong> de revisão e ajustes' },
        { included: true, highlight: true, text: '<strong>Copywriting completo</strong> do funil' },
        { included: true, highlight: true, text: '<strong>Design das páginas</strong>' },
        { included: true, highlight: true, text: '<strong>Mensagens de WhatsApp</strong>' },
        { included: true, highlight: true, text: '<strong>E-mails e automações</strong>' },
      ],
      supportDays: 45,
      guaranteeDays: 30,
      ctaText: 'Quero Implementação Total',
      ctaVariant: 'premium',
      dataPacote: 'Mapa Funil - Implementação Total',
    },
  ],
  comparisonRows = [
    { feature: 'Questionário de briefing', diagnostico: '✓', estrategia: '✓', implementacao: '✓' },
    { feature: 'Diagrama de Mapa de Funil', diagnostico: '✓', estrategia: '✓', implementacao: '✓' },
    { feature: 'Resumo do Projeto', diagnostico: '✓', estrategia: '✓', implementacao: '✓' },
    { feature: 'Reinvestimento em Tráfego', diagnostico: '—', estrategia: '✓', implementacao: '✓' },
