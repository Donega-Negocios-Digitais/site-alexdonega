    { feature: 'Identificação de vazamentos', diagnostico: '✓', estrategia: '✓', implementacao: '✓' },
    { feature: 'Relatório PDF', diagnostico: '✓', estrategia: '✓', implementacao: '✓' },
    { feature: 'Vídeo de estratégia', diagnostico: '—', estrategia: '✓', implementacao: '✓' },
    { feature: 'Mentoria individual', diagnostico: '1 hora', estrategia: '2 horas', implementacao: '6 horas' },
    { feature: 'Reuniões de revisão', diagnostico: '—', estrategia: '1 reunião', implementacao: '3 reuniões' },
    { feature: 'Copywriting do funil', diagnostico: '—', estrategia: '—', implementacao: '✓' },
    { feature: 'Design das páginas', diagnostico: '—', estrategia: '—', implementacao: '✓' },
    { feature: 'Mensagens de WhatsApp', diagnostico: '—', estrategia: '—', implementacao: '✓' },
    { feature: 'E-mails e automações', diagnostico: '—', estrategia: '—', implementacao: '✓' },
    { feature: 'Período de suporte', diagnostico: '7 dias', estrategia: '30 dias', implementacao: '45 dias' },
    { feature: 'Garantia', diagnostico: '7 dias', estrategia: '30 dias', implementacao: '30 dias' },
  ],
  trustSignals = [
    { text: 'Pagamento 100% Seguro' },
    { text: 'Garantia de Satisfação' },
    { text: '+200 Funis Mapeados' },
