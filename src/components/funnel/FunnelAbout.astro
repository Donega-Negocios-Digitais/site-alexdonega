---
interface AboutPhase {
  title?: string;
  description?: string;
}

interface AboutPlayer {
  photo: string;
  name: string;
  role: string;
}

interface Props {
  eyebrow?: string;
  name?: string;
  photo?: string;
  bio?: string;
  phases?: AboutPhase[];
  mission?: string;
  playersLabel?: string;
  players?: AboutPlayer[];
  trustText?: string;
}

const {
  eyebrow = 'Quem Constrói com Você',
  name = 'Alex Donega',
  photo = '/img/people/alex-donega.webp',
  bio = 'Arquiteto de Funis com Mestrado em Economia e mais de 15 anos projetando sistemas de venda que convertem com previsibilidade. Combino modelagem financeira, tecnologia e copy estratégica para transformar tráfego em receita recorrente.',
  phases = [
    { description: '<strong>15+ anos em funis de alta escala</strong> — de SaaS a infoprodutos, com arquiteturas que já processaram milhões em vendas.' },
    { description: '<strong>7 empresas construídas do zero</strong> — cada uma validada por simulação financeira antes do primeiro real investido.' },
    { description: '<strong>Mentor de centenas de profissionais</strong> — ensinando arquitetura de funis, IA aplicada e decisão baseada em dados.' },
  ],
  mission = '"Cada funil que projeto começa com um modelo matemático. Antes de investir um real em tráfego, você vai saber exatamente quanto precisa converter em cada etapa para ter lucro. Isso não é otimismo — é engenharia de resultado."',
  playersLabel = 'Projetos com líderes de mercado:',
  players = [
    { photo: '/img/testimonials/diego-carmona-nasdaq-ipo.webp', name: 'Diego Carmona', role: 'Leadlovers · IPO Nasdaq' },
    { photo: '/img/testimonials/sergio-barbosa-waseller-placa-10milhoes.webp', name: 'Sergio Barbosa', role: 'Founder · Waseller' },
    { photo: '/img/testimonials/jp-savings-club-evento.webp', name: 'JP Galvão', role: 'CEO · Savings Club' },
    { photo: '/img/testimonials/christian-barbosa-neotriad-palestra.webp', name: 'Christian Barbosa', role: 'Neotriad · Produtividade' },
  ],
  trustText = 'Confiado por mais de <span class="trust-highlight">230</span> empresários',
} = Astro.props;
---

<section class="funnel-about">
  <div class="container">
    <div class="about-wrapper">
      <div class="about-image">
        <div class="image-container">
          <img src={photo} alt={name} width="400" height="500" loading="lazy" />
          <div class="image-glow"></div>
        </div>
      </div>
      <div class="about-content">
        <span class="section-eyebrow">{eyebrow}</span>
        <h2 class="section-title">{name}</h2>
        <p class="about-bio">{bio}</p>
        <div class="about-phases">
          {phases.map((phase) => (
            <div class="about-phase">
              <div class="phase-dot"></div>
              <p set:html={phase.description} />
            </div>
          ))}
        </div>
        <p class="about-mission">
          <em>{mission}</em>
        </p>
        <div class="about-players">
          <p class="about-players-label">{playersLabel}</p>
          <div class="about-players-grid">
            {players.map((player) => (
              <div class="about-player">
                <div class="about-player-photo">
                  <img src={player.photo} alt={player.name} loading="lazy" />
                </div>
                <span class="about-player-name">{player.name}</span>
                <span class="about-player-role">{player.role}</span>
              </div>
            ))}
          </div>
          <p class="about-players-trust" set:html={trustText} />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .funnel-about { padding: 8rem 0; background: rgba(255, 255, 255, 0.01); }
  .about-wrapper { display: grid; grid-template-columns: 1fr 1.5fr; gap: 5rem; align-items: center; }
  .about-image { position: relative; }
  .image-container { position: relative; border-radius: 24px; overflow: hidden; border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4); }
  .image-container img { width: 100%; height: auto; display: block; filter: grayscale(0.2) contrast(1.1); transition: all 0.5s ease; }
  .image-container:hover img { filter: grayscale(0) contrast(1); transform: scale(1.05); }
  .image-glow { position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(249, 115, 22, 0.2) 0%, transparent 70%); pointer-events: none; opacity: 0; transition: opacity 0.5s ease; }
  .image-container:hover .image-glow { opacity: 1; }
  .about-content { max-width: 600px; }
  .about-bio { font-family: var(--font-body); font-size: 1.25rem; color: white; font-weight: 500; line-height: 1.5; margin-bottom: 2rem; }
  .about-phases { display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem; }
  .about-phase { display: flex; gap: 1rem; align-items: flex-start; }
  .phase-dot { width: 8px; height: 8px; background: rgb(249, 115, 22); border-radius: 50%; margin-top: 0.6rem; flex-shrink: 0; box-shadow: 0 0 10px rgba(249, 115, 22, 0.5); }
  .about-phase p { font-family: var(--font-body); font-size: 1rem; color: rgba(255, 255, 255, 0.7); line-height: 1.6; margin: 0; }
  .about-phase strong { color: white; }
  .about-mission { font-family: var(--font-body); font-size: 1.125rem; color: rgba(255, 255, 255, 0.6); line-height: 1.7; border-left: 3px solid rgb(249, 115, 22); padding-left: 1.5rem; font-style: italic; margin-bottom: 2.5rem; }
  .about-players { margin-top: 0; }
  .about-players-label { font-family: var(--font-body); font-size: 0.8rem; color: rgba(255, 255, 255, 0.4); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; margin-bottom: 1.25rem; }
  .about-players-grid { display: flex; gap: 1.5rem; }
  .about-player { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .about-player-photo { width: 64px; height: 64px; border-radius: 50%; overflow: hidden; border: 2px solid rgba(255, 255, 255, 0.1); transition: border-color 0.3s ease; }
  .about-player-photo:hover { border-color: rgba(249, 115, 22, 0.5); }
  .about-player-photo img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1); transition: filter 0.3s ease; }
  .about-player-photo:hover img { filter: grayscale(0.3); }
  .about-player-name { font-family: var(--font-body); font-size: 0.8rem; color: white; font-weight: 600; text-align: center; line-height: 1.2; }
  .about-player-role { font-family: var(--font-body); font-size: 0.7rem; color: rgba(255, 255, 255, 0.6); text-align: center; line-height: 1.3; }
  .about-players-trust { font-family: var(--font-body); text-align: left; font-size: 1.125rem; font-weight: 400; color: rgba(255, 255, 255, 0.7); margin-top: 1rem; font-style: italic; }
  .trust-highlight { color: rgb(249, 115, 22); font-style: normal; }

  @media (max-width: 768px) {
    .about-wrapper { grid-template-columns: 1fr; gap: 3rem; text-align: center; }
    .about-content { margin: 0 auto; }
    .about-phase { text-align: left; }
    .about-mission { text-align: left; }
    .about-players-grid { flex-wrap: wrap; justify-content: center; gap: 1.25rem; }
    .about-player-photo { width: 56px; height: 56px; }
  }
</style>
