---
interface Props {
  title: string;
  subtitle: string;
  primaryHref: string;
  primaryLabel: string;
  primaryVariant?: 'default' | 'obsidian' | 'gsd';
  sectionVariant?: 'default' | 'obsidian' | 'gsd';
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title,
  subtitle,
  primaryHref,
  primaryLabel,
  primaryVariant = 'default',
  sectionVariant = 'default',
  secondaryHref = 'https://wa.me/5545999506444',
  secondaryLabel = 'Falar Comigo',
} = Astro.props;
---

<section class:list={['cta-section', sectionVariant === 'obsidian' && 'obsidian-bg', sectionVariant === 'gsd' && 'gsd-bg']}>
  <div class="container">
    <h2 class="cta-title">{title}</h2>
    <p class="cta-subtitle">{subtitle}</p>
    <div class="cta-buttons">
      <a href={primaryHref} class:list={['btn-primary', primaryVariant === 'obsidian' && 'obsidian', primaryVariant === 'gsd' && 'gsd']}>
        {primaryLabel}
        <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
      <a href={secondaryHref} target="_blank" rel="noopener" class="btn-secondary">
        <svg class="btn-icon" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .cta-section {
    text-align: center;
    padding: 8rem 1.5rem;
    background: linear-gradient(180deg, #0a0a0a 0%, #000 100%);
  }

  .obsidian-bg {
    background: linear-gradient(180deg, #0a0a0a 0%, rgba(155, 81, 224, 0.03) 50%, #000 100%);
  }

  .gsd-bg {
    background: linear-gradient(180deg, #0a0a0a 0%, rgba(16, 185, 129, 0.03) 50%, #000 100%);
  }

  .cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  .cta-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(to right, rgb(249, 115, 22), rgb(234, 88, 12));
    color: white;
    padding: 1rem 2rem;
    border-radius: 100px;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid rgba(251, 146, 60, 0.3);
    box-shadow: 0 4px 15px rgba(249, 115, 22, 0.25);
    transition: all 0.3s;
  }

  .btn-primary.obsidian {
    background: linear-gradient(to right, var(--obsidian, #9b51e0), var(--obsidian-hover, #8040c8));
    border-color: rgba(155, 81, 224, 0.3);
    box-shadow: 0 4px 15px rgba(155, 81, 224, 0.25);
  }

  .btn-primary:hover {
    background: linear-gradient(to right, rgb(234, 88, 12), rgb(194, 65, 12));
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(249, 115, 22, 0.4);
  }

  .btn-primary.obsidian:hover {
    background: linear-gradient(to right, var(--obsidian-hover, #8040c8), var(--obsidian, #9b51e0));
    box-shadow: 0 8px 25px rgba(155, 81, 224, 0.4);
  }

  .btn-primary.gsd {
    background: linear-gradient(to right, var(--gsd, #10b981), var(--gsd-hover, #059669));
    border-color: rgba(16, 185, 129, 0.3);
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.25);
  }

  .btn-primary.gsd:hover {
    background: linear-gradient(to right, var(--gsd-hover, #059669), var(--gsd, #10b981));
    box-shadow: 0 8px 25px rgba(16, 185, 129, 0.4);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: white;
    padding: 1rem 2rem;
    border-radius: 100px;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .btn-icon {
    width: 1.25rem;
    height: 1.25rem;
  }
</style>
