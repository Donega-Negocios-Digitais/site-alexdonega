---
interface Props {
  variant?: 'orange' | 'purple' | 'emerald';
}

const { variant = 'orange' } = Astro.props;

const palettes = {
  orange: {
    pulse1_30: 'rgba(251,146,60,1)',
    pulse1_70: 'rgba(249,115,22,0.8)',
    pulse1_100: 'rgba(249,115,22,0)',
    pulse2_25: 'rgba(251,146,60,0.9)',
    pulse2_60: 'rgba(234,88,12,0.7)',
    pulse2_100: 'rgba(234,88,12,0)',
    bg_0: 'rgba(249,115,22,0.15)',
    bg_40: 'rgba(251,146,60,0.08)',
    bg_80: 'rgba(234,88,12,0.05)',
    thread_15: 'rgba(249,115,22,0.8)',
    thread_85: 'rgba(249,115,22,0.8)',
  },
  purple: {
    pulse1_30: 'rgba(155,81,224,1)',
    pulse1_70: 'rgba(155,81,224,0.8)',
    pulse1_100: 'rgba(155,81,224,0)',
    pulse2_25: 'rgba(155,81,224,0.9)',
    pulse2_60: 'rgba(128,60,200,0.7)',
    pulse2_100: 'rgba(128,60,200,0)',
    bg_0: 'rgba(155,81,224,0.15)',
    bg_40: 'rgba(155,81,224,0.08)',
    bg_80: 'rgba(128,60,200,0.05)',
    thread_15: 'rgba(155,81,224,0.8)',
    thread_85: 'rgba(155,81,224,0.8)',
  },
  emerald: {
    pulse1_30: 'rgba(16,185,129,1)',
    pulse1_70: 'rgba(16,185,129,0.8)',
    pulse1_100: 'rgba(16,185,129,0)',
    pulse2_25: 'rgba(16,185,129,0.9)',
    pulse2_60: 'rgba(5,150,105,0.7)',
    pulse2_100: 'rgba(5,150,105,0)',
    bg_0: 'rgba(16,185,129,0.15)',
    bg_40: 'rgba(16,185,129,0.08)',
    bg_80: 'rgba(5,150,105,0.05)',
    thread_15: 'rgba(16,185,129,0.8)',
    thread_85: 'rgba(16,185,129,0.8)',
  },
} as const;

const colors = palettes[variant];
---

<div class="hero-background">
  <svg
    class="animated-lines"
    viewBox="0 0 1200 800"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid slice"
  >
    <defs>
      <radialGradient id="neonPulse1" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="rgba(255,255,255,1)" />
        <stop offset="30%" stop-color={colors.pulse1_30} />
        <stop offset="70%" stop-color={colors.pulse1_70} />
        <stop offset="100%" stop-color={colors.pulse1_100} />
      </radialGradient>
      <radialGradient id="neonPulse2" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="rgba(255,255,255,0.9)" />
        <stop offset="25%" stop-color={colors.pulse2_25} />
        <stop offset="60%" stop-color={colors.pulse2_60} />
        <stop offset="100%" stop-color={colors.pulse2_100} />
      </radialGradient>
      <radialGradient id="heroTextBg" cx="30%" cy="50%" r="70%">
        <stop offset="0%" stop-color={colors.bg_0} />
        <stop offset="40%" stop-color={colors.bg_40} />
        <stop offset="80%" stop-color={colors.bg_80} />
        <stop offset="100%" stop-color="rgba(0,0,0,0)" />
      </radialGradient>
      <filter id="neonGlow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="2" result="coloredBlur" />
        <feMerge>
          <feMergeNode in="coloredBlur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <linearGradient id="threadFade1" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="rgba(0,0,0,1)" />
        <stop offset="15%" stop-color={colors.thread_15} />
        <stop offset="85%" stop-color={colors.thread_85} />
        <stop offset="100%" stop-color="rgba(0,0,0,1)" />
      </linearGradient>
    </defs>

    <g>
      <ellipse cx="300" cy="350" rx="400" ry="200" fill="url(#heroTextBg)" opacity="0.6" />

      <path id="thread1" d="M50 720 Q200 590 350 540 Q500 490 650 520 Q800 550 950 460 Q1100 370 1200 340" stroke="url(#threadFade1)" stroke-width="0.8" fill="none" opacity="0.8" />
      <circle r="2" fill="url(#neonPulse1)" opacity="1" filter="url(#neonGlow)">
        <animateMotion dur="4s" repeatCount="indefinite"><mpath href="#thread1" /></animateMotion>
      </circle>

      <path id="thread2" d="M80 730 Q250 620 400 570 Q550 520 700 550 Q850 580 1000 490 Q1150 400 1300 370" stroke="url(#threadFade1)" stroke-width="1.5" fill="none" opacity="0.7" />
      <circle r="3" fill="url(#neonPulse2)" opacity="1" filter="url(#neonGlow)">
        <animateMotion dur="5s" repeatCount="indefinite"><mpath href="#thread2" /></animateMotion>
      </circle>

      <path id="thread3" d="M20 710 Q180 580 320 530 Q460 480 600 510 Q740 540 880 450 Q1020 360 1200 330" stroke="url(#threadFade1)" stroke-width="1.2" fill="none" opacity="0.8" />
      <circle r="2.5" fill="url(#neonPulse1)" opacity="1" filter="url(#neonGlow)">
        <animateMotion dur="4.5s" repeatCount="indefinite"><mpath href="#thread3" /></animateMotion>
      </circle>
    </g>
  </svg>
</div>

<style>
  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .animated-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
