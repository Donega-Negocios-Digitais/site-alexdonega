---
// Componente de Hero Animado com linhas fluidas
---

<section class="animated-hero">
  <div class="hero-background">
    <!-- SVG com linhas animadas -->
    <svg
      class="animated-lines"
      viewBox="0 0 1200 800"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <radialGradient id="neonPulse1" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(255,255,255,1)" />
          <stop offset="30%" stop-color="rgba(251,146,60,1)" />
          <stop offset="70%" stop-color="rgba(249,115,22,0.8)" />
          <stop offset="100%" stop-color="rgba(249,115,22,0)" />
        </radialGradient>
        <radialGradient id="neonPulse2" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(255,255,255,0.9)" />
          <stop offset="25%" stop-color="rgba(251,146,60,0.9)" />
          <stop offset="60%" stop-color="rgba(234,88,12,0.7)" />
          <stop offset="100%" stop-color="rgba(234,88,12,0)" />
        </radialGradient>
        <radialGradient id="neonPulse3" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(255,255,255,1)" />
          <stop offset="35%" stop-color="rgba(251,146,60,1)" />
          <stop offset="75%" stop-color="rgba(234,88,12,0.6)" />
          <stop offset="100%" stop-color="rgba(234,88,12,0)" />
        </radialGradient>
        <radialGradient id="heroTextBg" cx="30%" cy="50%" r="70%">
          <stop offset="0%" stop-color="rgba(249,115,22,0.15)" />
          <stop offset="40%" stop-color="rgba(251,146,60,0.08)" />
          <stop offset="80%" stop-color="rgba(234,88,12,0.05)" />
          <stop offset="100%" stop-color="rgba(0,0,0,0)" />
        </radialGradient>
        <filter id="heroTextBlur" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="12" result="blur" />
          <feTurbulence baseFrequency="0.7" numOctaves="4" result="noise" />
          <feColorMatrix in="noise" type="saturate" values="0" result="monoNoise" />
          <feComponentTransfer in="monoNoise" result="alphaAdjustedNoise">
            <feFuncA type="discrete" tableValues="0.03 0.06 0.09 0.12" />
          </feComponentTransfer>
          <feComposite in="blur" in2="alphaAdjustedNoise" operator="multiply" result="noisyBlur" />
          <feMerge>
            <feMergeNode in="noisyBlur" />
          </feMerge>
        </filter>
        <linearGradient id="threadFade1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="rgba(0,0,0,1)" />
          <stop offset="15%" stop-color="rgba(249,115,22,0.8)" />
          <stop offset="85%" stop-color="rgba(249,115,22,0.8)" />
          <stop offset="100%" stop-color="rgba(0,0,0,1)" />
        </linearGradient>
        <linearGradient id="threadFade2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="rgba(0,0,0,1)" />
          <stop offset="12%" stop-color="rgba(251,146,60,0.7)" />
          <stop offset="88%" stop-color="rgba(251,146,60,0.7)" />
          <stop offset="100%" stop-color="rgba(0,0,0,1)" />
        </linearGradient>
        <linearGradient id="threadFade3" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="rgba(0,0,0,1)" />
          <stop offset="18%" stop-color="rgba(234,88,12,0.8)" />
          <stop offset="82%" stop-color="rgba(234,88,12,0.8)" />
          <stop offset="100%" stop-color="rgba(0,0,0,1)" />
        </linearGradient>
        <filter id="neonGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="2" result="coloredBlur" />
          <feMerge>
            <feMergeNode in="coloredBlur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>

      <g>
        <!-- Background ellipses para criar brilho -->
        <ellipse
          cx="300"
          cy="350"
          rx="400"
          ry="200"
          fill="url(#heroTextBg)"
          filter="url(#heroTextBlur)"
          opacity="0.6"
        />
        <ellipse
          cx="350"
          cy="320"
          rx="500"
          ry="250"
          fill="url(#heroTextBg)"
          filter="url(#heroTextBlur)"
          opacity="0.4"
        />

        <!-- Threads animadas (linhas curvas) -->
        {Array.from({ length: 36 }, (_, i) => i + 1).map((threadNum) => {
          const paths = [
            "M50 720 Q200 590 350 540 Q500 490 650 520 Q800 550 950 460 Q1100 370 1200 340",
            "M80 730 Q250 620 400 570 Q550 520 700 550 Q850 580 1000 490 Q1150 400 1300 370",
            "M20 710 Q180 580 320 530 Q460 480 600 510 Q740 540 880 450 Q1020 360 1200 330",
            "M120 740 Q280 640 450 590 Q620 540 770 570 Q920 600 1070 510 Q1220 420 1350 390",
            "M60 725 Q220 600 380 550 Q540 500 680 530 Q820 560 960 470 Q1100 380 1280 350",
            "M150 735 Q300 660 480 610 Q660 560 800 590 Q940 620 1080 530 Q1220 440 1400 410",
          ];
          const threadFades = ["threadFade1", "threadFade2", "threadFade3"];
          const neonPulses = ["neonPulse1", "neonPulse2", "neonPulse3"];

          const pathIndex = (threadNum - 1) % paths.length;
          const fadeIndex = (threadNum - 1) % threadFades.length;
          const pulseIndex = (threadNum - 1) % neonPulses.length;
          const duration = 4 + (threadNum % 3);
          const strokeWidth = 0.3 + (threadNum % 5) * 0.3;
          const opacity = 0.4 + (threadNum % 3) * 0.2;
          const radius = 1 + (threadNum % 4) * 0.5;

          return (
            <>
              <path
                id={`thread${threadNum}`}
                d={paths[pathIndex]}
                stroke={`url(#${threadFades[fadeIndex]})`}
                stroke-width={strokeWidth}
                fill="none"
                opacity={opacity}
              />
              <circle r={radius} fill={`url(#${neonPulses[pulseIndex]})`} opacity="1" filter="url(#neonGlow)">
                <animateMotion dur={`${duration}s`} repeatCount="indefinite">
                  <mpath href={`#thread${threadNum}`} />
                </animateMotion>
              </circle>
            </>
          );
        })}
      </g>
    </svg>
  </div>

  <!-- Conteúdo do Hero -->
  <div class="hero-content">
    <header class="hero-header">
      <div class="logo-container">
        <img src="/favicon.svg" alt="Logo" class="logo" />
      </div>

      <nav class="nav-desktop">
        <a href="#" class="nav-link">Features</a>
        <a href="#" class="nav-link">Pricing</a>
        <a href="#" class="nav-link">About us</a>
        <a href="#" class="nav-link">Contact</a>
      </nav>

      <button class="nav-mobile-toggle" id="mobileMenuToggle">
        <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <button class="cta-button shimmer-button">
        Deploy Now
      </button>
    </header>

    <div class="nav-mobile" id="mobileMenu">
      <nav class="nav-mobile-content">
        <a href="#" class="nav-link">Features</a>
        <a href="#" class="nav-link">Pricing</a>
        <a href="#" class="nav-link">About us</a>
        <a href="#" class="nav-link">Contact</a>
        <button class="cta-button shimmer-button">Deploy Now</button>
      </nav>
    </div>

    <main class="hero-main">
      <div class="trial-badge">
        <span class="trial-text">Try 14 days trial free</span>
      </div>

      <h1 class="hero-title">
        Build a Portfolio<br />
        in <span class="text-styled" data-text="Minutes">Minutes</span>
      </h1>

      <p class="hero-description">
        Join a Community of Digital Artists<br class="hidden-mobile" />
        <span class="mobile-space"> </span>
        Sharing Breathtaking Landscapes.
      </p>

      <button class="get-started-button">
        Get Started
        <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </button>
    </main>
  </div>
</section>

<style>
  .animated-hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: #000;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    background: black;
  }

  .animated-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* Header */
  .hero-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
  }

  @media (min-width: 1024px) {
    .hero-header {
      padding: 1rem 3rem;
    }
  }

  .logo-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-left: 1.5rem;
  }

  @media (min-width: 1024px) {
    .logo-container {
      padding-left: 3rem;
    }
  }

  .logo {
    width: 2rem;
    height: 2rem;
  }

  @media (min-width: 640px) {
    .logo {
      width: 2.5rem;
      height: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .logo {
      width: 3rem;
      height: 3rem;
    }
  }

  /* Navigation */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.8);
    transition: color 0.3s;
    text-decoration: none;
    font-size: 0.875rem;
  }

  @media (min-width: 1024px) {
    .nav-link {
      font-size: 1rem;
    }
  }

  .nav-link:hover {
    color: white;
  }

  .nav-mobile-toggle {
    display: block;
    color: white;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .nav-mobile-toggle {
      display: none;
    }
  }

  .menu-icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .nav-mobile {
    display: none;
    position: absolute;
    top: 4rem;
    left: 0;
    right: 0;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 20;
  }

  .nav-mobile.active {
    display: block;
  }

  @media (min-width: 768px) {
    .nav-mobile {
      display: none !important;
    }
  }

  .nav-mobile-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
  }

  /* CTA Button - Shimmer style */
  .cta-button {
    display: none;
    position: relative;
    background: linear-gradient(to right, rgb(249, 115, 22), rgb(234, 88, 12));
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid rgba(251, 146, 60, 0.3);
    box-shadow: 0 4px 15px rgba(249, 115, 22, 0.25);
    cursor: pointer;
    transition: all 0.3s;
    overflow: hidden;
  }

  .cta-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    animation: shimmer 3s infinite;
  }

  .cta-button:hover {
    background: linear-gradient(to right, rgb(234, 88, 12), rgb(194, 65, 12));
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 25px rgba(249, 115, 22, 0.4);
  }

  @media (min-width: 768px) {
    .cta-button {
      display: flex;
    }
  }

  @media (min-width: 1024px) {
    .cta-button {
      padding: 0.5rem 1.5rem;
      font-size: 1rem;
    }
  }

  @keyframes shimmer {
    100% {
      left: 100%;
    }
  }

  /* Main Content */
  .hero-main {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    flex: 1;
    padding: 1rem 1.5rem;
    max-width: 72rem;
    padding-left: 3rem;
  }

  @media (min-width: 640px) {
    .hero-main {
      padding-left: 3rem;
      margin-top: -3rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-main {
      padding: 1rem 3rem;
      padding-left: 5rem;
      margin-top: -6rem;
    }
  }

  .trial-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 9999px;
    padding: 0.5rem 1rem;
    margin-bottom: 2rem;
  }

  .trial-text {
    color: white;
    font-size: 0.75rem;
  }

  @media (min-width: 768px) {
    .trial-text {
      font-size: 0.75rem;
    }
  }

  /* Title */
  .hero-title {
    color: white;
    font-size: 2.25rem;
    font-weight: bold;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    text-wrap: balance;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: 3.75rem;
    }
  }

  @media (min-width: 1280px) {
    .hero-title {
      font-size: 6rem;
    }
  }

  .text-styled {
    position: relative;
    font-style: italic;
    font-weight: 300;
    display: inline-flex;
  }

  .text-styled::after {
    content: attr(data-text);
    position: absolute;
    left: 0.04em;
    top: 0.04em;
    background: linear-gradient(
      45deg,
      transparent 45%,
      white 45%,
      white 55%,
      transparent 0
    );
    z-index: -1;
    background-size: 0.06em 0.06em;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: line-shadow 15s linear infinite;
  }

  @keyframes line-shadow {
    0% {
      background-position: 0 0;
    }
    100% {
      background-position: 100% -100%;
    }
  }

  /* Description */
  .hero-description {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    margin-bottom: 2rem;
    max-width: 42rem;
    text-wrap: pretty;
  }

  @media (min-width: 640px) {
    .hero-description {
      font-size: 1rem;
    }
  }

  @media (min-width: 768px) {
    .hero-description {
      font-size: 0.875rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-description {
      font-size: 1.5rem;
    }
  }

  .hidden-mobile {
    display: none;
  }

  @media (min-width: 640px) {
    .hidden-mobile {
      display: block;
    }
  }

  .mobile-space {
    display: inline;
  }

  @media (min-width: 640px) {
    .mobile-space {
      display: none;
    }
  }

  /* Get Started Button */
  .get-started-button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(to right, rgb(249, 115, 22), rgb(234, 88, 12));
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid rgba(251, 146, 60, 0.3);
    box-shadow: 0 4px 15px rgba(249, 115, 22, 0.25);
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .get-started-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    animation: shimmer 3s infinite;
  }

  @media (min-width: 640px) {
    .get-started-button {
      padding: 0.875rem 2rem;
      font-size: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .get-started-button {
      font-size: 1.125rem;
    }
  }

  .get-started-button:hover {
    background: linear-gradient(to right, rgb(234, 88, 12), rgb(194, 65, 12));
    box-shadow: 0 8px 25px rgba(249, 115, 22, 0.4);
    transform: translateY(-2px) scale(1.05);
  }

  .get-started-button:hover .arrow-icon {
    transform: translateX(4px) rotate(-12deg);
  }

  .arrow-icon {
    width: 1.25rem;
    height: 1.25rem;
    transition: transform 0.3s;
  }
</style>

<script>
  // Mobile menu toggle
  const mobileMenuToggle = document.getElementById('mobileMenuToggle');
  const mobileMenu = document.getElementById('mobileMenu');

  mobileMenuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('active');
  });
</script>
