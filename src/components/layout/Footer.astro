---
// Footer.astro - Componente reutilizável de rodapé
// Use em qualquer pagina Astro: import Footer from '../components/layout/Footer.astro'
---

<footer class="footer">
    <div class="footer-content">
        <div class="footer-brand">
            <h4>Alex Donega</h4>
            <p>Fundador de SaaS. Explorando IA na prática e compartilhando a jornada sem filtro.</p>
            <p class="signature">"Testando, errando e compartilhando."</p>
        </div>

        <div class="footer-column">
            <h5>Navegação</h5>
            <a href="#sobre">Sobre</a>
            <a href="#servicos">Serviços</a>
            <a href="#portfolio">Portfólio</a>
            <a href="#conteudo">Conteúdo</a>
            <a href="/politicas/">Políticas</a>
        </div>

        <div class="footer-column">
            <h5>Cursos</h5>
            <a href="/engenharia-de-contexto-aplicado-ao-marketing-digital/">Context Engineering</a>
            <a href="/claude-code-em-1-dia/">Claude Code em 1 Dia</a>
            <a href="/segundo-cerebro-com-obsidian/">Segundo Cérebro</a>
        </div>

        <div class="footer-column">
            <h5>Contato</h5>
            <a href="https://wa.me/5545999506444" target="_blank">WhatsApp</a>
            <a href="https://instagram.com/donegaalex" target="_blank" rel="noopener noreferrer">Instagram</a>
            <a href="https://youtube.com/@alexdonega" target="_blank" rel="noopener noreferrer">YouTube</a>
            <a href="https://linkedin.com/in/alexdonega" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
    </div>

    <div class="footer-bottom">
        <span>&copy; 2026 Alex Donega. Todos os direitos reservados.</span>
        <span>Toledo-PR, Brasil</span>
    </div>
</footer>

<style>
    .footer {
        padding: 48px 24px;
        background: #0a0a0a;
        border-top: 1px solid #2a2a2a;
        width: 100%;
    }

    .footer-content {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr;
        gap: 32px;
    }

    .footer-brand h4 {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: #FFFFFF;
        margin-bottom: 12px;
    }

    .footer-brand p {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 13px;
        color: #FFFFFF;
        opacity: 0.85;
        line-height: 1.5;
    }

    .footer-brand .signature {
        font-style: italic;
        opacity: 0.9;
        margin-top: 12px;
        font-size: 13px;
    }

    .footer-column h5 {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 18px;
        font-weight: 600;
        color: #FFFFFF;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 20px;
    }

    .footer-column a {
        display: block;
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 14px;
        font-weight: 400;
        color: #FFFFFF;
        opacity: 0.85;
        text-decoration: none;
        margin-bottom: 12px;
        line-height: 1.5;
        transition: opacity 0.2s;
    }

    .footer-column a:hover {
        opacity: 1;
    }

    .footer-bottom {
        max-width: 1200px;
        margin: 32px auto 0;
        padding-top: 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        text-align: center;
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 12px;
        color: #FFFFFF;
        opacity: 0.7;
    }

    .footer-bottom a {
        color: #FFFFFF;
        text-decoration: none;
    }

    .footer-bottom a:hover {
        opacity: 1;
    }

    /* Tablet (min-width: 768px) */
    @media (min-width: 768px) {
        .footer {
            padding: 56px 24px;
        }

        .footer-content {
            grid-template-columns: repeat(2, 1fr);
            gap: 40px;
        }

        .footer-bottom {
            flex-direction: row;
            justify-content: space-between;
            text-align: left;
        }
    }

    /* Desktop (min-width: 1024px) */
    @media (min-width: 1024px) {
        .footer-content {
            grid-template-columns: repeat(4, 1fr);
        }
    }
</style>
