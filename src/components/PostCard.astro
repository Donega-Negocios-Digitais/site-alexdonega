---
interface Props {
  slug: string;
  title: string;
  description?: string;
  image?: string;
  tags?: string[];
  pubDate: Date;
  author?: string;
  // Atributos extras para filtros (usados na página de listagem)
  dataAttrs?: {
    tags?: string;
    title?: string;
    description?: string;
  };
}

const {
  slug,
  title,
  description,
  image,
  tags = [],
  pubDate,
  author = 'Alex Donega',
  dataAttrs
} = Astro.props;

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('pt-BR', {
    day: '2-digit',
    month: 'short',
    year: 'numeric'
  }).format(date);
};
---

<article
  class="post-card"
  data-tags={dataAttrs?.tags}
  data-title={dataAttrs?.title}
  data-description={dataAttrs?.description}
>
  <a href={`/blog/${slug}`} class="post-card-link">
    <div
      class="post-card-image"
      style={image ? `background-image: url(${image}); background-size: cover; background-position: center;` : ''}
    >
      <div class="post-card-category">
        {tags[0] || 'Artigo'}
      </div>
    </div>

    <div class="post-card-content">
      <h2 class="post-card-title">{title}</h2>
      {description && (
        <p class="post-card-description">{description}</p>
      )}

      <div class="post-card-footer">
        <div class="post-card-author">
          <img
            src="/images/alex-donega-autor-blog.webp"
            alt={author}
            class="author-avatar-img"
          />
          <div class="author-info">
            <span class="author-name">{author}</span>
            <time datetime={pubDate.toISOString()}>
              {formatDate(pubDate)}
            </time>
          </div>
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  :root {
    --bg-card: #1a1a1a;
    --bg-card-hover: #222222;
    --text-white: #ffffff;
    --text-gray: #a3a3a3;
    --text-muted: #737373;
    --accent: #d87757;
    --border: #2a2a2a;
  }

  /* Por padrão visível. Na página de listagem, o parent .posts-grid controla a visibilidade */
  .post-card {
    display: block;
  }

  :global(.posts-grid) .post-card {
    display: none;
  }

  :global(.posts-grid) .post-card.visible {
    display: block;
  }

  .post-card-link {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s;
    height: 100%;
  }

  .post-card-link:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(216, 119, 87, 0.15);
  }

  .post-card-image {
    position: relative;
    height: 200px;
    background: linear-gradient(135deg, var(--accent) 0%, #ff9966 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .post-card-category {
    position: absolute;
    top: 16px;
    left: 16px;
    background: rgba(10, 10, 10, 0.8);
    color: var(--text-white);
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .post-card-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-card-title {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--text-white);
    margin-bottom: 12px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-description {
    color: var(--text-gray);
    margin-bottom: 20px;
    line-height: 1.6;
    font-size: 15px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .post-card-footer {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .post-card-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .author-avatar-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .author-name {
    color: var(--text-white);
    font-weight: 500;
    font-size: 14px;
  }

  .author-info time {
    color: var(--text-muted);
    font-size: 13px;
  }
</style>
