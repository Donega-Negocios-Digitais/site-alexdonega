---
// Badge.astro - Componente de badge estilo shadcn/ui

interface Props {
  variant?: 'default' | 'secondary' | 'outline' | 'destructive';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const baseClasses = 'inline-flex items-center rounded-full px-3 py-1 text-xs font-medium transition-colors';

const variants = {
  default: 'bg-accent text-white',
  secondary: 'bg-secondary text-secondary-foreground',
  outline: 'border border-border text-foreground',
  destructive: 'bg-destructive text-destructive-foreground',
};
---

<span class={`${baseClasses} ${variants[variant]} ${className}`}>
  <slot />
</span>
