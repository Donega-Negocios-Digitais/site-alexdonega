---
interface Props {}

const notifications = [
  { name: 'Rafael', city: 'SP', action: 'solicitou o Mapa de Funil', time: '2' },
  { name: 'Juliana', city: 'RJ', action: 'reservou a vaga Estratégia', time: '5' },
  { name: 'Marcos', city: 'MG', action: 'solicitou o Mapa de Funil', time: '8' },
  { name: 'Camila', city: 'PR', action: 'reservou a vaga Implementação', time: '12' },
  { name: 'Lucas', city: 'SC', action: 'solicitou o Mapa de Funil', time: '15' },
  { name: 'Fernanda', city: 'BA', action: 'reservou a vaga Estratégia', time: '18' },
  { name: 'Thiago', city: 'RS', action: 'solicitou o Mapa de Funil', time: '22' },
  { name: 'Amanda', city: 'PE', action: 'reservou a vaga Implementação', time: '25' },
];
---

<div id="social-proof-toast" class="social-proof-toast" aria-live="polite">
  <div class="toast-card">
    <div class="toast-avatar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
    </div>
    <div class="toast-content">
      <p class="toast-name" id="toast-name"></p>
      <p class="toast-time" id="toast-time"></p>
    </div>
    <button class="toast-close" id="toast-close" aria-label="Fechar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
</div>

<style>
  .social-proof-toast {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 80;
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .social-proof-toast.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .toast-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(26, 26, 26, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 0.875rem 1rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
    max-width: 300px;
  }
  .toast-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(249, 115, 22, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .toast-avatar svg { width: 22px; height: 22px; color: rgb(249, 115, 22); }
  .toast-content { flex: 1; min-width: 0; }
  .toast-name { font-family: var(--font-body); font-size: 0.85rem; font-weight: 600; color: white; margin: 0; line-height: 1.3; }
  .toast-time { font-family: var(--font-body); font-size: 0.75rem; color: rgba(255, 255, 255, 0.5); margin: 0.15rem 0 0; }
  .toast-close {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
    border-radius: 6px;
    transition: all 0.2s;
  }
  .toast-close:hover { color: rgba(255, 255, 255, 0.8); background: rgba(255, 255, 255, 0.05); }
  .toast-close svg { width: 16px; height: 16px; }

  @media (max-width: 768px) {
    .social-proof-toast { bottom: auto; top: auto; left: 0.75rem; right: 0.75rem; bottom: 5rem; }
    .toast-card { max-width: 100%; }
  }
</style>

<script is:inline>
  (function() {
    var notifications = [
      { name: 'Rafael', city: 'SP', action: 'solicitou o Mapa de Funil', time: '2' },
      { name: 'Juliana', city: 'RJ', action: 'reservou a vaga Estratégia', time: '5' },
      { name: 'Marcos', city: 'MG', action: 'solicitou o Mapa de Funil', time: '8' },
      { name: 'Camila', city: 'PR', action: 'reservou a vaga Implementação', time: '12' },
      { name: 'Lucas', city: 'SC', action: 'solicitou o Mapa de Funil', time: '15' },
      { name: 'Fernanda', city: 'BA', action: 'reservou a vaga Estratégia', time: '18' },
      { name: 'Thiago', city: 'RS', action: 'solicitou o Mapa de Funil', time: '22' },
      { name: 'Amanda', city: 'PE', action: 'reservou a vaga Implementação', time: '25' }
    ];

    var toast = document.getElementById('social-proof-toast');
    var nameEl = document.getElementById('toast-name');
    var timeEl = document.getElementById('toast-time');
    var closeBtn = document.getElementById('toast-close');

    if (!toast || !nameEl || !timeEl) return;

    var currentIndex = 0;
    var isVisible = false;
    var timeout = null;
    var cooldown = false;
    var minTimeOnPage = 30000;
    var minScrollDepth = 0.3;
    var showInterval = 20000;
    var hideDelay = 6000;

    function shouldShow() {
      if (cooldown) return false;
      if (Date.now() - pageLoadTime < minTimeOnPage) return false;
      var scrollDepth = window.pageYOffset / (document.documentElement.scrollHeight - document.documentElement.clientHeight || 1);
      return scrollDepth >= minScrollDepth;
    }

    function show() {
      if (!shouldShow() || isVisible) return;
      var n = notifications[currentIndex];
      nameEl.textContent = n.name + ' de ' + n.city + ' ' + n.action;
      timeEl.textContent = 'há ' + n.time + ' minutos';
      toast.classList.add('visible');
      isVisible = true;
      currentIndex = (currentIndex + 1) % notifications.length;
      timeout = setTimeout(hide, hideDelay);
    }

    function hide() {
      if (timeout) clearTimeout(timeout);
      toast.classList.remove('visible');
      isVisible = false;
      cooldown = true;
      setTimeout(function() { cooldown = false; }, 10000);
    }

    if (closeBtn) closeBtn.addEventListener('click', hide);

    var pageLoadTime = Date.now();
    setInterval(show, showInterval);

    // Don't show if sticky CTA is visible (mobile)
    window.addEventListener('scroll', function() {
      if (isVisible) {
        var stickyCta = document.getElementById('sticky-cta-mobile');
        if (stickyCta && stickyCta.classList.contains('visible')) {
          hide();
        }
      }
    }, { passive: true });
  })();
</script>
