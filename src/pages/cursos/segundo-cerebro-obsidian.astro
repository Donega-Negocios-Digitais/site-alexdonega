    --obsidian-light: rgba(155, 81, 224, 0.1);
    --obsidian-hover: #8040c8;
  }

  /* ==================== HERO SECTION ==================== */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #000;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .animated-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
  }

  .hero-text-center {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-badge {
    margin-bottom: 2rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(155, 81, 224, 0.3);
    border-radius: 9999px;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    color: var(--obsidian);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    animation: pulse-dot 2s infinite;
  }

  .badge-dot.obsidian {
    background: var(--obsidian);
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.2); }
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: white;
    margin-bottom: 1.5rem;
  }

  .text-obsidian {
    color: var(--obsidian);
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-video {
    max-width: 800px;
    margin: 0 auto 2rem;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(155, 81, 224, 0.2);
  }

  .hero-video video {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-description {
    font-size: clamp(0.9375rem, 1.5vw, 1.125rem);
