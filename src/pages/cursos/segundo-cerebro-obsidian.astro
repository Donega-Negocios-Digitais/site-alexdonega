---
// segundo-cerebro-obsidian.astro - Página do curso Segundo Cérebro com Obsidian (Design v2)
import Layout from '../../layouts/Layout.astro';
import HeroAnimatedBackground from '../../components/course/HeroAnimatedBackground.astro';
import CourseFinalCta from '../../components/course/CourseFinalCta.astro';
import CourseFaqSection from '../../components/course/CourseFaqSection.astro';

const courseFaqItems = [
  {
    question: 'Preciso saber programar?',
    answer: 'Não! O Obsidian é feito para qualquer pessoa. Você não precisa de nenhum conhecimento técnico.',
    button: { text: 'Ver módulo de instalação →', href: '#modulos' },
  },
  {
    question: 'Funciona para qualquer área?',
    answer: 'Sim. O Segundo Cérebro é universal e pode ser adaptado para qualquer área de atuação ou interesse.',
    button: { text: 'Ver exemplos por área →', href: '#exemplos' },
  },
  {
    question: 'Quanto tempo tenho acesso?',
    answer: 'Acesso vitalício. Comprou uma vez, seu para sempre.',
    button: { text: 'Ver detalhes do acesso →', href: '#investimento' },
  },
  {
    question: 'E se eu não gostar?',
    answer: 'Garantia de 7 dias. Devolvo 100% do seu dinheiro sem perguntas.',
    button: { text: 'Falar sobre garantia →', href: 'https://wa.me/5545999506444', variant: 'secondary' as const },
  },
  {
    question: 'O Obsidian é gratuito?',
    answer: 'Sim! O Obsidian é 100% gratuito para uso pessoal. Você só paga pelo curso, não pelo app.',
    button: { text: 'Baixar Obsidian →', href: 'https://obsidian.md', variant: 'secondary' as const },
  },
];
---

<Layout
  title="Segundo Cérebro com Obsidian - Clone seu Cérebro"
  description="Aprenda a construir seu Segundo Cérebro no Obsidian. Organize ideias, conecte pensamentos e nunca mais esqueça nada importante."
>

<!-- Hero Section com Animação -->
<section class="hero-section">
  <HeroAnimatedBackground variant="purple" />

  <!-- Conteudo Principal -->
  <div class="hero-content">
    <div class="hero-text-center">
      <!-- Badge -->
      <div class="hero-badge">
        <span class="badge">
          <span class="badge-dot obsidian"></span>
          Curso Completo
        </span>
      </div>

      <!-- Titulo Principal -->
      <h1 class="hero-title">
        Clone seu Cérebro,<br>
        Domine o <span class="text-obsidian">Obsidian</span>
      </h1>

      <!-- Subtitulo -->
      <p class="hero-subtitle">
        Aprenda a construir seu Segundo Cérebro no Obsidian. Organize ideias, conecte pensamentos e nunca mais esqueça nada importante.
      </p>

      <!-- Video Container -->
      <div class="hero-video">
        <video autoplay loop muted playsinline>
          <source src="https://go.academialendaria.ai/wp-content/uploads/2025/11/canvas-hero-1-1.mp4" type="video/mp4">
        </video>
      </div>

      <!-- Descrição -->
      <p class="hero-description">
        Dobre sua produtividade usando um Segundo Cérebro com I.A que organiza suas informações, conecta suas ideias e cria projetos para você
      </p>

      <!-- CTA -->
      <div class="hero-cta">
        <a href="#investimento" class="btn-primary obsidian">
          Comece agora
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Seção 01: Por que ter um Segundo Cérebro -->
<section class="section" id="porque">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow obsidian">01 - Clone seu Cérebro</span>
      <h2 class="section-title">Por que ter um Segundo Cérebro no <span class="text-obsidian">Obsidian</span>?</h2>
      <p class="section-subtitle">
        Seu cérebro foi feito para ter ideias, não para armazená-las. Liberte sua mente delegando a memória para um sistema confiável.
      </p>
    </div>

    <div class="benefits-grid">
      <div class="benefit-card obsidian">
        <div class="benefit-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/>
            <path d="M12 6a1 1 0 0 0-1 1v5a1 1 0 0 0 .29.71l3 3a1 1 0 0 0 1.42-1.42L13 11.59V7a1 1 0 0 0-1-1z"/>
          </svg>
        </div>
        <h3>Nunca mais esqueça nada</h3>
        <p>Capture ideias, insights e informações importantes em segundos. Tudo fica salvo e organizado automaticamente.</p>
      </div>

      <div class="benefit-card obsidian">
        <div class="benefit-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-5.07l-2.83 2.83M9.76 14.24l-2.83 2.83m0-10.14l2.83 2.83m4.48 4.48l2.83 2.83"/>
          </svg>
        </div>
        <h3>Conecte suas ideias</h3>
        <p>Crie links entre suas notas e descubra conexões que você nunca imaginaria. Seu conhecimento vira uma rede viva.</p>
      </div>

      <div class="benefit-card obsidian">
        <div class="benefit-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
            <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
          </svg>
        </div>
        <h3>Produza mais rápido</h3>
        <p>Com suas ideias organizadas, criar conteúdo, tomar decisões e resolver problemas se torna muito mais fácil.</p>
      </div>
    </div>

    <div class="section-cta">
      <a href="#investimento" class="btn-primary obsidian">Quero organizar minhas ideias</a>
    </div>
  </div>
</section>

<!-- Secao: Obsidian na Era da IA -->
<section class="section-dark obsidian-bg" id="ia">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow obsidian">A Nova Fronteira</span>
      <h2 class="section-title">O <span class="text-obsidian">Obsidian</span> nunca foi tão poderoso</h2>
      <p class="section-subtitle">
        Estamos vivendo uma revolução. A IA está mudando tudo — menos uma coisa: <strong class="text-white">quem tem contexto, vence.</strong>
      </p>
    </div>

    <div class="benefits-grid">
      <div class="benefit-card obsidian">
        <div class="benefit-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h3>Contexto e o novo ouro</h3>
        <p>A IA não lê mentes. Ela lê contexto. Quanto mais rico e organizado for o seu segundo cérebro, mais poderosa a IA se torna nas suas mãos.</p>
      </div>

      <div class="benefit-card obsidian">
        <div class="benefit-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 16v-4M12 8h.01"/>
          </svg>
        </div>
        <h3>Engenharia de Contexto</h3>
        <p>Prompts são commodities. O que diferencia quem extrai 10x mais da IA e a qualidade do contexto que você alimenta. Seu Obsidian vira uma mina de ouro.</p>
      </div>

      <div class="benefit-card obsidian">
        <div class="benefit-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v20M2 12h20"/>
            <circle cx="12" cy="12" r="4"/>
          </svg>
        </div>
        <h3>Base de conhecimento viva</h3>
        <p>Cada nota, cada conexão, cada insight que você captura no Obsidian se transforma em combustível para a IA trabalhar POR você, não contra você.</p>
      </div>
    </div>

    <div class="highlight-box obsidian">
      <p class="highlight-quote">"Quem domina o Obsidian hoje, domina a IA amanhã."</p>
      <p class="highlight-text">Enquanto outros ficam perdidos em prompts mágicos, você constrói uma base sólida de contexto engenheizado.</p>
    </div>
  </div>
</section>

<!-- Secao: Metodologia ACE -->
<section class="section" id="metodologia">
  <div class="container">
    <div class="section-header">
      <div class="method-badge">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <span>Metodologia Comprovada</span>
      </div>
      <h2 class="section-title">Nada de teoria vaga. Isso aqui tem estrutura.</h2>
      <p class="section-subtitle">
        Usamos a metodologia ACE, criada por Nick Milo do Linking Your Thinking - o maior especialista mundial em Obsidian. Uma estrutura simples que organiza tudo na sua vida.
      </p>
    </div>

    <div class="ace-grid">
      <div class="ace-card">
        <span class="ace-letter">A</span>
        <h3 class="ace-word">Atlas</h3>
        <p>Seu mapa do conhecimento. Todas as suas notas, ideias, referencias e aprendizados ficam aqui - conectados e acessiveis para sempre.</p>
      </div>

      <div class="ace-card">
        <span class="ace-letter">C</span>
        <h3 class="ace-word">Calendário</h3>
        <p>Seu registro no tempo. Daily notes, reuniões, reflexões e logs. Tudo que acontece na sua vida, organizado cronologicamente.</p>
      </div>

      <div class="ace-card">
        <span class="ace-letter">E</span>
        <h3 class="ace-word">Esforços</h3>
        <p>Suas ações e projetos. Diferente de "tarefas", Esforços são esforços que você puxa quando tem energia - não listas que te cobram.</p>
      </div>
    </div>

    <div class="methodology-quote">
      <p>"O ACE não é mais uma metodologia complicada. É a forma mais simples de organizar conhecimento, tempo e ação em um só lugar."</p>
      <cite>Baseado no framework de <strong>Nick Milo</strong> - Linking Your Thinking</cite>
    </div>

    <div class="section-cta">
      <a href="#investimento" class="btn-primary obsidian">Quero aprender essa metodologia</a>
    </div>
  </div>
</section>

<!-- Secao: Como Funciona -->
<section class="section-dark" id="como-funciona">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow obsidian">O Obsidian na Prática</span>
      <h2 class="section-title">Como funciona o curso</h2>
      <p class="section-subtitle">
        Um método passo a passo para você sair do zero e ter seu Segundo Cérebro funcionando.
      </p>
    </div>

    <div class="steps-grid">
      <div class="step-card">
        <span class="step-number obsidian">1</span>
        <h3>Fundamentos</h3>
        <p>Entenda a filosofia por trás do Segundo Cérebro e por que o Obsidian é a melhor ferramenta para isso.</p>
      </div>
      <div class="step-card">
        <span class="step-number obsidian">2</span>
        <h3>Setup Completo</h3>
        <p>Instale e configure o Obsidian do jeito certo, com os plugins essenciais e templates prontos.</p>
      </div>
      <div class="step-card">
        <span class="step-number obsidian">3</span>
        <h3>Sistema de Captura</h3>
        <p>Aprenda a capturar ideias de qualquer lugar - livros, vídeos, conversas, pensamentos.</p>
      </div>
      <div class="step-card">
        <span class="step-number obsidian">4</span>
        <h3>Organização</h3>
        <p>Crie uma estrutura de pastas e tags que faz sentido para o seu estilo de trabalho.</p>
      </div>
      <div class="step-card">
        <span class="step-number obsidian">5</span>
        <h3>Conexoes</h3>
        <p>Domine os links bidirecionais e veja seu conhecimento se transformar em uma rede poderosa.</p>
      </div>
      <div class="step-card">
        <span class="step-number obsidian">6</span>
        <h3>Produção</h3>
        <p>Use seu Segundo Cérebro para criar conteúdo, tomar decisões e resolver problemas reais.</p>
      </div>
    </div>
  </div>
</section>

<!-- Secao: Para Quem E -->
<section class="section" id="publico">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow obsidian">Para Quem É o Curso</span>
      <h2 class="section-title">Este curso é para você se...</h2>
    </div>

    <div class="audience-grid">
      <div class="audience-card obsidian">
        <div class="audience-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
            <path d="M8 7h6"/>
            <path d="M8 11h8"/>
          </svg>
        </div>
        <h3>Estudantes</h3>
        <p>Quer organizar seus estudos e reter mais conhecimento</p>
      </div>

      <div class="audience-card obsidian">
        <div class="audience-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 19l7-7 3 3-7 7-3-3z"/>
            <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
            <circle cx="11" cy="11" r="2"/>
          </svg>
        </div>
        <h3>Criadores de Conteúdo</h3>
        <p>Precisa de um sistema para nunca ficar sem ideias</p>
      </div>

      <div class="audience-card obsidian">
        <div class="audience-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
        </div>
        <h3>Profissionais</h3>
        <p>Quer aumentar a produtividade e organizar projetos</p>
      </div>

      <div class="audience-card obsidian">
        <div class="audience-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
            <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
          </svg>
        </div>
        <h3>Empreendedores</h3>
        <p>Precisa tomar decisões melhores com base em dados</p>
      </div>

      <div class="audience-card obsidian">
        <div class="audience-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
            <path d="M11 8v6"/>
            <path d="M8 11h6"/>
          </svg>
        </div>
        <h3>Pesquisadores</h3>
        <p>Quer conectar referências e descobrir insights</p>
      </div>

      <div class="audience-card obsidian">
        <div class="audience-icon obsidian">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <circle cx="12" cy="12" r="6"/>
            <circle cx="12" cy="12" r="2"/>
          </svg>
        </div>
        <h3>Curiosos</h3>
        <p>Gosta de aprender e quer um lugar para guardar tudo</p>
      </div>
    </div>

    <div class="section-cta">
      <a href="#investimento" class="btn-primary obsidian">Esse curso é para mim</a>
    </div>
  </div>
</section>

<!-- Secao: Sobre o Professor -->
<section class="section-dark" id="professor">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow obsidian">Conheça seu Professor</span>
      <h2 class="section-title">Quem vai te ensinar</h2>
    </div>

    <div class="about-grid">
      <div class="about-image">
        <img src="/img/people/alex-donega.webp" alt="Alex Donega" loading="lazy" />
      </div>
      <div class="about-content">
        <h3>Alex Donega</h3>
        <p>Uso o Obsidian todos os dias há mais de 3 anos. Ele é o centro do meu sistema de trabalho - de onde saem todos os meus conteúdos, projetos e decisões.</p>
        <p>Sou Gestor de Projetos na Autobots Ventures, trabalho com +25 software no ecossistema Autobots Ventures, e ensino empreendedores a dominar IA de verdade usando Context Engineering.</p>
        <p>Já quebrei duas empresas antes de descobrir que o problema era falta de sistema. Hoje, com meu Segundo Cérebro no Obsidian, nada se perde. Cada ideia, cada aprendizado, cada conexão fica registrada e acessível.</p>

        <blockquote class="about-quote obsidian">
          "O Obsidian não é só um app de notas. É uma extensão do seu cérebro."
        </blockquote>

        <a href="#investimento" class="btn-primary obsidian">Quero aprender com o Alex</a>
      </div>
    </div>
  </div>
</section>

<!-- Secao: Modulos -->
<section class="section" id="conteudo">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow obsidian">O Que Você Vai Receber</span>
      <h2 class="section-title">Conteúdo completo do curso</h2>
    </div>

    <div class="modules-grid">
      <div class="module-card">
        <span class="module-badge obsidian">Modulo 1</span>
        <h3>Fundamentos do Segundo Cérebro</h3>
        <p>Entenda a filosofia e os princípios que fazem o sistema funcionar.</p>
        <ul class="module-list">
          <li><span class="check obsidian">✓</span> O que é um Segundo Cérebro</li>
          <li><span class="check obsidian">✓</span> Por que o Obsidian</li>
          <li><span class="check obsidian">✓</span> Mindset de organizacao</li>
        </ul>
      </div>

      <div class="module-card">
        <span class="module-badge obsidian">Módulo 2</span>
        <h3>Setup e Configuração</h3>
        <p>Instale e configure o Obsidian do jeito certo desde o início.</p>
        <ul class="module-list">
          <li><span class="check obsidian">✓</span> Instalação passo a passo</li>
          <li><span class="check obsidian">✓</span> Plugins essenciais</li>
          <li><span class="check obsidian">✓</span> Temas e aparencia</li>
        </ul>
      </div>

      <div class="module-card">
        <span class="module-badge obsidian">Módulo 3</span>
        <h3>Sistema de Notas</h3>
        <p>Crie uma estrutura que funciona para você.</p>
        <ul class="module-list">
          <li><span class="check obsidian">✓</span> Estrutura de pastas</li>
          <li><span class="check obsidian">✓</span> Tags e metadados</li>
          <li><span class="check obsidian">✓</span> Templates prontos</li>
        </ul>
      </div>

      <div class="module-card">
        <span class="module-badge obsidian">Módulo 4</span>
        <h3>Captura e Processamento</h3>
        <p>Aprenda a capturar ideias de qualquer fonte.</p>
        <ul class="module-list">
          <li><span class="check obsidian">✓</span> Captura rápida</li>
          <li><span class="check obsidian">✓</span> Processamento de notas</li>
          <li><span class="check obsidian">✓</span> Inbox Zero</li>
        </ul>
      </div>

      <div class="module-card">
        <span class="module-badge obsidian">Módulo 5</span>
        <h3>Links e Conexões</h3>
        <p>Transforme notas isoladas em uma rede de conhecimento.</p>
        <ul class="module-list">
          <li><span class="check obsidian">✓</span> Links bidirecionais</li>
          <li><span class="check obsidian">✓</span> Grafo de conhecimento</li>
          <li><span class="check obsidian">✓</span> MOCs e índices</li>
        </ul>
      </div>

      <div class="module-card">
        <span class="module-badge obsidian">Módulo 6</span>
        <h3>Workflows Avançados</h3>
        <p>Use o Obsidian para produzir e criar.</p>
        <ul class="module-list">
          <li><span class="check obsidian">✓</span> Daily Notes</li>
          <li><span class="check obsidian">✓</span> Projetos e tarefas</li>
          <li><span class="check obsidian">✓</span> Integração com IA</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Seção: Bônus -->
<section class="section bonus-section obsidian-bg">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow obsidian">Bônus Exclusivos</span>
      <h2 class="section-title">Bônus por tempo limitado</h2>
      <p class="section-subtitle">
        Além do curso completo, você ainda recebe esses bônus especiais.
      </p>
    </div>

    <div class="bonus-grid">
      <div class="bonus-card">
        <div class="bonus-ribbon obsidian">BÔNUS</div>
        <h3>Vault Starter Kit</h3>
        <p>Um vault pré-configurado com estrutura de pastas, templates e plugins prontos para usar.</p>
        <span class="bonus-value">Valor: <strong>R$ 197</strong></span>
      </div>

      <div class="bonus-card">
        <div class="bonus-ribbon obsidian">BÔNUS</div>
        <h3>30 Templates Prontos</h3>
        <p>Templates para daily notes, reuniões, projetos, livros, artigos e muito mais.</p>
        <span class="bonus-value">Valor: <strong>R$ 97</strong></span>
      </div>

      <div class="bonus-card">
        <div class="bonus-ribbon obsidian">BÔNUS</div>
        <h3>Comunidade Exclusiva</h3>
        <p>Acesso ao grupo de alunos para tirar dúvidas, trocar ideias e fazer networking.</p>
        <span class="bonus-value">Valor: <strong>R$ 297</strong></span>
      </div>

      <div class="bonus-card">
        <div class="bonus-ribbon obsidian">BÔNUS</div>
        <h3>Atualizações Vitalícias</h3>
        <p>Todas as atualizações futuras do curso incluídas, sem pagar nada a mais.</p>
