    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-cta {
    margin-bottom: 2rem;
  }

  /* ==================== BUTTONS ==================== */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(to right, rgb(249, 115, 22), rgb(234, 88, 12));
    color: white;
    padding: 1rem 2rem;
    border-radius: 100px;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid rgba(251, 146, 60, 0.3);
    box-shadow: 0 4px 15px rgba(249, 115, 22, 0.25);
    transition: all 0.3s;
  }

  .btn-primary.obsidian {
    background: linear-gradient(to right, var(--obsidian), var(--obsidian-hover));
    border-color: rgba(155, 81, 224, 0.3);
    box-shadow: 0 4px 15px rgba(155, 81, 224, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(249, 115, 22, 0.4);
  }

  .btn-primary.obsidian:hover {
    box-shadow: 0 8px 25px rgba(155, 81, 224, 0.4);
  }

  .btn-secondary {
