---
import Layout from "../../layouts/Layout.astro";
import HeroAnimatedBackground from "../../components/course/HeroAnimatedBackground.astro";
import CourseFinalCta from "../../components/course/CourseFinalCta.astro";
import CourseFaqSection from "../../components/course/CourseFaqSection.astro";

const courseFaqItems = [
    {
        question: "Preciso saber programar?",
        answer: "Sim, e recomendado ter conhecimento basico de HTML, CSS e JavaScript. Voce nao precisa ser expert, mas o curso assume familiaridade com desenvolvimento web.",
        button: { text: "Ver modulo de fundamentos →", href: "#conteudo" },
    },
    {
        question: "O curso esta atualizado com Astro 5?",
        answer: "Sim! O curso cobre Astro 5 e sera atualizado conforme novas versoes forem lancadas. Voce recebe todas as atualizacoes.",
        button: { text: "Ver conteudo completo →", href: "#conteudo" },
    },
    {
        question: "Quanto tempo tenho acesso?",
        answer: "Acesso vitalicio. Comprou uma vez, seu para sempre. Incluindo todas as atualizacoes futuras.",
        button: { text: "Ver detalhes do acesso →", href: "#investimento" },
    },
    {
        question: "Posso usar Astro com React/Vue/Svelte?",
        answer: "Com certeza! O Astro foi feito para integrar com qualquer framework UI. O curso cobre como usar React, Vue, Svelte e outros dentro do Astro.",
        button: { text: "Ver modulo de integracao →", href: "#conteudo" },
    },
    {
        question: "E se eu nao gostar?",
        answer: "Garantia de 7 dias. Devolvo 100% do seu dinheiro sem perguntas.",
        button: {
            text: "Falar sobre garantia →",
            href: "https://wa.me/5545999506444",
            variant: "secondary" as const,
        },
    },
];
---

<Layout
    title="Astro na Pratica - Construa Sites Modernos com Performance Extrema"
    description="Curso completo e pratico para construir sites modernos usando o Astro Framework. 175 aulas, 17 modulos, projetos reais."
>
    <!-- Hero Section -->
    <section class="hero-section">
        <HeroAnimatedBackground variant="purple" />
        <div class="hero-content">
            <div class="hero-text-center">
                <div class="hero-badge">
                    <span class="badge">
                        <span class="badge-dot"></span>
                        Curso de Desenvolvimento Web
                    </span>
                </div>
                <h1 class="hero-title">
                    Domine o Framework que<br />
                    <span class="text-gradient">Redefine a Web Moderna</span>
                </h1>
                <p class="hero-subtitle">
                    Um curso premium e pratico para construir sites modernos com <strong
                        class="text-white">performance extrema</strong
                    > usando o Astro Framework. Do basico ao avancado, com projetos
                    reais.
                </p>
                <div class="hero-cta">
                    <a href="#investimento" class="btn-primary">
                        Quero Dominar o Astro
                        <svg
                            class="btn-icon"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                    </a>
                </div>
                <p class="hero-quote">
                    "Em um mundo de frameworks over-engineered, Astro promete
                    simplicidade com performance extraordinaria."
                </p>
            </div>
        </div>
    </section>

    <!-- 01: O Desafio -->
    <section class="section" id="desafio">
        <div class="container">
            <div class="section-header">
                <span class="section-eyebrow">01 - O Desafio</span>
                <h2 class="section-title">Astro e enganosamente complexo</h2>
                <p class="section-subtitle">
                    Astro promete simplicidade com excelente DX e performance.
                    Mas por tras dessa simplicidade existe um universo de
                    ferramentas poderosas esperando voce dominar.
                </p>
            </div>
            <div class="problems-grid">
                <div class="problem-card">
                    <div class="problem-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><circle cx="12" cy="12" r="10"></circle><line
                                x1="12"
                                y1="8"
                                x2="12"
                                y2="12"></line><line
                                x1="12"
                                y1="16"
                                x2="12.01"
                                y2="16"></line></svg
                        >
                    </div>
                    <h3>Otimizar imagens automaticamente</h3>
                    <p>
                        Image Service, Picture component, responsive images —
                        sabe usar tudo isso de forma otimizada?
                    </p>
                </div>
                <div class="problem-card">
                    <div class="problem-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"
                            ></path><path d="M3 3v5h5"></path><path
                                d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"
                            ></path><path d="M16 16h5v5"></path></svg
                        >
                    </div>
                    <h3>Rotas dinamicas e SSR</h3>
                    <p>
                        Dynamic routes, SSG pagination, rewrites, redirects —
                        voce domina rendering no Astro?
                    </p>
                </div>
                <div class="problem-card">
                    <div class="problem-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                            ></path></svg
                        >
                    </div>
                    <h3>APIs e endpoints dinamicos</h3>
                    <p>
                        CRUD endpoints, RSS feeds, JSON APIs — sabe construir
                        backends completos com Astro?
                    </p>
                </div>
                <div class="problem-card">
                    <div class="problem-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-5.07l-2.83 2.83M9.76 14.24l-2.83 2.83m0-10.14l2.83 2.83m4.48 4.48l2.83 2.83"
                            ></path></svg
                        >
                    </div>
                    <h3>Middleware e autenticacao</h3>
                    <p>
                        Auth protegido, middleware, Astro locals —
                        funcionalidades avancadas que fazem toda diferenca.
                    </p>
                </div>
            </div>
            <div class="problem-conclusion">
                <p class="conclusion-text">
                    Astro se move rapido... tipo MUITO rapido!
                </p>
                <p class="conclusion-highlight">
                    3 versoes major em pouco mais de 1 ano. Voce esta <span
                        class="text-accent">acompanhando</span
                    >?
                </p>
            </div>
        </div>
    </section>

    <!-- 02: O que Astro pode fazer -->
    <section class="section-dark" id="ferramentas">
        <div class="container">
            <div class="section-header">
                <span class="section-eyebrow"
                    >02 - Conheca Suas Ferramentas</span
                >
                <h2 class="section-title">
                    Voce sabe tudo que o Astro pode fazer?
                </h2>
                <p class="section-subtitle">
                    Astro comecou focado em conteudo. Hoje suporta desde landing
                    pages simples ate apps full-stack com auth, databases e
                    muito mais.
                </p>
            </div>
            <div class="benefits-grid">
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
                            ></path></svg
                        >
                    </div>
                    <h3>Content Collections</h3>
                    <p>
                        Defina e consulte dados type-safe com as content
                        collections do Astro. Glob, File e Custom Loaders.
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><rect
                                x="2"
                                y="3"
                                width="20"
                                height="14"
                                rx="2"
                                ry="2"></rect><line
                                x1="8"
                                y1="21"
                                x2="16"
                                y2="21"></line><line
                                x1="12"
                                y1="17"
                                x2="12"
                                y2="21"></line></svg
                        >
                    </div>
                    <h3>View Transitions</h3>
                    <p>
                        Transicoes entre paginas usando a View Transitions API
                        com os helpers nativos do Astro.
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><circle cx="12" cy="12" r="3"></circle><path
                                d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9c.26.6.4 1.02.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                            ></path></svg
                        >
                    </div>
                    <h3>Middleware & Auth</h3>
                    <p>
                        Configure middleware para injetar comportamentos
                        dinamicos. Proteja rotas com autenticacao completa.
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                            ></path><polyline points="14 2 14 8 20 8"
                            ></polyline><line x1="16" y1="13" x2="8" y2="13"
                            ></line><line x1="16" y1="17" x2="8" y2="17"
                            ></line></svg
                        >
                    </div>
                    <h3>Markdown & MDX</h3>
                    <p>
                        Renderize markdown e componentes MDX com roteamento
                        baseado em paginas. Importe componentes no MDX.
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
                            ></path><path
                                d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
                            ></path></svg
                        >
                    </div>
                    <h3>SSR + SSG Hibrido</h3>
                    <p>
                        Renderize paginas estaticas ou no servidor. Rotas
                        dinamicas, paginacao SSG e endpoints CRUD.
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><polyline points="16 18 22 12 16 6"
                            ></polyline><polyline points="8 6 2 12 8 18"
                            ></polyline></svg
                        >
                    </div>
                    <h3>Integracoes & i18n</h3>
                    <p>
                        Integre qualquer framework UI, prefetching de links,
                        internacionalizacao nativa e dev toolbar.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- 03: Conteudo do Curso -->
    <section class="section" id="conteudo">
        <div class="container">
            <div class="section-header">
                <span class="section-eyebrow">03 - Conteudo Completo</span>
                <h2 class="section-title">O que esta no curso</h2>
                <p class="section-subtitle">
                    175 aulas focadas nas ferramentas nativas do Astro. Ao
                    terminar, voce sabera construir qualquer tipo de site
                    moderno.
                </p>
            </div>

            <h3 class="section-divider">Secao 1: Core Astro</h3>
            <div class="modules-grid">
                <div class="module-card">
                    <span class="module-badge">Modulo 1</span><h3>
                        Astro Basics
                    </h3><p>Conceitos basicos de sites Astro.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Instalacao e Setup
                        </li><li>
                            <span class="check">✓</span> Estrutura de Arquivos e Rotas
                        </li><li>
                            <span class="check">✓</span> Layouts, Slots e Componentes
                        </li><li>
                            <span class="check">✓</span> CSS, Styling e JavaScript
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 2</span><h3>
                        Astro Components
                    </h3><p>Componentes com sintaxe customizada do Astro.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Button e Heading Components
                        </li><li>
                            <span class="check">✓</span> TypeScript em componentes
                        </li><li>
                            <span class="check">✓</span> Usando UI Frameworks (React,
                            Vue...)
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 3</span><h3>
                        Markdown e MDX
                    </h3><p>Renderize markdown e MDX no Astro.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Componentes Markdown
                        </li><li>
                            <span class="check">✓</span> Importando arquivos MD
                        </li><li>
                            <span class="check">✓</span> MDX e importacao de componentes
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 4</span><h3>
                        Content Collections
                    </h3><p>Dados type-safe com content collections.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Glob(), File() e Custom Loaders
                        </li><li>
                            <span class="check">✓</span> Schemas com Zod
                        </li><li>
                            <span class="check">✓</span> Querying e rendering collections
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 5</span><h3>
                        Rendering e Routing
                    </h3><p>Opcoes de renderizacao e roteamento.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Dynamic Routes (SSR + SSG)
                        </li><li>
                            <span class="check">✓</span> SSG Pagination
                        </li><li>
                            <span class="check">✓</span> Rewrites e Redirects
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 6</span><h3>
                        Projeto: Portfolio
                    </h3><p>Construa um portfolio pessoal completo.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> 22 aulas, 2h de conteudo
                        </li><li>
                            <span class="check">✓</span> Revisao de todos os conceitos
                        </li><li>
                            <span class="check">✓</span> Deploy com Netlify
                        </li>
                    </ul>
                </div>
            </div>

            <h3 class="section-divider">Secao 2: Astro Tools</h3>
            <div class="modules-grid">
                <div class="module-card">
                    <span class="module-badge">Modulo 7</span><h3>
                        Image Optimization
                    </h3><p>Otimize imagens locais e remotas.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Image e Picture components
                        </li><li>
                            <span class="check">✓</span> Responsive images
                        </li><li>
                            <span class="check">✓</span> getImage function
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 8</span><h3>
                        Dynamic Endpoints
                    </h3><p>Endpoints dinamicos em SSG e SSR.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> JSON endpoints e RSS feed
                        </li><li>
                            <span class="check">✓</span> CRUD endpoints com SSR
                        </li><li>
                            <span class="check">✓</span> POST, GET, DELETE, PATCH
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 9</span><h3>
                        Astro DB
                    </h3><p>Solucao de banco de dados do Astro.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Setup e seeding local
                        </li><li>
                            <span class="check">✓</span> Astro Studio e dados live
                        </li><li>
                            <span class="check">✓</span> Deploy com Vercel
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 10</span><h3>
                        Middleware
                    </h3><p>Middleware para comportamentos dinamicos.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Context Object e Redirects
                        </li><li>
                            <span class="check">✓</span> Astro Locals
                        </li><li>
                            <span class="check">✓</span> Alterando response e logging
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 11</span><h3>
                        Projeto: Auth
                    </h3><p>Autenticacao completa com middleware.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Firebase Auth (6 aulas)
                        </li><li>
                            <span class="check">✓</span> Lucia Auth (7 aulas)
                        </li><li>
                            <span class="check">✓</span> Middleware de protecao
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 12</span><h3>
                        View Transitions
                    </h3><p>Transicoes entre paginas com a API nativa.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Transition Animations
                        </li><li>
                            <span class="check">✓</span> State management
                        </li><li>
                            <span class="check">✓</span> Lifecycle Events
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 13</span><h3>
                        Internationalization
                    </h3><p>i18n nativo do Astro.</p><ul class="module-list">
                        <li><span class="check">✓</span> Language picker</li><li
                        >
                            <span class="check">✓</span> Dynamic Routes i18n
                        </li><li>
                            <span class="check">✓</span> Customizando middleware
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 14</span><h3>
                        Integracoes & Config
                    </h3><p>Integracoes, config e dev toolbar.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Templates e themes
                        </li><li>
                            <span class="check">✓</span> Prefetching Links
                        </li><li><span class="check">✓</span> Dev toolbar</li>
                    </ul>
                </div>
            </div>

            <h3 class="section-divider">Secao 3: Astro Projects</h3>
            <div class="modules-grid">
                <div class="module-card">
                    <span class="module-badge">Modulo 15</span><h3>
                        Astro + CMS
                    </h3><p>3 opcoes de CMS com Astro.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> JSON / Google Sheets
                        </li><li>
                            <span class="check">✓</span> Keystatic CMS (5 aulas)
                        </li><li>
                            <span class="check">✓</span> Strapi CMS (5 aulas)
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 16</span><h3>
                        Projeto: CRUD App
                    </h3><p>App completo de tracking de livros.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Astro DB + CRUD API
                        </li><li>
                            <span class="check">✓</span> Busca com OpenLibrary API
                        </li><li>
                            <span class="check">✓</span> Update status e delete
                        </li>
                    </ul>
                </div>
                <div class="module-card">
                    <span class="module-badge">Modulo 17</span><h3>
                        E-commerce Basico
                    </h3><p>E-commerce SSR com Stripe.</p><ul
                        class="module-list"
                    >
                        <li>
                            <span class="check">✓</span> Stripe Community Loader
                        </li><li>
                            <span class="check">✓</span> Carrinho com cookies
                        </li><li>
                            <span class="check">✓</span> Checkout e confirmacao
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- 04: Para Quem E -->
    <section class="section-dark" id="publico">
        <div class="container">
            <div class="section-header">
                <span class="section-eyebrow">04 - Para Quem E</span>
                <h2 class="section-title">Este curso e para voce se...</h2>
            </div>
            <div class="audience-grid">
                <div class="audience-card">
                    <div class="audience-icon">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><polyline points="16 18 22 12 16 6"
                            ></polyline><polyline points="8 6 2 12 8 18"
                            ></polyline></svg
                        >
                    </div><h3>Desenvolvedores Front-end</h3><p>
                        Quer dominar o framework mais performatico da web
                    </p>
                </div>
                <div class="audience-card">
                    <div class="audience-icon">
                        <svg
                            viewBox="0 0 24 24"
