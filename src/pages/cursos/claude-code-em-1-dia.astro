---
// claude-code-em-1-dia.astro - Página do workshop Claude Code (Design v2)
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Claude Code para Iniciantes - Aprenda em Um Dia"
  description="Aprenda Claude Code em um dia. Saia com um projeto publicado. Workshop ao vivo com Alex Donega."
>

<!-- Hero Section com Animação -->
<section class="hero-section">
  <!-- Background animado com linhas SVG -->
  <div class="hero-background">
    <svg
      class="animated-lines"
      viewBox="0 0 1200 800"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <radialGradient id="neonPulse1" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(255,255,255,1)" />
          <stop offset="30%" stop-color="rgba(251,146,60,1)" />
          <stop offset="70%" stop-color="rgba(249,115,22,0.8)" />
          <stop offset="100%" stop-color="rgba(249,115,22,0)" />
        </radialGradient>
        <radialGradient id="neonPulse2" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(255,255,255,0.9)" />
          <stop offset="25%" stop-color="rgba(251,146,60,0.9)" />
          <stop offset="60%" stop-color="rgba(234,88,12,0.7)" />
          <stop offset="100%" stop-color="rgba(234,88,12,0)" />
        </radialGradient>
        <radialGradient id="heroTextBg" cx="30%" cy="50%" r="70%">
          <stop offset="0%" stop-color="rgba(249,115,22,0.15)" />
          <stop offset="40%" stop-color="rgba(251,146,60,0.08)" />
          <stop offset="80%" stop-color="rgba(234,88,12,0.05)" />
          <stop offset="100%" stop-color="rgba(0,0,0,0)" />
        </radialGradient>
        <filter id="neonGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="2" result="coloredBlur" />
          <feMerge>
            <feMergeNode in="coloredBlur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
        <linearGradient id="threadFade1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="rgba(0,0,0,1)" />
          <stop offset="15%" stop-color="rgba(249,115,22,0.8)" />
          <stop offset="85%" stop-color="rgba(249,115,22,0.8)" />
          <stop offset="100%" stop-color="rgba(0,0,0,1)" />
        </linearGradient>
      </defs>

      <g>
        <ellipse cx="300" cy="350" rx="400" ry="200" fill="url(#heroTextBg)" opacity="0.6" />

        <!-- Threads animados -->
        <path id="thread1" d="M50 720 Q200 590 350 540 Q500 490 650 520 Q800 550 950 460 Q1100 370 1200 340" stroke="url(#threadFade1)" stroke-width="0.8" fill="none" opacity="0.8" />
        <circle r="2" fill="url(#neonPulse1)" opacity="1" filter="url(#neonGlow)">
          <animateMotion dur="4s" repeatCount="indefinite"><mpath href="#thread1" /></animateMotion>
        </circle>

        <path id="thread2" d="M80 730 Q250 620 400 570 Q550 520 700 550 Q850 580 1000 490 Q1150 400 1300 370" stroke="url(#threadFade1)" stroke-width="1.5" fill="none" opacity="0.7" />
        <circle r="3" fill="url(#neonPulse2)" opacity="1" filter="url(#neonGlow)">
          <animateMotion dur="5s" repeatCount="indefinite"><mpath href="#thread2" /></animateMotion>
        </circle>

        <path id="thread3" d="M20 710 Q180 580 320 530 Q460 480 600 510 Q740 540 880 450 Q1020 360 1200 330" stroke="url(#threadFade1)" stroke-width="1.2" fill="none" opacity="0.8" />
        <circle r="2.5" fill="url(#neonPulse1)" opacity="1" filter="url(#neonGlow)">
          <animateMotion dur="4.5s" repeatCount="indefinite"><mpath href="#thread3" /></animateMotion>
        </circle>
      </g>
    </svg>
  </div>

  <!-- Conteudo Principal -->
  <div class="hero-content">
    <div class="hero-text-center">
      <!-- Badge -->
      <div class="hero-badge">
        <span class="badge">
          <span class="badge-dot"></span>
          Workshop Ao Vivo
        </span>
      </div>

      <!-- Titulo Principal -->
      <h1 class="hero-title">
        Aprenda <span class="text-gradient">Claude Code</span><br>
        em Um Dia
      </h1>

      <!-- Subtitulo -->
      <p class="hero-subtitle">
        Um workshop ao vivo e amigavel para iniciantes com <strong class="text-white">Alex Donega</strong> — saia com um projeto funcionando e a confianca para usar Claude Code no seu dia a dia.
      </p>

      <!-- Descricao -->
      <p class="hero-description">
        Sessoes guiadas ao vivo, grupos de discussao entre participantes e suporte pratico — usando as mesmas ferramentas que eu uso — para te dar um fluxo de trabalho repetivel que voce pode aplicar no seu emprego, na sua vida e no seu proximo projeto.
      </p>

      <!-- CTA -->
      <div class="hero-cta">
        <a href="#detalhes-preco" class="btn-primary">
          Inscreva-se no Claude Code para Iniciantes
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>
      </div>

      <!-- Screenshot -->
      <div class="hero-screenshot">
        <img src="https://framerusercontent.com/assets/img/HpzuWCWdx2FCMAEvTlTOmXHRk.png" alt="Claude Code em acao" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- Secao: Para Quem E -->
<section class="section" id="publico">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Para quem e este curso?</h2>
    </div>

    <div class="audience-cards">
      <div class="audience-card-full">
        <div class="card-image" style="background-image: url('https://framerusercontent.com/assets/img/XBCrRyMhztXlJGqGET3Vxxpm9qY.png')"></div>
        <div class="card-content">
          <p><strong>Pessoas curiosas</strong> sobre Claude Code mas intimidadas pelo terminal</p>
        </div>
      </div>

      <div class="audience-card-full">
        <div class="card-image" style="background-image: url('https://framerusercontent.com/assets/img/ddTHngczFesjMEtm7wlikksLAw.png')"></div>
        <div class="card-content">
          <p><strong>Desenvolvedores e nao-desenvolvedores</strong> novos no Claude Code buscando um lugar amigavel para aprender</p>
        </div>
      </div>

      <div class="audience-card-full">
        <div class="card-image" style="background-image: url('https://framerusercontent.com/assets/img/agA6QBkWMxUXhCnkgyugRdCgYSs.png')"></div>
        <div class="card-content">
          <p><strong>Construtores de diversas areas</strong> — engenharia, marketing, pesquisa, produto, conteudo</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Secao: O Que Voce Vai Aprender -->
