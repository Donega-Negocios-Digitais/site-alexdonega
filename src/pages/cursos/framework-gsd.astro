---
// framework-gsd.astro - Página do curso Framework Get Shit Done (Design v2)
import Layout from '../../layouts/Layout.astro';
import HeroAnimatedBackground from '../../components/course/HeroAnimatedBackground.astro';
import CourseFinalCta from '../../components/course/CourseFinalCta.astro';
import CourseFaqSection from '../../components/course/CourseFaqSection.astro';

const courseFaqItems = [
  {
    question: 'Preciso saber programar?',
    answer: 'Não! O GSD foi criado para qualquer pessoa que queira usar IA para criar projetos. Você não precisa ser programador - o framework te guia passo a passo, mesmo que você nunca tenha escrito uma linha de código.',
    button: { text: 'Quero começar do zero →', href: '#modulos' },
  },
  {
    question: 'Funciona se eu nunca usei Claude Code?',
    answer: 'Sim! O curso começa do zero. Te ensino a instalar, configurar e usar o Claude Code da forma correta. Em poucas horas você já está criando seus primeiros projetos.',
    button: { text: 'Ver aula de instalação →', href: '#modulos' },
  },
  {
    question: 'Quanto tempo tenho acesso?',
    answer: 'Acesso vitalício. Comprou uma vez, seu para sempre. Inclui todas as atualizações futuras do framework.',
    button: { text: 'Garantir meu acesso vitalício →', href: '#investimento' },
  },
  {
    question: 'E se eu não gostar?',
    answer: 'Garantia de 7 dias. Devolvo 100% do seu dinheiro sem perguntas.',
    button: { text: 'Quero conhecer sem risco →', href: '#investimento', variant: 'secondary' as const },
  },
  {
    question: 'O que consigo criar com o GSD?',
    answer: 'Sites, aplicativos, automações, sistemas web, landing pages, lojas virtuais... Se você consegue descrever, o GSD consegue construir. Um aluno fez um MVP que normalmente cobraria R$ 6.000 em UMA NOITE.',
    button: { text: 'Quero ver o que posso criar →', href: '#conteudo' },
  },
  {
    question: 'Quanto tempo leva para aprender?',
    answer: 'Você pode começar a criar projetos no primeiro dia. O curso é prático - cada módulo te leva direto à aplicação. Em uma semana você já domina o workflow completo.',
    button: { text: 'Quero começar agora →', href: '#investimento' },
  },
];
---

<Layout
  title="Framework Get Shit Done - IA Que Trabalha Enquanto Você Dorme"
  description="Aprenda o framework GSD para criar projetos completos com IA enquanto você dorme. Mesmo sem saber programar, construa MVPs profissionais em horas, não semanas."
  hideFooter={true}
>

<!-- Hero Section com Vídeo -->
<section class="hero-section">
  <HeroAnimatedBackground variant="emerald" />

  <!-- Conteúdo Principal -->
  <div class="hero-content">
    <div class="hero-grid">
      <!-- Coluna de Texto -->
      <div class="hero-text">
        <!-- Badge -->
        <div class="hero-badge">
          <span class="badge">
            <span class="badge-dot gsd"></span>
            Método Revolucionário
          </span>
        </div>

        <!-- Titulo Principal -->
        <h1 class="hero-title">
          Enquanto Você <span class="text-gsd">Dorme</span>,<br>
          A IA <span class="text-gsd">Trabalha</span>.
        </h1>

        <!-- Subtitulo -->
        <p class="hero-subtitle">
          <strong>Não sou programador.</strong> Mas usando o <strong class="text-white">Framework GSD</strong>, vendi meu primeiro projeto SaaS por <strong>R$ 6.000</strong> — e levei apenas <strong>7:32 minutos</strong> para criar. Enquanto a IA trabalhava, eu dormia.
        </p>

        <!-- CTA -->
        <div class="hero-cta">
          <a href="#investimento" class="btn-primary gsd">
            Quero IA Trabalhando Por Mim
            <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Coluna do Vídeo -->
      <div class="hero-video-container">
        <div class="video-wrapper">
          <div class="video-glow gsd-glow"></div>
          <div class="video-container">
            <video
              id="hero-video"
              poster="/img/people/alex-donega.webp"
              playsinline
              muted
              loop
              preload="metadata"
            >
              <source src="/videos/alex-intro.mp4" type="video/mp4" />
              <img src="/img/people/alex-donega.webp" alt="Alex Donega" />
            </video>
            <button class="video-play-btn gsd-btn" aria-label="Reproduzir vídeo">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
          </div>
          <div class="video-decoration video-decoration-1 gsd-border"></div>
          <div class="video-decoration video-decoration-2 gsd-bg"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Seção 01: O Problema -->
<section class="section" id="problema">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow gsd">01 - O Problema Real</span>
      <h2 class="section-title">Por que você ainda não criou seu projeto?</h2>
      <p class="section-subtitle">
        Você já tentou usar ChatGPT ou Claude para criar algo, mas ficou perdido? A IA começa bem, mas depois se perde, repete erros, e você desiste no meio do caminho.
      </p>
    </div>

    <div class="problems-grid">
      <div class="problem-card">
        <div class="problem-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <h3>"A IA começa bem, mas depois se perde"</h3>
        <p>Você pede para criar um site, a IA faz metade, e depois começa a errar. Cada vez que você corrige, ela quebra outra coisa. Você fica preso num loop infinito.</p>
      </div>

      <div class="problem-card">
        <div class="problem-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
            <path d="M3 3v5h5"/>
            <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
            <path d="M16 16h5v5"/>
          </svg>
        </div>
        <h3>"Não sei o que pedir para a IA"</h3>
        <p>Você sabe o que quer (um site, um app, uma automação), mas não sabe como descrever para a IA. Os resultados nunca saem como você imaginou.</p>
      </div>

      <div class="problem-card">
        <div class="problem-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
        <h3>"Demora dias para fazer algo simples"</h3>
        <p>O que deveria levar horas, leva dias. Você fica preso em detalhes técnicos, erros que não entende, e acaba desistindo antes de terminar.</p>
      </div>

      <div class="problem-card">
        <div class="problem-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-5.07l-2.83 2.83M9.76 14.24l-2.83 2.83m0-10.14l2.83 2.83m4.48 4.48l2.83 2.83"/>
          </svg>
        </div>
        <h3>"Preciso dormir, mas o projeto não anda"</h3>
        <p>Imagine se a IA continuasse trabalhando enquanto você dorme. Acordar com um projeto pronto. Isso parece impossível? Com o GSD, não é.</p>
      </div>
    </div>

    <div class="problem-conclusion">
      <p class="conclusion-text">Se você se identificou com algum desses problemas...</p>
      <p class="conclusion-highlight">A solução é ter um <span class="text-gsd">framework</span> que faz a IA trabalhar por você.</p>
    </div>
  </div>
</section>

<!-- Seção 02: A Solução -->
<section class="section-dark" id="solucao">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow gsd">02 - A Solução</span>
      <h2 class="section-title">Como Fazer a IA Trabalhar Enquanto Você Dorme</h2>
      <p class="section-subtitle">
        O <strong>Framework GSD (Get Shit Done)</strong> é o único método que organiza a IA em <strong>5 agentes especializados</strong>. Cada um faz sua parte e passa o bastão. Resultado: projetos completos criados enquanto você descansa.
      </p>
    </div>

    <!-- Comparacao Antes/Depois -->
    <div class="comparison-grid">
      <div class="comparison-box before">
        <span class="comparison-badge">Sem GSD</span>
        <ul class="comparison-list">
          <li><span class="icon">✕</span> IA se perde no meio do caminho</li>
          <li><span class="icon">✕</span> Você precisa ficar olhando o tempo todo</li>
          <li><span class="icon">✕</span> Projetos demoram dias ou semanas</li>
          <li><span class="icon">✕</span> Erros que você não sabe corrigir</li>
          <li><span class="icon">✕</span> Desiste antes de terminar</li>
          <li><span class="icon">✕</span> Frustração e tempo perdido</li>
        </ul>
      </div>

      <div class="comparison-box after">
        <span class="comparison-badge">Com GSD</span>
        <ul class="comparison-list">
          <li><span class="icon">✓</span> 5 agentes trabalhando em sequência</li>
          <li><span class="icon">✓</span> Você dorme, a IA trabalha sozinha</li>
          <li><span class="icon">✓</span> Projetos prontos em horas, não dias</li>
          <li><span class="icon">✓</span> Cada agente verifica o trabalho do outro</li>
          <li><span class="icon">✓</span> Acorda com o projeto completo</li>
          <li><span class="icon">✓</span> Mesmo sem saber programar</li>
        </ul>
      </div>
    </div>

    <!-- Case dos 10k -->
    <div class="big-case">
      <div class="case-header">
        <span class="case-tag">CASE REAL</span>
        <h3>R$ 10.000 em Uma Noite</h3>
      </div>
      <p class="case-description">
        Usei o GSD para criar um sistema completo de agendamento com pagamentos integrados. Configurei os agentes à noite antes de dormir. Quando acordei, o sistema estava pronto, testado e funcionando. Entreguei ao cliente na manhã seguinte. Ele pagou R$ 10.000.
      </p>
      <div class="case-stats">
        <div class="stat">
          <span class="stat-number">8h</span>
          <span class="stat-label">Dormindo</span>
        </div>
        <div class="stat">
          <span class="stat-number">5</span>
          <span class="stat-label">Agentes Trabalhando</span>
        </div>
        <div class="stat">
          <span class="stat-number">R$6k</span>
          <span class="stat-label">Faturados</span>
        </div>
      </div>
    </div>

    <!-- Sub-Agentes -->
    <div class="agents-section">
      <h3 class="agents-title">Os 5 Agentes Que Trabalham Por Você</h3>
      <p class="agents-subtitle">Cada um tem uma função específica. Juntos, criam projetos completos enquanto você descansa.</p>

      <div class="agents-grid">
        <div class="agent-card">
          <span class="agent-number">01</span>
          <h4>Mapeador</h4>
          <p>Analisa o que precisa ser feito. Mapeia tecnologias, estrutura e define o caminho.</p>
        </div>

        <div class="agent-card">
          <span class="agent-number">02</span>
          <h4>Pesquisador</h4>
          <p>Busca as melhores formas de fazer. Estuda exemplos e evita erros comuns.</p>
        </div>

        <div class="agent-card">
          <span class="agent-number">03</span>
          <h4>Planejador</h4>
          <p>Cria um plano passo a passo. Define exatamente o que cada parte do projeto precisa.</p>
        </div>

        <div class="agent-card">
          <span class="agent-number">04</span>
          <h4>Construtor</h4>
          <p>Escreve o código, cria as páginas, configura tudo. Faz o trabalho pesado.</p>
        </div>

        <div class="agent-card">
          <span class="agent-number">05</span>
          <h4>Verificador</h4>
          <p>Testa tudo. Garante que está funcionando antes de te entregar o projeto.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Seção 03: As 5 Fases -->
<section class="section" id="fases">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow gsd">03 - O Método</span>
      <h2 class="section-title">As 5 Fases do GSD</h2>
      <p class="section-subtitle">
        Um workflow estruturado que leva você da ideia ao código funcionando - sem perder qualidade no caminho.
      </p>
    </div>

    <div class="phases-timeline">
      <div class="phase-item">
        <div class="phase-marker">
          <span class="phase-num">1</span>
        </div>
        <div class="phase-content">
          <h3>Inicialização</h3>
          <p>Mapeia seu código existente (se houver) e inicializa a estrutura GSD. Cria pasta .planning/ com PROJECT.md, REQUIREMENTS.md e ROADMAP.md.</p>
          <span class="phase-time">⏱️ 15-60 minutos</span>
        </div>
      </div>

      <div class="phase-item">
        <div class="phase-marker">
          <span class="phase-num">2</span>
        </div>
        <div class="phase-content">
          <h3>Discussão</h3>
          <p>O GSD faz perguntas adaptativas para entender sua visão. Articula o problema antes de planejar a solução. Output: CONTEXT.md.</p>
          <span class="phase-time">⏱️ 15-30 minutos</span>
        </div>
      </div>

      <div class="phase-item">
        <div class="phase-marker">
          <span class="phase-num">3</span>
        </div>
        <div class="phase-content">
          <h3>Planejamento</h3>
          <p>Cria PLAN.md com tarefas atômicas usando Goal-Backward. Define critérios de sucesso antes de codar.</p>
          <span class="phase-time">⏱️ 20-40 minutos</span>
        </div>
      </div>

      <div class="phase-item">
        <div class="phase-marker">
          <span class="phase-num">4</span>
        </div>
        <div class="phase-content">
          <h3>Execução</h3>
          <p>Executor agents implementam cada tarefa com commits atômicos. Modo Parallel (rápido) ou Sequential (seguro).</p>
          <span class="phase-time">⏱️ Variável (conforme complexidade)</span>
        </div>
      </div>

      <div class="phase-item">
        <div class="phase-marker">
          <span class="phase-num">5</span>
        </div>
        <div class="phase-content">
          <h3>Verificação</h3>
          <p>Verifier agent valida que tudo funciona conforme os objetivos. Gera VERIFICATION.md com evidências.</p>
          <span class="phase-time">⏱️ 15-30 minutos</span>
        </div>
      </div>
    </div>

    <div class="workflow-note">
      <p><strong>💡 Ciclo contínuo:</strong> Após a verificação, você pode iniciar uma nova fase ou completar o milestone. O workflow se repete mantendo a qualidade em cada iteração.</p>
    </div>
  </div>
</section>

<!-- Seção 04: Para Quem É -->
<section class="section-dark" id="publico">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow gsd">04 - Para Quem É</span>
      <h2 class="section-title">Este curso é para você se...</h2>
      <p class="section-subtitle">Não precisa saber programar. Não precisa ser técnico. Se você consegue usar o WhatsApp, consegue usar o GSD.</p>
    </div>

    <div class="audience-grid">
      <div class="audience-card gsd">
        <div class="audience-icon gsd">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
        </div>
        <h3>Quer Criar Renda Extra</h3>
        <p>Sabe que poderia vender sites, apps ou automações, mas não sabe por onde começar</p>
      </div>

      <div class="audience-card gsd">
        <div class="audience-icon gsd">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
            <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
          </svg>
        </div>
        <h3>Empreendedor Curioso</h3>
        <p>Tem ideias de negócio, mas acha que criar o produto digital custa caro ou demora muito</p>
      </div>

      <div class="audience-card gsd">
        <div class="audience-icon gsd">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3>Quer Trabalhar Menos</h3>
        <p>Está cansado de trocar tempo por dinheiro. Quer que a tecnologia trabalhe por você</p>
      </div>

      <div class="audience-card gsd">
        <div class="audience-icon gsd">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          </svg>
        </div>
        <h3>Profissional Liberal</h3>
        <p>É consultor, coach, advogado, médico. Quer automatizar partes do seu trabalho</p>
      </div>

      <div class="audience-card gsd">
        <div class="audience-icon gsd">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 16v-4M12 8h.01"/>
          </svg>
        </div>
        <h3>Nunca Programou</h3>
        <p>Sempre achou que criar sites ou apps era só para nerds. Quer provar que está errado</p>
      </div>

      <div class="audience-card gsd">
        <div class="audience-icon gsd">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3>Quer Escala</h3>
        <p>Já tem um negócio, mas quer criar produtos digitais para vender enquanto dorme</p>
      </div>
    </div>

    <div class="audience-cta">
      <a href="#investimento" class="btn-primary gsd">Quero IA Trabalhando Por Mim</a>
    </div>
  </div>
</section>

<!-- Seção 05: Sobre o Professor -->
<section class="section" id="professor">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow gsd">05 - Quem Vai Te Ensinar</span>
      <h2 class="section-title">Uma nota do Alex</h2>
    </div>

    <div class="about-grid">
      <div class="about-image">
        <img src="/img/people/alex-donega.webp" alt="Alex Donega" loading="lazy" />
      </div>
      <div class="about-content">
        <h3>Alex Donega</h3>
        <p>Quando descobri o GSD, minha produtividade com IA mudou completamente. Antes, eu passava horas em Ralph Loops - pedindo, corrigindo, pedindo de novo. O Claude "esquecia" o contexto e eu tinha que repetir tudo.</p>
        <p>O GSD resolve isso com uma ideia simples: em vez de forçar uma única conversa a fazer tudo, use múltiplos agentes especializados. Cada um com contexto fresco de 200k tokens. Resultado? Código melhor, menos bugs, mais velocidade.</p>
        <p>Uso o GSD diariamente nos meus 3 MicroSaaS (Novo Envio, FalaZapp, MyMess) e nos projetos da Autobots Ventures. Não é teoria - é o que funciona na prática.</p>

        <blockquote class="about-quote gsd">
          "O GSD não é sobre usar IA de forma diferente. É sobre usar IA de forma inteligente."
        </blockquote>

        <ul class="credentials-list">
          <li><span class="check gsd">✓</span> Gestor de Projetos na Autobots Ventures</li>
          <li><span class="check gsd">✓</span> Membro do time Autobots Ventures (+25 software)</li>
          <li><span class="check gsd">✓</span> Fundador de 3 MicroSaaS em operação</li>
          <li><span class="check gsd">✓</span> Especialista em Context Engineering</li>
          <li><span class="check gsd">✓</span> Criador do framework Conteúdo Mestre</li>
        </ul>

        <a href="#investimento" class="btn-primary gsd">Quero aprender com o Alex</a>
      </div>
    </div>
  </div>
</section>

<!-- Seção: Bônus -->
<section class="section bonus-section">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow gsd">Bônus Exclusivos</span>
      <h2 class="section-title">Mais valor para você</h2>
    </div>

    <div class="bonus-grid">
      <div class="bonus-card">
        <div class="bonus-ribbon gsd">BÔNUS</div>
        <h3>Templates GSD Prontos</h3>
        <p>Todos os templates de PLAN.md, CONTEXT.md, e arquivos de planejamento prontos para usar.</p>
        <span class="bonus-value">Valor: <strong>R$ 297</strong></span>
      </div>

      <div class="bonus-card">
        <div class="bonus-ribbon gsd">BÔNUS</div>
        <h3>Cheatsheet de Comandos</h3>
        <p>Guia rápido de todos os comandos GSD com exemplos práticos de uso.</p>
        <span class="bonus-value">Valor: <strong>R$ 97</strong></span>
      </div>

      <div class="bonus-card">
        <div class="bonus-ribbon gsd">BÔNUS</div>
        <h3>Comunidade Exclusiva</h3>
        <p>Acesso ao grupo de alunos para tirar dúvidas, trocar experiências e ver casos reais.</p>
        <span class="bonus-value">Valor: <strong>R$ 297</strong></span>
      </div>

      <div class="bonus-card">
        <div class="bonus-ribbon gsd">BÔNUS</div>
        <h3>Atualizações Vitalícias</h3>
