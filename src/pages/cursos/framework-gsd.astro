<script is:inline>
  function toggleModule(moduleId) {
    const items = document.querySelectorAll('.module-accordion-item');
    const targetItem = document.querySelector(`[data-module="${moduleId}"]`);
    
    // Fecha todos os módulos
    items.forEach(item => {
      item.classList.remove('active');
    });
    
    // Abre o módulo clicado (se não estava ativo)
    if (!targetItem.classList.contains('active')) {
      targetItem.classList.add('active');
    }
  }
  
  // Inicializa com o módulo de fundação aberto
  document.addEventListener('DOMContentLoaded', () => {
    toggleModule('fundacao');
  });
</script>

