---
// engenharia-de-contexto.astro - Página do curso de Engenharia de Contexto (Design v2)
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Engenharia de Contexto Aplicada ao Marketing Digital"
  description="Aprenda a transformar IA genérica em resultados extraordinários. Domine Context Engineering para criar conteúdo que realmente converte."
>

<!-- Hero Section com Animação -->
<section class="hero-section">
  <!-- Background animado com linhas SVG -->
  <div class="hero-background">
    <svg
      class="animated-lines"
      viewBox="0 0 1200 800"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <radialGradient id="neonPulse1" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(255,255,255,1)" />
          <stop offset="30%" stop-color="rgba(251,146,60,1)" />
          <stop offset="70%" stop-color="rgba(249,115,22,0.8)" />
          <stop offset="100%" stop-color="rgba(249,115,22,0)" />
        </radialGradient>
        <radialGradient id="neonPulse2" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(255,255,255,0.9)" />
          <stop offset="25%" stop-color="rgba(251,146,60,0.9)" />
          <stop offset="60%" stop-color="rgba(234,88,12,0.7)" />
          <stop offset="100%" stop-color="rgba(234,88,12,0)" />
        </radialGradient>
        <radialGradient id="heroTextBg" cx="30%" cy="50%" r="70%">
          <stop offset="0%" stop-color="rgba(249,115,22,0.15)" />
          <stop offset="40%" stop-color="rgba(251,146,60,0.08)" />
          <stop offset="80%" stop-color="rgba(234,88,12,0.05)" />
          <stop offset="100%" stop-color="rgba(0,0,0,0)" />
        </radialGradient>
        <filter id="neonGlow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="2" result="coloredBlur" />
          <feMerge>
            <feMergeNode in="coloredBlur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
        <linearGradient id="threadFade1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="rgba(0,0,0,1)" />
          <stop offset="15%" stop-color="rgba(249,115,22,0.8)" />
          <stop offset="85%" stop-color="rgba(249,115,22,0.8)" />
          <stop offset="100%" stop-color="rgba(0,0,0,1)" />
        </linearGradient>
      </defs>

      <g>
        <ellipse cx="300" cy="350" rx="400" ry="200" fill="url(#heroTextBg)" opacity="0.6" />

        <!-- Threads animados -->
        <path id="thread1" d="M50 720 Q200 590 350 540 Q500 490 650 520 Q800 550 950 460 Q1100 370 1200 340" stroke="url(#threadFade1)" stroke-width="0.8" fill="none" opacity="0.8" />
        <circle r="2" fill="url(#neonPulse1)" opacity="1" filter="url(#neonGlow)">
          <animateMotion dur="4s" repeatCount="indefinite"><mpath href="#thread1" /></animateMotion>
        </circle>

        <path id="thread2" d="M80 730 Q250 620 400 570 Q550 520 700 550 Q850 580 1000 490 Q1150 400 1300 370" stroke="url(#threadFade1)" stroke-width="1.5" fill="none" opacity="0.7" />
        <circle r="3" fill="url(#neonPulse2)" opacity="1" filter="url(#neonGlow)">
          <animateMotion dur="5s" repeatCount="indefinite"><mpath href="#thread2" /></animateMotion>
        </circle>

        <path id="thread3" d="M20 710 Q180 580 320 530 Q460 480 600 510 Q740 540 880 450 Q1020 360 1200 330" stroke="url(#threadFade1)" stroke-width="1.2" fill="none" opacity="0.8" />
        <circle r="2.5" fill="url(#neonPulse1)" opacity="1" filter="url(#neonGlow)">
          <animateMotion dur="4.5s" repeatCount="indefinite"><mpath href="#thread3" /></animateMotion>
        </circle>
      </g>
    </svg>
  </div>

  <!-- Conteudo Principal -->
  <div class="hero-content">
    <div class="hero-text-center">
      <!-- Badge -->
      <div class="hero-badge">
        <span class="badge">
          <span class="badge-dot"></span>
          Novo Curso
        </span>
      </div>

      <!-- Titulo Principal -->
      <h1 class="hero-title">
        De IA Generica para<br>
        <span class="text-gradient">Resultados Extraordinarios</span>
      </h1>

      <!-- Subtitulo -->
      <p class="hero-subtitle">
        A diferenca entre quem usa IA de forma mediocre e quem usa de forma extraordinaria nao e inteligencia, nao e tecnica, nao e prompt magico. E <strong class="text-white">CONTEXTO ESTRUTURADO</strong>.
      </p>

      <!-- CTA -->
      <div class="hero-cta">
        <a href="#investimento" class="btn-primary">
          Quero Dominar Context Engineering
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>
      </div>

      <!-- Hook Quote -->
      <p class="hero-quote">
        "Voce nao tem um problema de IA. Voce tem um problema de CONTEXTO."
      </p>
    </div>
  </div>
</section>

<!-- Secao 01: O Problema -->
<section class="section" id="problema">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">01 - O Problema Real</span>
      <h2 class="section-title">Por que sua IA entrega resultados genericos?</h2>
      <p class="section-subtitle">
        Imagine dar uma tarefa para um funcionario novo sem explicar nada sobre sua empresa, seus clientes, seu tom de voz... Ele vai entregar algo generico. A IA e igual.
      </p>
    </div>

    <div class="problems-grid">
      <div class="problem-card">
        <div class="problem-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <h3>"Uso ChatGPT mas os resultados sao genericos"</h3>
        <p>Voce gasta mais tempo corrigindo a IA do que escrevendo voce mesmo. Os outputs nao tem a sua voz, nao conhecem seu publico.</p>
      </div>

      <div class="problem-card">
        <div class="problem-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
            <path d="M3 3v5h5"/>
            <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
            <path d="M16 16h5v5"/>
          </svg>
        </div>
        <h3>"Sinto que estou usando 10% do potencial"</h3>
        <p>Voce sabe que a IA pode fazer mais, mas nao sabe como estruturar pedidos complexos. Fica na superficialidade.</p>
      </div>

      <div class="problem-card">
        <div class="problem-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
        <h3>"Nao sei estruturar prompts complexos"</h3>
        <p>Tenta diferentes abordagens, mas os resultados sao inconsistentes. Cada vez que pede algo, parece uma loteria.</p>
      </div>

      <div class="problem-card">
        <div class="problem-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-5.07l-2.83 2.83M9.76 14.24l-2.83 2.83m0-10.14l2.83 2.83m4.48 4.48l2.83 2.83"/>
          </svg>
        </div>
        <h3>"Quero automacao mas nao sei dar contexto certo"</h3>
        <p>Ja tentou criar workflows automatizados, mas a IA nao entende o suficiente do seu negocio para funcionar sozinha.</p>
      </div>
    </div>

    <div class="problem-conclusion">
      <p class="conclusion-text">Se voce se identificou com algum desses problemas...</p>
      <p class="conclusion-highlight">A solucao nao e mais prompts. E <span class="text-accent">Context Engineering</span>.</p>
    </div>
  </div>
</section>

<!-- Secao 02: A Solucao -->
<section class="section-dark" id="solucao">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">02 - A Solucao</span>
      <h2 class="section-title">O que e Engenharia de Contexto?</h2>
      <p class="section-subtitle">
        Context Engineering e a arte de estruturar informacoes para que IAs entreguem resultados personalizados e consistentes - toda vez.
      </p>
    </div>

    <!-- Framework Visual -->
    <div class="framework-visual">
      <h3 class="framework-title">O Fluxo da Engenharia de Contexto</h3>
      <div class="framework-flow">
        <div class="framework-step">
          <span class="step-number">1</span>
          <span class="step-label">Material Bruto</span>
        </div>
        <span class="framework-arrow">→</span>
        <div class="framework-step highlight">
          <span class="step-number">2</span>
          <span class="step-label">Sanitizacao</span>
        </div>
        <span class="framework-arrow">→</span>
        <div class="framework-step highlight">
          <span class="step-number">3</span>
          <span class="step-label">DNA Loading</span>
        </div>
        <span class="framework-arrow">→</span>
        <div class="framework-step">
          <span class="step-number">4</span>
          <span class="step-label">Output Unico</span>
        </div>
      </div>
    </div>

    <!-- Comparacao Antes/Depois -->
    <div class="comparison-grid">
      <div class="comparison-box before">
        <span class="comparison-badge">Antes</span>
        <ul class="comparison-list">
          <li><span class="icon">✕</span> Prompts avulsos e genericos</li>
          <li><span class="icon">✕</span> Resultados inconsistentes</li>
          <li><span class="icon">✕</span> IA nao conhece seu negocio</li>
          <li><span class="icon">✕</span> Tempo corrigindo outputs</li>
          <li><span class="icon">✕</span> Conteudo sem personalidade</li>
          <li><span class="icon">✕</span> Frustracao com ferramentas</li>
        </ul>
      </div>

      <div class="comparison-box after">
        <span class="comparison-badge">Depois</span>
        <ul class="comparison-list">
          <li><span class="icon">✓</span> Sistema estruturado de contexto</li>
          <li><span class="icon">✓</span> Resultados consistentes sempre</li>
          <li><span class="icon">✓</span> IA conhece seu DNA completo</li>
          <li><span class="icon">✓</span> Outputs prontos para usar</li>
          <li><span class="icon">✓</span> Sua voz, sua identidade</li>
          <li><span class="icon">✓</span> Produtividade multiplicada</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Secao 03: O Metodo -->
<section class="section" id="metodo">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">03 - O Metodo</span>
      <h2 class="section-title">O que voce vai dominar</h2>
      <p class="section-subtitle">
        Frameworks praticos que estudei em 43+ artigos e papers (Anthropic, arXiv, contextengineering.ai) pra voce nao precisar. Te passo o atalho.
      </p>
    </div>

    <div class="benefits-grid">
      <div class="benefit-card">
        <div class="benefit-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3>DNA System</h3>
        <p>Framework de contexto para sua marca e negocio. Personalidade, Publico, Tom de Voz - tudo documentado para a IA usar.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <h3>Conteudo Mestre</h3>
        <p>Sistema de criacao escalavel. 3 fases: Sanitizacao, Duo-Drafting, Refinamento. Produz conteudo na SUA voz.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3>Automacao Inteligente</h3>
        <p>Como estruturar contexto para workflows automatizados. IA que trabalha sozinha porque entende seu negocio.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
        </div>
        <h3>Personas + IA Generativa</h3>
        <p>A fusao que funciona: personas estruturadas alimentando ChatGPT/Claude para estrategias de marketing perfeitas.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
            <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
          </svg>
        </div>
        <h3>Aplicacao em Marketing</h3>
        <p>Cases reais de Context Engineering em campanhas, copy, conteudo para redes sociais, emails e muito mais.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h3>Templates Prontos</h3>
        <p>Nao comeca do zero. Recebe templates de DNA, prompts estruturados e workflows prontos para adaptar ao seu negocio.</p>
      </div>
    </div>
  </div>
</section>

<!-- Secao 04: Para Quem E -->
<section class="section-dark" id="publico">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">04 - Para Quem E</span>
      <h2 class="section-title">Este curso e para voce se...</h2>
    </div>

    <div class="audience-grid">
      <div class="audience-card">
        <div class="audience-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 19l7-7 3 3-7 7-3-3z"/>
            <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
            <circle cx="11" cy="11" r="2"/>
          </svg>
        </div>
        <h3>Criadores de Conteudo</h3>
        <p>Quer escalar producao sem perder autenticidade</p>
      </div>

      <div class="audience-card">
        <div class="audience-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3>Marketers Digitais</h3>
        <p>Precisa de resultados consistentes com IA</p>
      </div>

      <div class="audience-card">
        <div class="audience-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
            <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
          </svg>
        </div>
        <h3>Empreendedores</h3>
        <p>Quer automatizar marketing sem perder qualidade</p>
      </div>

      <div class="audience-card">
        <div class="audience-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
        </div>
        <h3>Agencias</h3>
        <p>Precisa escalar entrega para multiplos clientes</p>
      </div>

      <div class="audience-card">
        <div class="audience-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </div>
        <h3>Copywriters</h3>
        <p>Quer usar IA sem perder o toque humano</p>
      </div>

      <div class="audience-card">
        <div class="audience-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 3v18h18"/>
            <path d="m19 9-5 5-4-4-3 3"/>
          </svg>
        </div>
        <h3>Gestores de Trafego</h3>
        <p>Precisa criar copys que convertem em escala</p>
      </div>
    </div>

    <div class="audience-cta">
      <a href="#investimento" class="btn-primary">Esse curso e para mim</a>
    </div>
  </div>
</section>

<!-- Secao 05: Sobre o Professor -->
<section class="section" id="professor">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">05 - Quem Vai Te Ensinar</span>
      <h2 class="section-title">Uma nota do Alex</h2>
    </div>

    <div class="about-grid">
      <div class="about-image">
        <img src="/img/alex-donega.webp" alt="Alex Donega" loading="lazy" />
      </div>
      <div class="about-content">
        <h3>Alex Donega</h3>
        <p>Cara, eu estudei 43+ artigos e papers sobre Context Engineering - Anthropic, arXiv, contextengineering.ai - pra voce nao precisar. Te passo o atalho.</p>
        <p>Nao sou programador. Fiz mestrado em ECONOMIA na ROMENIA (sim, terra do Dracula!). Se eu consegui dominar Context Engineering, voce consegue. E sobre saber PEDIR pra IA, nao sobre saber programar.</p>
        <p>Uso esses frameworks diariamente nos meus 3 MicroSaaS: Novo Envio, FalaZapp e MyMess. Nao e teoria - e o que funciona na pratica.</p>

        <blockquote class="about-quote">
          "A diferenca entre IA ok e IA impressionante esta no contexto. Aprendi isso na marra - e agora vou te ensinar."
        </blockquote>

        <ul class="credentials-list">
          <li><span class="check">✓</span> Gestor de Projetos na Autobots Ventures</li>
          <li><span class="check">✓</span> Membro do time Autobots Ventures (+25 software)</li>
          <li><span class="check">✓</span> Fundador de 3 MicroSaaS em operacao</li>
          <li><span class="check">✓</span> 43+ artigos estudados sobre Context Engineering</li>
          <li><span class="check">✓</span> Criador dos frameworks DNA System e Conteudo Mestre</li>
        </ul>

        <a href="#investimento" class="btn-primary">Quero aprender com o Alex</a>
      </div>
    </div>
  </div>
</section>

<!-- Secao 06: Modulos -->
<section class="section-dark" id="conteudo">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">06 - Conteudo Completo</span>
      <h2 class="section-title">O que voce vai receber</h2>
    </div>

    <div class="modules-grid">
      <div class="module-card">
        <span class="module-badge">Modulo 1</span>
        <h3>Fundamentos de Context Engineering</h3>
        <p>Entenda a filosofia e por que contexto > prompts.</p>
        <ul class="module-list">
          <li><span class="check">✓</span> O que e Context Engineering</li>
          <li><span class="check">✓</span> Por que prompts sozinhos nao funcionam</li>
          <li><span class="check">✓</span> O modelo mental correto para IA</li>
        </ul>
      </div>

      <div class="module-card">
        <span class="module-badge">Modulo 2</span>
        <h3>DNA System</h3>
        <p>Crie o DNA completo da sua marca/negocio.</p>
        <ul class="module-list">
          <li><span class="check">✓</span> DNA de Personalidade</li>
          <li><span class="check">✓</span> DNA de Publico</li>
          <li><span class="check">✓</span> DNA de Tom de Voz</li>
        </ul>
      </div>

