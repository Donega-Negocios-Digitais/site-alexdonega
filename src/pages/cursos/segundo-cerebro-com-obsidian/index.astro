        <script>
        // Knowledge Graph Animation with Expand + Float effect
        (function() {
            const svg = document.getElementById('knowledge-graph');
            if (!svg) return;

            const centerX = 449.5;
            const centerY = 275;

            const nodes = svg.querySelectorAll('.node');
            const categories = svg.querySelectorAll('.categories circle');
            const allCircles = [...nodes, ...categories];

            // Store original (final) positions
            const finalPositions = [];
            allCircles.forEach((el, i) => {
                finalPositions[i] = {
                    cx: parseFloat(el.getAttribute('cx')),
                    cy: parseFloat(el.getAttribute('cy'))
                };
                // Start all elements at center
                el.setAttribute('cx', centerX);
                el.setAttribute('cy', centerY);
                el.style.opacity = '0';

                // Also hide and center associated text
                const text = el.nextElementSibling;
                if (text && text.tagName === 'text') {
                    text.setAttribute('x', centerX);
                    text.setAttribute('y', centerY);
                    text.style.opacity = '0';
                }
            });

            // Hide lines initially
            const lines = svg.querySelectorAll('.links line');
            lines.forEach(line => {
                line.style.opacity = '0';
            });

            // Floating animation parameters
            const floatParams = allCircles.map(() => ({
                speedX: 0.3 + Math.random() * 0.4,
                speedY: 0.3 + Math.random() * 0.4,
                ampX: 2 + Math.random() * 4,
                ampY: 2 + Math.random() * 4,
                phaseX: Math.random() * Math.PI * 2,
                phaseY: Math.random() * Math.PI * 2
            }));

            let hasExpanded = false;
            let expandStartTime = null;
            const expandDuration = 1200; // ms

            // Easing function for smooth animation
            function easeOutCubic(t) {
                return 1 - Math.pow(1 - t, 3);
            }

            function expandAndFloat(timestamp) {
                if (!expandStartTime) expandStartTime = timestamp;
                const elapsed = timestamp - expandStartTime;
                const progress = Math.min(elapsed / expandDuration, 1);
                const easedProgress = easeOutCubic(progress);

                allCircles.forEach((el, i) => {
                    const final = finalPositions[i];
                    const p = floatParams[i];

                    // Calculate current position during expansion
                    let currentX = centerX + (final.cx - centerX) * easedProgress;
                    let currentY = centerY + (final.cy - centerY) * easedProgress;

                    // Add floating effect after expansion starts
                    if (progress > 0.3) {
                        const floatElapsed = (elapsed - expandDuration * 0.3) / 1000;
                        const floatStrength = Math.min((progress - 0.3) / 0.7, 1);
                        currentX += Math.sin(floatElapsed * p.speedX + p.phaseX) * p.ampX * floatStrength;
                        currentY += Math.sin(floatElapsed * p.speedY + p.phaseY) * p.ampY * floatStrength;
                    }

                    el.setAttribute('cx', currentX);
                    el.setAttribute('cy', currentY);
                    el.style.opacity = Math.min(easedProgress * 1.5, 0.9);

                    // Move associated text
                    const text = el.nextElementSibling;
                    if (text && text.tagName === 'text') {
                        text.setAttribute('x', currentX);
                        text.setAttribute('y', currentY + 4);
                        text.style.opacity = Math.min(easedProgress * 1.5, 1);
                    }
                });

                // Fade in lines
                lines.forEach(line => {
                    line.style.opacity = Math.min(easedProgress * 0.8, 0.6);
                });

                // Continue animation
                if (progress < 1) {
                    requestAnimationFrame(expandAndFloat);
                } else {
                    // Switch to pure floating animation
                    requestAnimationFrame(floatOnly);
                }
            }

            let floatStartTime = null;
            function floatOnly(timestamp) {
                if (!floatStartTime) floatStartTime = timestamp;
                const elapsed = (timestamp - floatStartTime) / 1000;

                allCircles.forEach((el, i) => {
                    const final = finalPositions[i];
                    const p = floatParams[i];

                    const offsetX = Math.sin(elapsed * p.speedX + p.phaseX) * p.ampX;
                    const offsetY = Math.sin(elapsed * p.speedY + p.phaseY) * p.ampY;

                    el.setAttribute('cx', final.cx + offsetX);
                    el.setAttribute('cy', final.cy + offsetY);

                    const text = el.nextElementSibling;
                    if (text && text.tagName === 'text') {
                        text.setAttribute('x', final.cx + offsetX);
                        text.setAttribute('y', final.cy + offsetY + 4);
                    }
                });

                requestAnimationFrame(floatOnly);
            }

            // Intersection Observer to trigger animation when section is visible
            const graphSection = document.querySelector('.graph-section');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting && !hasExpanded) {
                        hasExpanded = true;
                        requestAnimationFrame(expandAndFloat);
                    }
                });
            }, { threshold: 0.3 });

            if (graphSection) {
                observer.observe(graphSection);
            }
        })();
        </script>

        <div style="text-align: center; margin-top: 32px;">
            <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 24px;">
                Este é o Graph View do Obsidian — a visualização que mostra como suas notas se conectam.
            </p>
            <a href="#investimento" class="btn-secondary">Quero criar meu grafo de conhecimento</a>
        </div>
    </div>
</section>

