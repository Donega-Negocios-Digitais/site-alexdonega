            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .bonus-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 32px;
            position: relative;
            overflow: hidden;
        }

        .bonus-card::before {
            content: 'BONUS';
            position: absolute;
            top: 16px;
            right: -24px;
            background: var(--accent);
            color: var(--bg-main);
            font-size: 10px;
            font-weight: 700;
            padding: 4px 32px;
            transform: rotate(45deg);
        }

        .bonus-card h3 {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 12px;
        }

        .bonus-card p {
            font-size: 14px;
            color: var(--text-gray);
            line-height: 1.7;
        }

        .bonus-value {
            margin-top: 16px;
            font-size: 14px;
            color: var(--text-muted);
        }

        .bonus-value span {
            color: var(--accent);
            font-weight: 600;
        }

        /* Pricing Section */
        .pricing-section {
            text-align: center;
        }

        /* Timer Bar */
        .timer-bar {
            background: #dc2626;
            padding: 10px 16px;
            border-radius: 12px 12px 0 0;
            margin: -48px -48px 24px -48px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .timer-bar svg {
            width: 16px;
            height: 16px;
            fill: #ffffff;
            flex-shrink: 0;
        }

        .timer-text {
            color: #ffffff;
            font-weight: 500;
            font-size: 13px;
        }

        .timer-countdown {
            display: flex;
            gap: 6px;
        }

        .timer-unit {
            display: flex;
            align-items: baseline;
            gap: 2px;
        }

        .timer-unit .number {
            font-family: "DePixel Klein", monospace;
            font-size: 14px;
            color: #ffffff;
            font-weight: bold;
        }

        .timer-unit .label {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.8);
        }

        .timer-separator {
            color: #ffffff;
            font-weight: bold;
        }

        /* Social Proof */
        .social-proof {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 24px;
        }

        .social-proof-stars {
            display: flex;
            gap: 4px;
        }

        .social-proof-stars svg {
            width: 24px;
            height: 24px;
            fill: #fbbf24;
        }

        .social-proof-text {
            color: var(--text-gray);
            font-size: 14px;
        }

        .social-proof-text strong {
            color: var(--text-white);
        }

        .pricing-card {
            background: linear-gradient(135deg, var(--bg-card) 0%, rgba(26, 26, 26, 0.8) 100%);
            border: 2px solid var(--accent);
            border-radius: 24px;
            padding: 48px;
            max-width: 550px;
            margin: 0 auto 48px;
        }

        .pricing-badge {
            display: inline-block;
            color: var(--accent);
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 16px;
            border-bottom: 2px solid var(--accent);
            padding-bottom: 8px;
        }

        .pricing-original {
            font-size: 22px;
            color: var(--text-muted);
            text-decoration: line-through;
            margin-bottom: 8px;
        }

        .pricing-main {
            margin-bottom: 24px;
        }

        .pricing-installment {
            font-size: 20px;
            color: var(--text-gray);
            margin-bottom: 8px;
        }

        .pricing-installment strong {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: 72px;
            font-weight: 500;
            color: var(--text-white);
        }

        .pricing-installment .currency {
            font-size: 28px;
            color: var(--accent);
            vertical-align: super;
        }

        .pricing-cash {
            font-size: 18px;
            color: var(--text-muted);
            margin-bottom: 24px;
        }

        .pricing-cash span {
            color: var(--accent);
            font-weight: 600;
            font-size: 20px;
        }

        .pricing-features {
            list-style: none;
            text-align: left;
            margin-bottom: 32px;
        }

        .pricing-features li {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 15px;
            color: var(--text-gray);
            margin-bottom: 12px;
        }

        .pricing-features .check {
            color: var(--accent);
            font-weight: bold;
        }

        .btn-buy {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: #22c55e;
            color: #ffffff;
            padding: 22px 32px;
            border-radius: 12px;
            font-size: 18px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s;
            width: 100%;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-buy:hover {
            background: #16a34a;
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(34, 197, 94, 0.4);
        }

        .btn-buy svg {
            width: 20px;
            height: 20px;
        }

        /* Guarantee Box */
        .guarantee-box {
            background: var(--accent-light);
            border: 1px solid rgba(216, 119, 87, 0.3);
            border-radius: 12px;
            padding: 24px;
            margin-top: 24px;
            display: flex;
            align-items: flex-start;
            gap: 16px;
            text-align: left;
        }

        .guarantee-icon {
            width: 48px;
            height: 48px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .guarantee-icon svg {
            width: 24px;
            height: 24px;
            fill: var(--bg-main);
        }

        .guarantee-content h4 {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 4px;
        }

        .guarantee-content p {
            font-size: 14px;
            color: var(--text-gray);
            line-height: 1.5;
        }

        /* Testimonial Inner (inside pricing card) */
        .testimonial-card-inner {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 24px;
            margin-top: 24px;
            text-align: left;
        }

        .testimonial-stars {
            display: flex;
            gap: 4px;
            margin-bottom: 12px;
        }

        .testimonial-stars svg {
            width: 16px;
            height: 16px;
            fill: #fbbf24;
        }

        .testimonial-text {
            font-size: 14px;
            color: var(--text-light);
            line-height: 1.7;
            font-style: italic;
            margin-bottom: 16px;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .testimonial-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--accent-light);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
            font-weight: 600;
            font-size: 14px;
        }

        .testimonial-info h5 {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 2px;
        }

        .testimonial-info span {
            font-size: 12px;
            color: var(--text-muted);
        }

        /* Payment Methods Inner (inside pricing card) */
        .payment-methods-inner {
            margin-top: 24px;
            padding-top: 24px;
            border-top: 1px solid var(--border);
            text-align: center;
        }

        .payment-label {
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .payment-icons {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .payment-icon {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 50px;
            height: 40px;
        }

        .payment-icon svg {
            height: 18px;
            width: auto;
            fill: var(--text-muted);
        }

        .payment-icon img {
            height: 18px;
            width: auto;
            opacity: 0.7;
        }

        /* FAQ Section */
        .faq-section {
            max-width: 700px;
            margin: 0 auto;
        }

        .faq-item {
            border-bottom: 1px solid var(--border);
            padding: 32px 0;
        }

        .faq-item:first-child {
            border-top: 1px solid var(--border);
        }

        .faq-question {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 12px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .faq-answer {
            font-size: 15px;
            color: var(--text-gray);
            line-height: 1.7;
        }

        /* Footer */
        .footer {
            padding: 64px 24px;
            border-top: 1px solid var(--border);
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 48px;
        }

        .footer-brand h4 {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: 24px;
            font-weight: 500;
            color: var(--text-white);
            margin-bottom: 16px;
        }

        .footer-brand p {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.7;
            max-width: 320px;
        }

        .footer-brand .signature {
            font-style: italic;
            color: var(--accent);
            margin-top: 16px;
            font-size: 13px;
        }

        .footer-column h5 {
            font-size: 12px;
            font-weight: 700;
            color: var(--text-gray);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 20px;
        }

        .footer-column a {
            display: block;
            font-size: 14px;
            color: var(--text-muted);
            text-decoration: none;
            margin-bottom: 14px;
            transition: color 0.2s;
        }

        .footer-column a:hover {
            color: var(--text-white);
        }

        .footer-bottom {
            max-width: 1200px;
            margin: 48px auto 0;
            padding-top: 32px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            color: var(--text-muted);
        }

        /* CTA Section */
        .cta-section {
            text-align: center;
            padding: 120px 24px;
            background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-main) 100%);
        }

        .cta-title {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: clamp(32px, 4vw, 48px);
            font-weight: 500;
            color: var(--text-white);
            margin-bottom: 20px;
            line-height: 1.2;
        }

        .cta-subtitle {
            font-size: 18px;
            color: var(--text-gray);
            margin-bottom: 40px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .cta-buttons {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .about-grid {
                grid-template-columns: 1fr;
                gap: 48px;
            }

            .about-image {
                max-width: 400px;
                margin: 0 auto;
            }
        }

        @media (max-width: 768px) {
            .features-row {
                grid-template-columns: 1fr;
            }

            .feature-item {
                border-right: none;
                border-bottom: 1px solid var(--border);
            }

            .feature-item:last-child {
                border-bottom: none;
            }

            .footer-content {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .footer-bottom {
                flex-direction: column;
                gap: 16px;
                text-align: center;
            }

            .cta-buttons {
                flex-direction: column;
                align-items: center;
            }
        }

        /* ==================== KNOWLEDGE GRAPH SECTION ==================== */
        .graph-section {
            padding: 80px 24px;
            background: var(--bg-main);
            overflow: hidden;
        }

        .graph-container {
            position: relative;
            max-width: 899px;
            height: 550px;
            margin: 0 auto;
        }

        .graph-svg {
            width: 100%;
            height: 100%;
        }

        .graph-svg text {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .graph-container {
                height: 400px;
            }
        }

        @media (max-width: 480px) {
            .graph-container {
                height: 320px;
            }
        }
    </style>
</head>
