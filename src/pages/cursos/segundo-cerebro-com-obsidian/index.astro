<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clone seu Cerebro, Domine o Obsidian | Alex Donega</title>
    <meta name="description" content="Aprenda a construir seu Segundo Cerebro no Obsidian. Organize ideias, conecte pensamentos e nunca mais esqueca nada importante.">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="Clone seu Cerebro, Domine o Obsidian">
    <meta property="og:description" content="Aprenda a construir seu Segundo Cerebro no Obsidian. Organize ideias, conecte pensamentos e nunca mais esqueca nada importante.">
    <meta property="og:url" content="https://alexdonega.com.br/segundo-cerebro-com-obsidian">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Clone seu Cerebro, Domine o Obsidian">
    <meta name="twitter:description" content="Aprenda a construir seu Segundo Cerebro no Obsidian. Organize ideias, conecte pensamentos e nunca mais esqueca nada importante.">

    <style>
        @import '@fontsource/source-serif-4';
        @import '@fontsource/inter';

        /* Fonte DePixel Klein */
        @font-face {
            font-family: "DePixel Klein";
            src: url("https://framerusercontent.com/assets/AxpKr4lNhgmNX1Qyo1xQntsit8.woff2") format("woff2");
            font-display: swap;
            font-style: normal;
            font-weight: 400;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-main: #0a0a0a;
            --bg-secondary: #111111;
            --bg-card: #1a1a1a;
            --bg-card-hover: #222222;
            --text-white: #ffffff;
            --text-light: #e5e5e5;
            --text-gray: #a3a3a3;
            --text-muted: #737373;
            --accent: #d87757;
            --accent-hover: #e8866a;
            --accent-light: rgba(216, 119, 87, 0.1);
            --border: #2a2a2a;
            --gradient-start: #1a1a1a;
            --gradient-end: #0a0a0a;
            /* Obsidian Purple */
            --obsidian: #9b51e0;
            --obsidian-hover: #8a45cc;
            --obsidian-btn: #6D2CD3;
            --obsidian-btn-hover: #5C27AC;
            --obsidian-light: rgba(155, 81, 224, 0.1);
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--bg-main);
            color: var(--text-light);
            font-size: 16px;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Header */
        .header {
            padding: 40px 24px 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 30px;
        }

        .header-line {
            flex: 1;
            height: 1px;
            background: var(--accent);
        }

        .logo {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: 20px;
            font-weight: 500;
            color: var(--text-white);
            text-decoration: none;
        }

        .logo span {
            color: var(--accent);
        }

        /* Hero Section */
        .hero {
            padding: 80px 24px 60px;
            text-align: center;
            background: var(--bg-secondary);
            border-radius: 20px;
            margin: 22px 24px;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 60%;
            height: 100%;
            background: radial-gradient(ellipse at 70% 30%, rgba(155, 81, 224, 0.12) 0%, transparent 60%);
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent-light);
            border: 1px solid rgba(216, 119, 87, 0.3);
            padding: 8px 16px;
            border-radius: 100px;
            font-size: 13px;
            color: var(--accent);
            margin-bottom: 24px;
        }

        .hero h1 {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: clamp(36px, 5vw, 56px);
            font-weight: 500;
            line-height: 1.1;
            color: var(--text-white);
            margin-bottom: 24px;
            letter-spacing: -1px;
        }

        .hero h1 .highlight {
            color: var(--accent);
            font-family: "DePixel Klein", monospace;
            font-size: 1.05em;
            letter-spacing: 2px;
        }

        .hero .subtitle {
            font-size: clamp(18px, 2.5vw, 22px);
            color: var(--text-gray);
            max-width: 700px;
            margin: 0 auto 32px;
            line-height: 1.7;
        }

        /* Video Container */
        .video-container {
            max-width: 800px;
            margin: 40px auto;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            background: var(--bg-card);
            aspect-ratio: 16/9;
        }

        .video-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-secondary) 100%);
            color: var(--text-muted);
            font-size: 18px;
        }

        .hero-video-text {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: clamp(20px, 3vw, 28px);
            color: var(--text-white);
            max-width: 800px;
            margin: 40px auto 0;
            line-height: 1.5;
            text-align: center;
        }

        /* Buttons */
        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--obsidian-btn);
            color: var(--text-white);
            padding: 16px 32px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-primary:hover {
            background: var(--obsidian-btn-hover);
            transform: translateY(-2px);
        }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: transparent;
            color: var(--text-white);
            padding: 16px 32px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            text-decoration: none;
            border: 1px solid var(--border);
            transition: all 0.2s;
        }

        .btn-secondary:hover {
            background: var(--bg-card);
            border-color: var(--text-muted);
        }

        /* Section Styles */
        .section {
            padding: 100px 24px;
        }

        .section-dark {
            background: var(--bg-secondary);
        }

        .section-header {
            text-align: center;
            max-width: 700px;
            margin: 0 auto 64px;
        }

        .section-eyebrow {
            font-size: 12px;
            font-weight: 700;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 16px;
        }

        .section-title {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: clamp(32px, 4vw, 40px);
            font-weight: 500;
            color: var(--text-white);
            margin-bottom: 20px;
            line-height: 1.2;
        }

        .section-subtitle {
            font-size: 18px;
            color: var(--text-gray);
            line-height: 1.7;
        }

        /* Divider */
        .divider {
            height: 1px;
            background: var(--accent);
            margin: 0 24px;
        }

        /* Benefits Grid */
        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 32px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .benefit-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 40px 32px;
            transition: all 0.3s;
        }

        .benefit-card:hover {
            border-color: var(--accent);
            transform: translateY(-4px);
        }

        .benefit-icon {
            width: 56px;
            height: 56px;
            background: var(--accent-light);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
        }

        .benefit-icon svg {
            width: 28px;
            height: 28px;
            stroke: var(--accent);
            fill: none;
            stroke-width: 2;
        }

        .benefit-card h3 {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 12px;
        }

        .benefit-card p {
            font-size: 15px;
            color: var(--text-gray);
            line-height: 1.7;
        }

        /* Features Section */
        .features-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0;
            background: var(--bg-card);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .feature-item {
            padding: 48px 32px;
            text-align: center;
            border-right: 1px solid var(--border);
        }

        .feature-item:last-child {
            border-right: none;
        }

        .feature-number {
            font-family: "DePixel Klein", monospace;
            font-size: 48px;
            color: var(--accent);
            margin-bottom: 16px;
        }

        .feature-item h3 {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 8px;
        }

        .feature-item p {
            font-size: 14px;
            color: var(--text-muted);
        }

        /* Apps Icons Grid */
        .apps-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 24px;
            max-width: 800px;
            margin: 0 auto;
        }

        .app-icon {
            width: 64px;
            height: 64px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.5;
            transition: all 0.3s;
        }

        .app-icon:hover {
            opacity: 0.8;
            transform: scale(1.05);
        }

        .app-icon svg {
            width: 32px;
            height: 32px;
            fill: var(--text-muted);
        }

        .app-icon.obsidian {
            opacity: 1;
            border-color: var(--accent);
            background: var(--accent-light);
        }

        .app-icon.obsidian svg {
            fill: var(--accent);
        }

        /* Floating Icons */
        .floating-icons-container {
            position: relative;
            padding: 60px 0;
        }

        .floating-icon {
            position: absolute;
            width: 48px;
            height: 48px;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            opacity: 0.6;
            transition: all 0.3s ease;
            z-index: 1;
        }

        .floating-icon:hover {
            opacity: 1;
            transform: scale(1.15);
        }

        .floating-icon img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            border-radius: 12px;
        }

        .floating-icon:nth-child(1) {
            top: 10%;
            left: 5%;
            animation: float1 6s ease-in-out infinite;
        }

        .floating-icon:nth-child(2) {
            top: 20%;
            right: 8%;
            animation: float2 7s ease-in-out infinite;
        }

        .floating-icon:nth-child(3) {
            top: 50%;
            left: 3%;
            animation: float3 5s ease-in-out infinite;
        }

        .floating-icon:nth-child(4) {
            top: 60%;
            right: 5%;
            animation: float1 6.5s ease-in-out infinite;
        }

        .floating-icon:nth-child(5) {
            bottom: 15%;
            left: 8%;
            animation: float2 5.5s ease-in-out infinite;
        }

        .floating-icon:nth-child(6) {
            bottom: 20%;
            right: 10%;
            animation: float3 7s ease-in-out infinite;
        }

        @keyframes float1 {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(5deg); }
        }

        @keyframes float2 {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(-5deg); }
        }

        @keyframes float3 {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-12px) rotate(3deg); }
        }

        @media (max-width: 768px) {
            .floating-icon {
                width: 36px;
                height: 36px;
                opacity: 0.4;
            }

            .floating-icon:nth-child(1) { left: 2%; }
            .floating-icon:nth-child(2) { right: 2%; }
            .floating-icon:nth-child(3) { left: 1%; }
            .floating-icon:nth-child(4) { right: 2%; }
            .floating-icon:nth-child(5) { left: 3%; }
            .floating-icon:nth-child(6) { right: 3%; }
        }

        /* ACE Framework Section */
        .ace-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .ace-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 40px 32px;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .ace-card:hover {
            transform: translateY(-8px);
            border-color: var(--accent);
            box-shadow: 0 20px 40px rgba(216, 119, 87, 0.15);
        }

        .ace-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--accent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .ace-card:hover::before {
            opacity: 1;
        }

        .ace-letter {
            font-family: "DePixel Klein", monospace;
            font-size: 72px;
            color: var(--accent);
            line-height: 1;
            margin-bottom: 8px;
        }

        .ace-word {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: 28px;
            font-weight: 500;
            color: var(--text-white);
            margin-bottom: 16px;
        }

        .ace-description {
            font-size: 15px;
            color: var(--text-gray);
            line-height: 1.7;
        }

        .ace-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(216, 119, 87, 0.15);
            border: 1px solid rgba(216, 119, 87, 0.4);
            padding: 12px 24px;
            border-radius: 100px;
            margin-bottom: 32px;
        }

        .ace-badge-text {
            font-size: 14px;
            color: var(--accent);
            font-weight: 600;
        }

        .ace-badge svg {
            width: 18px;
            height: 18px;
            fill: var(--accent);
        }

        .methodology-quote {
            max-width: 700px;
            margin: 48px auto 0;
            text-align: center;
            padding: 32px;
            background: var(--accent-light);
            border-radius: 16px;
            border-left: 4px solid var(--accent);
        }

        .methodology-quote p {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: 20px;
            font-style: italic;
            color: var(--text-light);
            margin-bottom: 16px;
        }

        .methodology-quote cite {
            font-size: 14px;
            color: var(--text-muted);
            font-style: normal;
        }

        .methodology-quote cite strong {
            color: var(--accent);
        }

        @media (max-width: 768px) {
            .ace-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .ace-letter {
                font-size: 56px;
            }

            .ace-word {
                font-size: 24px;
            }
        }

        /* Central Obsidian Logo */
        .central-logo-area {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 280px;
            margin: 40px auto;
            position: relative;
            width: 100%;
        }

        .obsidian-central {
            width: 140px;
            height: 140px;
            background: transparent;
            border-radius: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 20px 60px rgba(155, 81, 224, 0.5), 0 0 80px rgba(155, 81, 224, 0.3);
            position: relative;
            z-index: 100;
        }

        .obsidian-central img {
            width: 120px;
            height: 120px;
            object-fit: contain;
        }

        @keyframes pulse-glow {
            0%, 100% {
                box-shadow: 0 20px 60px rgba(155, 81, 224, 0.5), 0 0 80px rgba(155, 81, 224, 0.3);
                transform: scale(1);
            }
            50% {
                box-shadow: 0 25px 80px rgba(216, 119, 87, 0.5), 0 0 100px rgba(216, 119, 87, 0.3);
                transform: scale(1.05);
            }
        }

        .obsidian-label {
            text-align: center;
            margin-top: 20px;
        }

        .obsidian-label h3 {
            font-family: "DePixel Klein", monospace;
            font-size: 32px;
            color: var(--accent);
            margin-bottom: 8px;
        }

        .obsidian-label p {
            font-size: 14px;
            color: var(--text-muted);
        }

        /* Video Feature Row (horizontal layout) */
        .video-feature-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 48px;
            align-items: center;
            max-width: 1000px;
            margin: 0 auto 64px;
        }

        .video-feature-row:last-child {
            margin-bottom: 0;
        }

        .video-feature-row.reverse {
            direction: rtl;
        }

        .video-feature-row.reverse > * {
            direction: ltr;
        }

        .video-feature-media {
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }

        .video-feature-media video {
            width: 100%;
            height: auto;
            display: block;
        }

        .video-feature-text h3 {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: 28px;
            font-weight: 500;
            color: var(--text-white);
            margin-bottom: 16px;
        }

        .video-feature-text p {
            font-size: 16px;
            color: var(--text-gray);
            line-height: 1.8;
        }

        @media (max-width: 768px) {
            .video-feature-row {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .video-feature-row.reverse {
                direction: ltr;
            }
        }

        /* How It Works */
        .steps-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 32px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .step-card {
            background: linear-gradient(135deg, var(--bg-card) 0%, rgba(26, 26, 26, 0.8) 100%);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 32px;
            position: relative;
        }

        .step-number {
            font-family: "DePixel Klein", monospace;
            font-size: 64px;
            color: var(--obsidian);
            opacity: 0.3;
            position: absolute;
            top: 16px;
            right: 24px;
        }

        .step-card h3 {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 12px;
        }

        .step-card p {
            font-size: 15px;
            color: var(--text-gray);
            line-height: 1.7;
        }

        /* Target Audience */
        .audience-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 24px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .audience-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 32px;
            text-align: center;
            transition: all 0.3s;
        }

        .audience-card:hover {
            border-color: rgba(216, 119, 87, 0.5);
        }

        .audience-icon {
            width: 56px;
            height: 56px;
            background: var(--accent-light);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
        }

        .audience-icon svg {
            width: 28px;
            height: 28px;
            stroke: var(--accent);
            fill: none;
            stroke-width: 2;
        }

        .audience-card h3 {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 8px;
        }

        .audience-card p {
            font-size: 14px;
            color: var(--text-muted);
        }

        /* About Section */
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 64px;
            align-items: start;
            max-width: 1000px;
            margin: 0 auto;
        }

        .about-image {
            border-radius: 20px;
            overflow: hidden;
            background: linear-gradient(180deg, #c9956c 0%, #8b5a3c 50%, #5a3825 100%);
            aspect-ratio: 4/5;
        }

        .about-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .about-content h3 {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: 32px;
            font-weight: 500;
            color: var(--text-white);
            margin-bottom: 24px;
        }

        .about-content p {
            font-size: 16px;
            color: var(--text-gray);
            line-height: 1.8;
            margin-bottom: 20px;
        }

        .about-content blockquote {
            font-family: 'Source Serif 4', Georgia, serif;
            font-size: 20px;
            font-style: italic;
            color: var(--accent);
            padding-left: 24px;
            border-left: 3px solid var(--accent);
            margin: 32px 0;
        }

        /* What You Get */
        .modules-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .module-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 32px;
        }

        .module-badge {
            display: inline-block;
            background: var(--accent);
            color: var(--bg-main);
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 6px 12px;
            border-radius: 4px;
            margin-bottom: 16px;
        }

        .module-card h3 {
            font-size: 20px;
            font-weight: 600;
            color: var(--text-white);
            margin-bottom: 12px;
        }

        .module-card p {
            font-size: 14px;
            color: var(--text-gray);
            line-height: 1.7;
        }

        .module-list {
            list-style: none;
            margin-top: 16px;
        }

        .module-list li {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 14px;
            color: var(--text-gray);
            margin-bottom: 10px;
