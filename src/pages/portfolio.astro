            <div class="stat-item">
              <div class="stat-number">86%</div>
              <div class="stat-label">Tráfego orgânico em 4 semanas</div>
            </div>
          </div>

        </div>
      </div>

    </div> <!-- Fim do grid -->

    <!-- CTA Final -->
    <div class="testimonials-cta">
      <p class="cta-text">Pronto para transformar seu produto SaaS?</p>
      <a href="#contato" class="btn btn-primary">Fale Comigo</a>
    </div>

  </div>
</section>

<script>
  // Controle de vídeos de testemunhos
  document.addEventListener('DOMContentLoaded', function() {
    const videos = document.querySelectorAll('.testimonial-video-player');
    const playButtons = document.querySelectorAll('.play-button');
    const videoOverlays = document.querySelectorAll('.video-overlay');

    function toggleVideo(video, button, overlay, index) {
      if (video.paused) {
        video.play();
        button.innerHTML = `
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
          </svg>
        `;
        overlay.classList.add('playing');
      } else {
        video.pause();
        button.innerHTML = `
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
            <path d="M8 5v14l11-7z"/>
          </svg>
        `;
        overlay.classList.remove('playing');
      }
    }

    playButtons.forEach((button, index) => {
      const video = videos[index];
      const overlay = videoOverlays[index];

      button.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleVideo(video, button, overlay, index);
      });

      video.addEventListener('click', () => {
        toggleVideo(video, button, overlay, index);
      });

      video.addEventListener('ended', () => {
        button.innerHTML = `
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
            <path d="M8 5v14l11-7z"/>
          </svg>
        `;
        overlay.classList.remove('playing');
        video.currentTime = 0;
      });
    });

    videos.forEach((video, index) => {
      video.addEventListener('play', () => {
        videos.forEach((otherVideo, otherIndex) => {
          if (otherIndex !== index && !otherVideo.paused) {
            otherVideo.pause();
            playButtons[otherIndex].innerHTML = `
              <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
                <path d="M8 5v14l11-7z"/>
              </svg>
            `;
            videoOverlays[otherIndex].classList.remove('playing');
          }
        });
      });
    });
  });
</script>

</Layout>
