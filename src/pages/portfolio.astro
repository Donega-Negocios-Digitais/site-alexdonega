---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Portfólio SaaS"
  description="Case studies de software SaaS que entregaram crescimento real. Veja projetos de CRM, automação com IA, gestão WhatsApp e operações de vendas."
>

<style>
  /* ==================== HERO SECTION ==================== */
  .hero {
    padding: 80px 16px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(ellipse at 50% 0%, rgba(216, 119, 87, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-content {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #9ca3af;
    margin-bottom: 16px;
  }

  .hero-title {
    font-size: 36px;
    font-weight: 700;
    color: white;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .hero-subtitle {
    font-size: 18px;
    color: #d1d5db;
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
  }

  /* ==================== CASE STUDIES SECTION ==================== */
  .cases-section {
    padding: 60px 16px;
  }

  .case-study {
    max-width: 1200px;
    margin: 0 auto 120px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
  }

  .case-study:last-child {
    margin-bottom: 60px;
  }

  .case-study:nth-child(1) { animation-delay: 0.1s; }
  .case-study:nth-child(2) { animation-delay: 0.2s; }
  .case-study:nth-child(3) { animation-delay: 0.3s; }
  .case-study:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .case-preview {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    padding: 24px;
    overflow: hidden;
    position: relative;
  }

  .case-preview img,
  .case-preview video {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }

  .case-preview video {
    object-fit: cover;
    aspect-ratio: 16 / 9;
    transition: transform 0.3s ease;
  }

  .case-study:hover .case-preview video {
    transform: scale(1.02);
  }

  .case-study:hover .case-preview {
    border-color: rgba(216, 119, 87, 0.3);
  }

  .case-content {
    padding: 0;
  }

  .case-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #9ca3af;
    margin-bottom: 16px;
  }

  .case-title {
    font-size: 28px;
    font-weight: 700;
    color: white;
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .case-description {
    font-size: 16px;
    color: #d1d5db;
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .case-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #d87757;
    color: #0a0a0a;
    padding: 14px 28px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    margin-bottom: 32px;
  }

  .case-btn:hover {
    background: #e8866a;
    transform: translateY(-2px);
  }

  .case-testimonial {
    background: #1a1a1a;
    border-left: 3px solid #d87757;
    padding: 20px;
    border-radius: 8px;
    margin-top: 24px;
  }

  .testimonial-quote {
    font-size: 15px;
    color: #d1d5db;
    line-height: 1.7;
    margin-bottom: 16px;
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(216, 119, 87, 0.1);
    overflow: hidden;
  }

  .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .author-info h4 {
    font-size: 14px;
    font-weight: 600;
    color: white;
    margin-bottom: 2px;
  }

  .author-info p {
    font-size: 13px;
    color: #9ca3af;
  }

  /* ==================== TESTIMONIALS SECTION ==================== */
  .testimonials-section {
    padding: 80px 16px;
    background: linear-gradient(135deg, #111111 0%, #0a0a0a 100%);
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title {
    font-size: 36px;
    font-weight: 700;
    color: white;
    margin-bottom: 12px;
    line-height: 1.1;
  }

  .section-subtitle {
    font-size: 18px;
    color: #d1d5db;
    max-width: 600px;
    margin: 0 auto;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 60px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .testimonial-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .testimonial-card:hover {
    transform: translateY(-8px);
    border-color: rgba(216, 119, 87, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .testimonial-video {
    position: relative;
    height: 280px;
    overflow: hidden;
    background: #000;
  }

  .testimonial-video-player {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .testimonial-card:hover .testimonial-video-player {
    transform: scale(1.05);
  }

  .video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .video-overlay.playing {
    opacity: 0;
  }

  .play-button {
    width: 64px;
    height: 64px;
    background: rgba(216, 119, 87, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    pointer-events: all;
  }

  .play-button:hover {
    background: #e8866a;
    transform: scale(1.1);
  }

  .play-button svg {
    width: 24px;
    height: 24px;
    margin-left: 4px;
  }

  .testimonial-content {
    padding: 32px 24px;
  }

  .testimonial-content .testimonial-quote {
    font-size: 16px;
    line-height: 1.7;
    color: #d1d5db;
    margin-bottom: 24px;
    font-style: italic;
    position: relative;
    padding-left: 24px;
    border-left: 3px solid #d87757;
  }

  .testimonial-content .testimonial-author {
    display: flex;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid #2a2a2a;
  }

  .testimonial-content .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    margin-right: 16px;
    background: rgba(216, 119, 87, 0.1);
  }

  .testimonial-content .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-content .author-info {
    flex: 1;
  }

  .testimonial-content .author-name {
    font-weight: 600;
    color: white;
    margin-bottom: 4px;
    font-size: 15px;
  }

  .testimonial-content .author-role {
    font-size: 13px;
    color: #9ca3af;
  }

  .testimonial-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .stat-item {
    text-align: center;
    padding: 20px 16px;
    background: #111111;
    border-radius: 8px;
    transition: all 0.3s ease;
    border: 1px solid #2a2a2a;
  }

  .stat-item:hover {
    background: #222222;
    border-color: rgba(216, 119, 87, 0.3);
  }

  .stat-number {
    font-size: 28px;
    font-weight: 700;
    color: #d87757;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 13px;
    color: #d1d5db;
    line-height: 1.3;
  }

  .testimonials-cta {
    text-align: center;
    padding: 48px 24px;
    background: #1a1a1a;
    border-radius: 16px;
    border: 1px solid #2a2a2a;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-text {
    font-size: 24px;
    font-weight: 600;
    color: white;
    margin-bottom: 24px;
  }

  .btn-primary {
    display: inline-block;
    background: #d87757;
    color: #0a0a0a;
    padding: 14px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background: #e8866a;
    transform: translateY(-2px);
  }

  /* Responsividade */
  @media (min-width: 768px) {
    .hero {
      padding: 120px 24px 60px;
    }

    .hero-title {
      font-size: 48px;
    }

    .hero-subtitle {
      font-size: 20px;
    }

    .cases-section {
      padding: 80px 24px;
    }

    .case-title {
      font-size: 32px;
    }

    .case-preview video {
      aspect-ratio: 16 / 10;
    }

    .testimonials-section {
      padding: 100px 24px;
    }

    .section-title {
      font-size: 48px;
    }

    .section-subtitle {
      font-size: 20px;
    }

    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .testimonial-video {
      height: 320px;
    }

    .testimonial-card:nth-child(3) {
      grid-column: span 2;
      max-width: 600px;
      margin: 0 auto;
    }
  }

  @media (min-width: 1024px) {
    .case-study {
      grid-template-columns: 45% 1fr;
      gap: 60px;
    }

    .case-title {
      font-size: 36px;
    }

    .hero-title {
      font-size: 56px;
    }

    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .testimonial-card:nth-child(3) {
      grid-column: auto;
      max-width: none;
    }

    .testimonial-video {
      height: 360px;
    }
  }
</style>

<!-- Hero Section -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-eyebrow">PORTFÓLIO</div>
