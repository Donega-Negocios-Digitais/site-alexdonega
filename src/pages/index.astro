</style>

<script>
  // Controle do vídeo com botão de play
  document.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    const playBtn = document.querySelector('.video-play-btn') as HTMLButtonElement;

    if (video && playBtn) {
      // Ao clicar no botão de play
      playBtn.addEventListener('click', () => {
        if (video.paused) {
          video.muted = false; // Ativa o som ao clicar
          video.play();
          playBtn.classList.add('hidden');
        }
      });

      // Ao clicar no vídeo para pausar/play
      video.addEventListener('click', () => {
        if (video.paused) {
          video.play();
          playBtn.classList.add('hidden');
        } else {
          video.pause();
          playBtn.classList.remove('hidden');
        }
      });

      // Quando o vídeo terminar
      video.addEventListener('ended', () => {
        playBtn.classList.remove('hidden');
      });

      // Autoplay muted ao entrar na viewport (opcional)
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            video.play().catch(() => {
              // Autoplay blocked, show play button
              playBtn.classList.remove('hidden');
            });
          } else {
            video.pause();
          }
        });
      }, { threshold: 0.5 });

      observer.observe(video);
    }

    // Filtros da Curadoria (Pinterest Grid)
    const filterBtns = document.querySelectorAll('.filter-btn');
    const coursePosters = document.querySelectorAll('.course-poster');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Remove active de todos
        filterBtns.forEach(b => b.classList.remove('active'));
        // Adiciona active no clicado
        btn.classList.add('active');

        const filter = btn.getAttribute('data-filter');

        coursePosters.forEach(poster => {
          const posterEl = poster as HTMLElement;
          if (filter === 'all') {
            posterEl.classList.remove('hidden');
          } else {
            const category = posterEl.getAttribute('data-category');
            if (category === filter) {
              posterEl.classList.remove('hidden');
            } else {
              posterEl.classList.add('hidden');
            }
          }
        });
      });
    });

    // Modal Newsletter
    const modal = document.getElementById('newsletter-modal');
    const modalTriggers = document.querySelectorAll('[data-open-modal="newsletter-modal"]');
    const modalCloseBtn = modal?.querySelector('.modal-close');
    const modalCloseText = modal?.querySelector('.modal-close-text');
    const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement;

    // Função para fechar modal
    const closeModal = () => {
      modal?.classList.remove('active');
      document.body.style.overflow = '';
    };

    // Abrir modal
    modalTriggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        modal?.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    // Fechar modal - botão X
    modalCloseBtn?.addEventListener('click', closeModal);

    // Fechar modal - botão "Não, obrigado"
    modalCloseText?.addEventListener('click', closeModal);

    // Fechar modal - clicando fora
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Fechar modal - tecla ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal?.classList.contains('active')) {
        closeModal();
      }
    });

    // Submit do formulário
    newsletterForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      const formData = new FormData(newsletterForm);
      const name = formData.get('name');
      const email = formData.get('email');

      // Aqui você pode integrar com sua ferramenta de email marketing
      // Ex: Mailchimp, ConvertKit, etc.
      console.log('Newsletter signup:', { name, email });

      // Feedback visual
      const submitBtn = newsletterForm.querySelector('.form-submit') as HTMLButtonElement;
      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'INSCRITO! ✓';
      submitBtn.style.background = 'rgb(52, 211, 153)';

      setTimeout(() => {
        closeModal();
        // Reset form
        newsletterForm.reset();
        submitBtn.textContent = originalText;
        submitBtn.style.background = '';
      }, 2000);
    });
  });
</script>
