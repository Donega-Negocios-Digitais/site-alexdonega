    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ==================== JORNADA ==================== */
  .journey-wrapper {
    max-width: 900px;
    margin: 0 auto;
  }

  .journey-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .journey-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1.5rem;
  }

  .journey-divider {
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, rgb(249, 115, 22), rgb(251, 146, 60));
    margin: 0 auto 1.5rem;
    border-radius: 2px;
  }

  .journey-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .journey-phases {
    display: grid;
    gap: 2rem;
  }

  .journey-phase {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.3s;
  }

  .journey-phase:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(249, 115, 22, 0.3);
    transform: translateY(-4px);
  }

  .phase-number {
    position: absolute;
    top: -12px;
    left: 24px;
    background: linear-gradient(135deg, rgb(249, 115, 22), rgb(234, 88, 12));
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
  }

  .journey-phase h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 1rem;
    margin-top: 0.5rem;
  }

  .journey-phase p {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .journey-phase p:last-child {
    margin-bottom: 0;
  }

  .journey-phase strong {
    color: rgb(251, 146, 60);
  }

  .journey-phase em {
    color: rgba(255, 255, 255, 0.9);
  }

  /* ==================== SERVIÇOS ==================== */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.3s;
  }

  .service-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(249, 115, 22, 0.3);
    transform: translateY(-4px);
  }

  .service-icon {
    width: 48px;
    height: 48px;
    background: rgba(249, 115, 22, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .service-icon svg {
    width: 24px;
    height: 24px;
    color: rgb(249, 115, 22);
  }

  .service-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.75rem;
  }

  .service-card p {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
  }

  /* ==================== PORTFÓLIO ==================== */
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .portfolio-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.3s;
  }

  .portfolio-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(249, 115, 22, 0.3);
    transform: translateY(-4px);
  }

  .portfolio-header {
    margin-bottom: 1rem;
  }

  .portfolio-status {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .portfolio-status.active {
    background: rgba(52, 211, 153, 0.15);
    color: rgb(52, 211, 153);
  }

  .portfolio-status.building {
    background: rgba(251, 191, 36, 0.15);
    color: rgb(251, 191, 36);
  }

  .portfolio-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.5rem;
  }

  .portfolio-card p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .portfolio-link {
    color: rgb(249, 115, 22);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .portfolio-link:hover {
    color: rgb(251, 146, 60);
  }

  .portfolio-link.muted {
    color: rgba(255, 255, 255, 0.4);
  }

  /* ==================== CURSOS ==================== */
  .courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2rem;
  }

  .course-card {
    position: relative;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 2rem;
    transition: all 0.3s;
  }

  .course-card:hover {
    border-color: rgba(249, 115, 22, 0.5);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(249, 115, 22, 0.15);
  }

  .course-badge {
    position: absolute;
    top: -10px;
    right: 20px;
    background: linear-gradient(135deg, rgb(249, 115, 22), rgb(234, 88, 12));
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .course-card h3 {
    font-size: 1.375rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
    margin-top: 0.5rem;
    line-height: 1.3;
  }

  .course-card > p {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .course-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  .course-features li {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .course-features li:last-child {
    border-bottom: none;
  }

  /* ==================== CURADORIA (PINTEREST STYLE) ==================== */
  .curadoria-filters {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.625rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: rgba(249, 115, 22, 0.5);
    color: white;
  }

  .filter-btn.active {
    background: linear-gradient(135deg, rgb(249, 115, 22), rgb(234, 88, 12));
    border-color: transparent;
    color: white;
  }

  /* Pinterest Masonry Grid */
  .pinterest-grid {
    columns: 5;
    column-gap: 16px;
  }

  @media (max-width: 1400px) {
    .pinterest-grid { columns: 4; }
  }

  @media (max-width: 1100px) {
    .pinterest-grid { columns: 3; }
  }

  @media (max-width: 768px) {
    .pinterest-grid { columns: 2; }
  }

  @media (max-width: 480px) {
    .pinterest-grid { columns: 2; column-gap: 10px; }
  }

  /* Course Poster Card */
  .course-poster {
    position: relative;
    break-inside: avoid;
    margin-bottom: 16px;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .course-poster:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .course-poster.hidden {
    display: none;
  }

  /* Poster Image/Background */
  .poster-image {
    width: 100%;
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .course-poster.tall .poster-image {
    height: 280px;
  }

  .poster-icon {
    font-size: 3rem;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
  }

  /* Overlay com informações */
  .poster-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.7) 60%, transparent 100%);
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .course-poster:hover .poster-overlay {
    transform: translateY(0);
  }

  .poster-category {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .poster-category.copy {
    background: rgba(168, 85, 247, 0.3);
    color: rgb(192, 132, 252);
  }

  .poster-category.trafego {
    background: rgba(59, 130, 246, 0.3);
    color: rgb(96, 165, 250);
  }

  .poster-category.ia {
    background: rgba(52, 211, 153, 0.3);
    color: rgb(110, 231, 183);
  }

  .poster-category.mentoria {
    background: rgba(251, 191, 36, 0.3);
    color: rgb(253, 224, 71);
  }

  .poster-overlay h3 {
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .poster-author {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  /* Badge de conclusão */
  .poster-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    color: rgb(52, 211, 153);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 20px;
    border: 1px solid rgba(52, 211, 153, 0.3);
  }

  /* Footer com contadores */
  .curadoria-footer {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    flex-wrap: wrap;
  }

  .curso-counter {
    text-align: center;
  }

  .counter-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    color: rgb(249, 115, 22);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .counter-text {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 640px) {
    .curadoria-footer {
      gap: 2rem;
    }
    .counter-number {
      font-size: 2rem;
    }
  }

  /* ==================== BUILD IN PUBLIC ==================== */
  .build-in-public {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  @media (max-width: 900px) {
    .build-in-public {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* Foto */
  .bip-photo {
    display: flex;
    justify-content: center;
  }

  .bip-photo-wrapper {
    position: relative;
    width: 100%;
    max-width: 320px;
  }

  .bip-photo-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(circle, rgba(249, 115, 22, 0.25) 0%, transparent 70%);
    filter: blur(50px);
    z-index: -1;
    animation: glow-pulse 4s ease-in-out infinite;
  }

  .bip-photo-container {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 100%);
    aspect-ratio: 3 / 4;
  }

  .bip-photo-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Placeholder quando não tem imagem */
  .bip-photo-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(249, 115, 22, 0.1) 0%, rgba(0,0,0,0.8) 100%);
  }

  .bip-photo-container img + .bip-photo-placeholder {
    display: none;
  }

  .bip-photo-container img[src=""] ~ .bip-photo-placeholder,
  .bip-photo-container img:not([src]) ~ .bip-photo-placeholder {
    display: flex;
  }

  .placeholder-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .placeholder-text {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* Decorações */
  .bip-decoration {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    animation: float 6s ease-in-out infinite;
  }

  .bip-decoration svg {
    color: rgb(249, 115, 22);
  }

  .bip-decoration-1 {
    width: 48px;
    height: 48px;
    background: rgba(249, 115, 22, 0.15);
    border: 1px solid rgba(249, 115, 22, 0.3);
    top: -15px;
    right: -15px;
  }

  .bip-decoration-2 {
    width: 36px;
    height: 36px;
    background: rgba(52, 211, 153, 0.15);
    border: 1px solid rgba(52, 211, 153, 0.3);
    bottom: 60px;
    left: -18px;
    animation-delay: -3s;
  }

  .bip-decoration-2 svg {
    color: rgb(52, 211, 153);
  }

  /* Conteúdo */
  .bip-content {
    padding: 1rem 0;
  }

  .bip-content .section-eyebrow {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgb(251, 146, 60);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .bip-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: white;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .bip-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  /* Canais */
  .bip-channels {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .bip-channel {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s;
  }

  .bip-channel:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(249, 115, 22, 0.3);
    transform: translateX(4px);
  }

  .channel-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .channel-icon svg {
    width: 22px;
    height: 22px;
  }

  .channel-icon.youtube {
    background: rgba(255, 0, 0, 0.15);
  }
  .channel-icon.youtube svg {
    color: #ff0000;
  }

  .channel-icon.instagram {
    background: linear-gradient(135deg, rgba(131, 58, 180, 0.2), rgba(253, 29, 29, 0.2), rgba(252, 176, 69, 0.2));
  }
  .channel-icon.instagram svg {
    color: #e1306c;
  }

  .channel-icon.newsletter {
    background: rgba(249, 115, 22, 0.15);
  }
  .channel-icon.newsletter svg {
    color: rgb(249, 115, 22);
  }

  .channel-icon.twitter {
    background: rgba(255, 255, 255, 0.1);
  }
  .channel-icon.twitter svg {
    color: white;
  }

  .channel-info {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .channel-name {
    font-size: 1rem;
    font-weight: 600;
    color: white;
  }

  .channel-handle {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .channel-arrow {
    width: 20px;
    height: 20px;
    color: rgba(255, 255, 255, 0.3);
    transition: all 0.3s;
  }

  .bip-channel:hover .channel-arrow {
    color: rgb(249, 115, 22);
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .bip-photo {
      order: -1;
    }
    .bip-content {
      text-align: center;
    }
    .bip-subtitle {
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* ==================== CTA SECTION ==================== */
  .cta-section {
    padding: 6rem 0;
    background: linear-gradient(135deg, rgba(249, 115, 22, 0.1) 0%, rgba(0, 0, 0, 0.9) 50%, rgba(234, 88, 12, 0.1) 100%);
    text-align: center;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
  }

  .cta-subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ==================== MODAL NEWSLETTER (ALTA CONVERSÃO) ==================== */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-container {
    display: grid;
    grid-template-columns: 280px 1fr;
    max-width: 720px;
    width: 100%;
    background: #0a0a0a;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    transform: scale(0.9) translateY(20px);
    transition: transform 0.3s ease;
  }

  .modal-overlay.active .modal-container {
    transform: scale(1) translateY(0);
  }

  /* Botão Fechar */
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    z-index: 10;
  }

  .modal-close svg {
    width: 18px;
    height: 18px;
    color: rgba(255, 255, 255, 0.6);
  }

  .modal-close:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .modal-close:hover svg {
    color: white;
  }

  /* Lado da Imagem */
  .modal-image {
    position: relative;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
    overflow: hidden;
  }

  .modal-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 450px;
  }

  .modal-image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%);
  }

  .modal-social-proof {
    display: flex;
    flex-direction: column;
  }

  .proof-number {
    font-size: 1.75rem;
    font-weight: 700;
    color: rgb(249, 115, 22);
    line-height: 1;
  }

  .proof-text {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 0.25rem;
  }

  /* Lado do Conteúdo */
  .modal-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
  }

  .modal-brand {
    margin-bottom: 1.25rem;
  }

  .brand-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .modal-title {
    font-size: 1.625rem;
    font-weight: 700;
    color: white;
    line-height: 1.3;
    margin: 0 0 0.75rem;
  }

  .modal-subtitle {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
    margin: 0 0 1.5rem;
  }

  .modal-benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  .modal-benefits li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.5rem 0;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .benefit-check {
    color: rgb(52, 211, 153);
    font-weight: 600;
    flex-shrink: 0;
  }

  /* Formulário */
  .modal-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .form-group {
    width: 100%;
  }

  .form-input {
    width: 100%;
    padding: 0.875rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 10px;
    color: white;
    font-size: 0.9375rem;
    font-family: inherit;
    transition: all 0.2s;
  }

  .form-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .form-input:focus {
    outline: none;
    border-color: rgb(249, 115, 22);
    background: rgba(249, 115, 22, 0.05);
