  .modal-close-text {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    padding: 0.5rem;
    margin-top: 0.5rem;
    transition: color 0.2s;
    align-self: center;
  }

  .modal-close-text:hover {
