  }

  /* Responsivo */
  @media (max-width: 700px) {
    .modal-container {
      grid-template-columns: 1fr;
      max-width: 400px;
    }

    .modal-image {
      display: none;
    }

    .modal-content {
      padding: 2rem 1.5rem;
    }

    .modal-title {
      font-size: 1.375rem;
