<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const reportItems = document.querySelectorAll('.report-item');
    const reportImage = document.getElementById('report-image');
    const imageBasePath = '/videos/services/funnel-mapping/';

    reportItems.forEach(item => {
      item.addEventListener('click', () => {
        reportItems.forEach(i => i.classList.remove('active'));
        item.classList.add('active');
        const imageName = item.dataset.image;
        if (reportImage && imageName) {
          reportImage.style.opacity = '0';
          setTimeout(() => {
            reportImage.src = imageBasePath + imageName + '.webp';
            const h3 = item.querySelector('h3');
            if (h3) reportImage.alt = h3.textContent || '';
            reportImage.style.opacity = '1';
          }, 150);
        }
      });
    });

    const visualItems = document.querySelectorAll('.visual-item');
    const visualReportImage = document.getElementById('visual-report-image');

    visualItems.forEach(item => {
      item.addEventListener('click', () => {
        visualItems.forEach(i => i.classList.remove('active'));
        item.classList.add('active');
        const imageName = item.dataset.image;
        if (visualReportImage && imageName) {
          visualReportImage.style.opacity = '0';
          setTimeout(() => {
            visualReportImage.src = imageBasePath + imageName + '.webp';
            const h3 = item.querySelector('h3');
            if (h3) visualReportImage.alt = h3.textContent || '';
            visualReportImage.style.opacity = '1';
          }, 150);
        }
      });
    });

    const pricingToggle = document.getElementById('pricingToggle');
    const toggleLabels = document.querySelectorAll('.toggle-label');
    const parceladoElements = document.querySelectorAll('.parcelado');
    const avistaElements = document.querySelectorAll('.avista');

    if (pricingToggle) {
      pricingToggle.addEventListener('click', () => {
        const isActive = pricingToggle.classList.toggle('active');
        toggleLabels.forEach(label => {
          if ((label.dataset.label === 'avista' && isActive) || (label.dataset.label === 'parcelado' && !isActive)) {
            label.classList.add('active');
          } else {
            label.classList.remove('active');
          }
        });
        parceladoElements.forEach(el => el.classList.toggle('hidden', isActive));
        avistaElements.forEach(el => el.classList.toggle('hidden', !isActive));
      });
    }

    const comparisonToggle = document.getElementById('comparisonToggle');
    const comparisonTable = document.getElementById('comparisonTable');

    if (comparisonToggle && comparisonTable) {
      comparisonToggle.addEventListener('click', () => {
        comparisonToggle.classList.toggle('active');
        comparisonTable.classList.toggle('hidden');
      });
    }
  });
</script>
