---
import Layout from '../../../layouts/Layout.astro';
import FooterAds from '../../../components/layout/FooterAds.astro';
---

<Layout title="Mapa de Funil com Simulação de Lucro — Alex Donega" description="Mapeie e simule a lucratividade do seu funil antes de gastar 1 centavo com anúncios. Previsão de lucro real." hideHeader hideFooter>

<!-- 1. Banner de Aviso (NEW) -->
<div class="warning-banner">
  <div class="warning-content">
    <span class="warning-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
    </span>
    <span class="warning-text">6 vagas disponíveis este mês — <a href="#pricing">Simule seu lucro antes que feche</a></span>
  </div>
</div>

<!-- 2. Hero + Prova Social (MODIFIED) -->
<section class="funnel-hero">
  <div class="hero-bg">
    <div class="grid-pattern"></div>
    <svg class="funnel-viz" viewBox="0 0 1200 800" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path id="path1" d="M100 200 Q300 150 500 250 T900 200" stroke="rgba(249, 115, 22, 0.2)" stroke-width="2" stroke-dasharray="10 10" />
      <path id="path2" d="M150 400 Q400 350 600 450 T1000 400" stroke="rgba(249, 115, 22, 0.15)" stroke-width="2" stroke-dasharray="8 8" />
      <path id="path3" d="M200 600 Q450 550 700 650 T1100 600" stroke="rgba(249, 115, 22, 0.1)" stroke-width="2" stroke-dasharray="12 12" />

      <!-- Pulsing Nodes -->
      <circle r="4" fill="rgb(249, 115, 22)">
        <animateMotion dur="6s" repeatCount="indefinite">
          <mpath href="#path1" />
        </animateMotion>
      </circle>
      <circle r="3" fill="rgb(251, 146, 60)">
        <animateMotion dur="8s" repeatCount="indefinite">
          <mpath href="#path2" />
        </animateMotion>
      </circle>
      <circle r="5" fill="rgb(234, 88, 12)">
        <animateMotion dur="5s" repeatCount="indefinite">
          <mpath href="#path3" />
        </animateMotion>
      </circle>
    </svg>
    <div class="bg-glow"></div>
  </div>
  <div class="container">
    <div class="hero-content">
      <span class="hero-eyebrow">Simulação de Lucratividade</span>
      <h1 class="hero-title">
        Descubra o Potencial de Lucro do Seu Funil <span class="text-gradient">Antes de Investir</span>
      </h1>
      <p class="hero-subtitle">
        Simulação matemática da lucratividade do seu negócio — cenários pessimista, provável e otimista — para você decidir com dados, não com achismo
      </p>
      <!-- Proof badges (NEW in hero) -->
      <div class="hero-social-proof">
        <div class="proof-badge">
          <span class="proof-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </span>
          <span class="proof-text">+200 funis mapeados</span>
        </div>
        <div class="proof-badge">
          <span class="proof-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </span>
          <span class="proof-text">15+ anos validando funis de alta escala</span>
        </div>
      </div>
      <div class="hero-stars">
        <svg viewBox="0 0 24 24" fill="rgb(251, 191, 36)" width="20" height="20"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="rgb(251, 191, 36)" width="20" height="20"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="rgb(251, 191, 36)" width="20" height="20"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="rgb(251, 191, 36)" width="20" height="20"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg viewBox="0 0 24 24" fill="rgb(251, 191, 36)" width="20" height="20"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      </div>
      <div class="hero-cta">
        <a href="#pricing" class="btn-primary">
          Simular meu lucro agora
          <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- 3. Prova Social Inicial (NEW) -->
<section class="funnel-social-proof-stats">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Comprovado</span>
      <h2 class="section-title">Resultados que comprovam</h2>
    </div>
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-number">+200</span>
        <span class="stat-label">funis mapeados</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">R$ 15M+</span>
        <span class="stat-label">em perdas evitadas</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">97%</span>
        <span class="stat-label">de taxa de satisfação</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">3x</span>
        <span class="stat-label">mais escalabilidade média</span>
      </div>
    </div>
    <div class="section-cta">
      <a href="#pricing" class="btn-primary">
        Sim, meu negócio precisa disso
        <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- 4. Problema (EXISTING - KEEP AS IS) -->
<section class="funnel-problem">
  <div class="container">
    <div class="problem-content">
      <h2 class="problem-title">O Marketing Digital Mudou Para Sempre...</h2>
      <div class="problem-text">
        <p>Os dias em que um empreendedor podia lançar um funil e ter retorno da noite para o dia acabaram.</p>
        <p>CPM subindo. CPC subindo. Margem caindo. Lançar um funil sem simular antes é queimar dinheiro no escuro — e você sabe disso.</p>
        <p class="highlight">O que você precisa são <strong>LUCROS PREVISÍVEIS</strong> do seu funil.</p>
        <p>E é aqui que o <span class="text-gradient">Mapeamento de Funil</span> entra.</p>
        <div class="problem-highlight">
          <span class="highlight-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </span>
          <span>Clientes descobriram que estavam <strong>queimando dinheiro em anúncios, copy e sites</strong> — sem nem saber onde estava o vazamento.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. Mecanismo de Falsa Solução (NEW) -->
<section class="funnel-false-solution">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">O Problema Real</span>
      <h2 class="section-title">Já perdeu tempo e dinheiro tentando essas soluções?</h2>
    </div>
    <div class="false-solution-grid">
      <div class="false-solution-card">
        <div class="false-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
        </div>
        <h3>Fazer contas no Excel</h3>
        <ul>
          <li>Planilhas confusas que ninguém entende</li>
          <li>Números que não refletem a realidade</li>
        </ul>
      </div>
      <div class="false-solution-card">
        <div class="false-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg>
        </div>
        <h3>Copiar funis de concorrentes</h3>
        <ul>
          <li>O que funciona para outros pode não funcionar para você</li>
          <li>Sem contexto do seu negócio</li>
        </ul>
      </div>
      <div class="false-solution-card">
        <div class="false-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3>Lançar e corrigir depois</h3>
        <ul>
          <li>Dinheiro queimado em testes</li>
          <li>Frustração com resultados ruins</li>
        </ul>
      </div>
    </div>
    <p class="false-solution-transition">O problema não é seu esforço, são as ferramentas que você usa...</p>
    <div class="section-cta">
      <a href="#pricing" class="btn-primary">
        Descobrir como ter lucro previsível
        <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

