---
import Layout from '../../../layouts/Layout.astro';
import FooterAds from '../../../components/layout/FooterAds.astro';
import WhatsAppButton from '../../../components/ui/WhatsAppButton.astro';
import ExitIntentModal from '../../../components/ui/ExitIntentModal';
import FunnelHero from '../../../components/funnel/FunnelHero.astro';
import FunnelMethodology from '../../../components/funnel/FunnelMethodology.astro';
import FunnelDeliverables from '../../../components/funnel/FunnelDeliverables.astro';
import FunnelPackageComplete from '../../../components/funnel/FunnelPackageComplete.astro';
import FunnelAbout from '../../../components/funnel/FunnelAbout.astro';
import FunnelPricing from '../../../components/funnel/FunnelPricing.astro';
import FunnelGuaranteeDual from '../../../components/funnel/FunnelGuaranteeDual.astro';
import FunnelFaq from '../../../components/funnel/FunnelFaq.astro';
import FunnelFinalCta from '../../../components/funnel/FunnelFinalCta.astro';
import SocialProofToast from '../../../components/ui/SocialProofToast.astro';
import '../../../styles/funnel.css';
---

<Layout title="Mapa de Funil com Simulação de Lucro — Alex Donega" description="Descubra por que seu funil não converte — mapeie, simule e pare de queimar R$ 1k+ por mês em anúncios sem retorno." hideHeader hideFooter>

<!-- 1. Hero -->
<FunnelHero />

<!-- 2. Para Quem E (qualificacao imediata) -->
<section class="funnel-audience">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Para Quem É</span>
      <h2 class="section-title">Feito para quem investe R$ 1k+ em anúncios todo mês</h2>
    </div>
    <p class="section-intro" style="text-align: center; margin-bottom: 3rem; color: var(--text-secondary);">Não importa seu nicho. Se você tem funil que precisa gerar lucro previsível, isso é para você:</p>
    <div class="audience-tags">
      <div class="audience-tag">
        <div class="tag-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
          </svg>
        </div>
        <h3>Coaches & Consultores</h3>
      </div>
      <div class="audience-tag">
        <div class="tag-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>
          </svg>
        </div>
        <h3>Criadores & Afiliados</h3>
      </div>
      <div class="audience-tag">
        <div class="tag-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 21h18"/><path d="M9 8h1"/><path d="M9 12h1"/><path d="M9 16h1"/><path d="M14 8h1"/><path d="M14 12h1"/><path d="M14 16h1"/>
            <path d="M5 21V5a2 2 0 012-2h10a2 2 0 012 2v16"/>
          </svg>
        </div>
        <h3>Empresas B2B</h3>
      </div>
      <div class="audience-tag">
        <div class="tag-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3>Negócios Locais</h3>
      </div>
      <div class="audience-tag">
        <div class="tag-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
          </svg>
        </div>
        <h3>Criadores de Cursos</h3>
      </div>
      <div class="audience-tag">
        <div class="tag-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>
          </svg>
        </div>
        <h3>Agências de Marketing</h3>
      </div>
      <div class="audience-tag">
        <div class="tag-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/>
          </svg>
        </div>
        <h3>Freelancers</h3>
      </div>
      <div class="audience-tag">
        <div class="tag-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
          </svg>
        </div>
        <h3>SaaS & MicroSaaS</h3>
      </div>
    </div>
  </div>
</section>

<!-- 3. Prova Social Stats -->
<section class="funnel-social-proof-stats">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Prova Social Real</span>
      <h2 class="section-title">Validado por +200 funis. R$ 15M evitados.</h2>
    </div>
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-number">+200</span>
        <span class="stat-label">empreendedores evitaram queimar dinheiro</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">R$ 15M+</span>
        <span class="stat-label">em prejuízos evitados em 2024-2025</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">97%</span>
        <span class="stat-label">retornam para escalar ou otimizar novamente</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">3x</span>
        <span class="stat-label">mais rápido para escalar (vs. tentativa e erro)</span>
      </div>
    </div>
  </div>
</section>

<!-- 4. VIP Testimonials (autoridade cedo) -->
<section class="funnel-vip-testimonials">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Resultados reais, nomes reais</span>
      <h2 class="section-title">Empreendedores que pararam de adivinhar<br>e começaram a calcular</h2>
      <p class="section-subtitle">Cada caso aqui parou de queimar verba e passou a ter clareza total sobre cada etapa do funil.</p>
    </div>

    <div class="vip-list">

      <!-- Diego Carmona -->
      <div class="vip-card vip-featured">
        <div class="vip-photo">
          <img src="/img/testimonials/diego-carmona-nasdaq-ipo.webp" alt="Diego Carmona na Nasdaq" width="340" height="320" loading="lazy" />
          <div class="vip-photo-glow"></div>
        </div>
        <div class="vip-info">
          <div class="vip-metric">
            <span class="vip-metric-value">R$150M+</span>
            <span class="vip-metric-label">Valuation de Portfólio</span>
          </div>
          <h3 class="vip-name">Diego Carmona</h3>
          <p class="vip-role">Co-founder Leadlovers · IPO na Nasdaq</p>
          <p class="vip-role-highlight">Shark/Investidor · 21+ Startups no Portfólio</p>
          <p class="vip-desc">
            Alex projetou e executou diversos funis de alta conversão para a Joint Venture de Diego Carmona, o empreendedor que liderou o exit milionário da Leadlovers com IPO na Nasdaq e hoje investe em mais de 21 startups com valuation total superior a R$150 milhões.
          </p>
        </div>
      </div>

      <!-- Sergio Barbosa -->
      <div class="vip-card">
        <div class="vip-photo">
          <img src="/img/testimonials/sergio-barbosa-waseller-placa-10milhoes.webp" alt="Sergio Barbosa - Waseller" width="280" height="260" loading="lazy" />
          <div class="vip-photo-glow"></div>
        </div>
        <div class="vip-info">
          <div class="vip-metric">
            <span class="vip-metric-value">R$1 Milhão</span>
            <span class="vip-metric-label">de receita recorrente mensal</span>
          </div>
          <h3 class="vip-name">Sergio Barbosa</h3>
          <p class="vip-role">Founder · Waseller</p>
          <p class="vip-desc">
            Com a arquitetura de funil desenvolvida por Alex, Sergio escalou o Waseller, sua plataforma SaaS, até atingir hoje R$1 milhão em receita recorrente mensal.
          </p>
        </div>
      </div>

      <!-- JP Galvão -->
      <div class="vip-card">
        <div class="vip-photo">
          <img src="/img/testimonials/jp-savings-club-evento.webp" alt="JP Galvão - Savings Club" width="280" height="260" loading="lazy" />
          <div class="vip-photo-glow"></div>
        </div>
        <div class="vip-info">
          <div class="vip-metric">
            <span class="vip-metric-value">1ª</span>
            <span class="vip-metric-label">Venda nos EUA</span>
          </div>
          <h3 class="vip-name">JP Galvão</h3>
          <p class="vip-role">CEO · Savings Club</p>
          <p class="vip-desc">
            Alex validou o funil da primeira empresa de consórcio dos EUA e participou diretamente da histórica primeira venda de consórcio em território americano, abrindo um mercado completamente novo.
          </p>
        </div>
      </div>

      <!-- Christian Barbosa -->
      <div class="vip-card">
        <div class="vip-photo">
          <img src="/img/testimonials/christian-barbosa-neotriad-palestra.webp" alt="Christian Barbosa - Neotriad" width="280" height="260" loading="lazy" />
          <div class="vip-photo-glow"></div>
        </div>
        <div class="vip-info">
          <div class="vip-metric">
            <span class="vip-metric-value">2026</span>
            <span class="vip-metric-label">Novo Funil de Aquisição</span>
          </div>
          <h3 class="vip-name">Christian Barbosa</h3>
          <p class="vip-role">Maior Especialista em Produtividade do Brasil · Neotriad</p>
          <p class="vip-desc">
            Alex reestruturou o funil de aquisição de clientes da Neotriad para 2026, realizando diversas simulações de cenários para trazer previsibilidade financeira e otimizar o fluxo de caixa da operação.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- 5. Problema -->
<section class="funnel-problem">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">O Problema Real</span>
      <h2 class="section-title">Seu último funil falhou porque você não simulou.</h2>
    </div>
    <div class="problem-content">
      <div class="problem-text">
        <p>Vamos ser honestos: você já queimou dinheiro em anúncios e viu sua margem desaparecer.</p>
        <p>E a pior parte? Você só descobre que o funil não vai dar certo <strong>depois</strong> de gastar 3-5k.</p>
        <p class="highlight">Você não precisa de mais tráfego. Você já gasta 1k+ por mês. <strong>O problema é não saber onde o dinheiro está vazando.</strong></p>
        <div class="problem-highlight">
          <span class="highlight-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </span>
          <span>Clientes nossos descobriram que estavam <strong>perdendo R$ 500-2k por dia em anúncios inúteis</strong>. E ninguém tinha avisado isso para eles.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 6. Falsa Solução + Antes e Depois (fundido) -->
<section class="funnel-false-solution">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">O Problema Real</span>
      <h2 class="section-title">Por que essas "soluções" custam R$ 5k-15k em prejuízos</h2>
    </div>
    <div class="false-solution-grid">
      <div class="false-solution-card">
        <div class="false-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
        </div>
        <h3>Planilhas que ninguém consegue manter</h3>
        <ul>
          <li>Você atualiza 1x, depois largará de lado</li>
          <li>Números de 2 meses atrás guiam decisões de hoje</li>
        </ul>
      </div>
      <div class="false-solution-card">
        <div class="false-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg>
        </div>
        <h3>Funis copiados quebram em 30 dias</h3>
        <ul>
          <li>Seu público é diferente</li>
          <li>Seus preços, mercado e produto são únicos • Resultado: funil que converte 0,5% em vez de 3%</li>
        </ul>
      </div>
      <div class="false-solution-card">
        <div class="false-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3>Testes custam R$ 10k-20k em prejuízos</h3>
        <ul>
          <li>90% dos empreendedores não conseguem fazer testes direito</li>
          <li>Ficam girando em roda</li>
        </ul>
      </div>
    </div>

    <!-- Antes e Depois (integrado) -->
    <div class="before-after-merged">
      <div class="before-after-grid">
        <div class="before-column">
          <h3 class="ba-title ba-before-title">ANTES <span>Sem simulação</span></h3>
          <ul class="ba-list">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
              <span>Você espera que funcione (mas não tem certeza)</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
              <span>Tenta adivinhar os números</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
              <span>Aprende errando (caro)</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
              <span>Medo de investir mais</span>
            </li>
          </ul>
        </div>
        <div class="ba-divider">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="32" height="32"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </div>
        <div class="after-column">
          <h3 class="ba-title ba-after-title">DEPOIS <span>Com MAPS</span></h3>
          <ul class="ba-list">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              <span>Você sabe exatamente o quanto vai ganhar</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              <span>Calcula 3 cenários com precisão</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              <span>Sabe exatamente onde o funil está vazando</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
              <span>Confiança para escalar (com dados)</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <p class="false-solution-transition">O que você realmente precisa é de previsibilidade no ciclo que já está rodando...</p>

    <div class="section-cta section-cta-mid">
      <a href="#pricing" class="btn-primary">
        Quero simular meu funil
        <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- 8. O Serviço -->
<section id="servico" class="funnel-what">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">O Serviço</span>
      <h2 class="section-title">De 'não sei se vai dar certo' para<br>'tenho 3 cenários calculados'</h2>
    </div>
    <div class="what-content">
      <p class="what-intro">
        A proposta não é só criar um mapa visual do seu funil. É <strong>simular a lucratividade real</strong> e descobrir exatamente qual etapa está consumindo verba sem converter.
      </p>
      <div class="what-list">
        <div class="what-step">
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <div class="step-text">
            <h3>Prever o potencial de lucro</h3>
            <p>Simule cenários e entenda quanto seu funil pode gerar</p>
          </div>
          <div class="step-number">01</div>
        </div>
        <div class="what-step">
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
          <div class="step-text">
            <h3>Identificar vazamentos</h3>
            <p>Encontre pontos onde você está perdendo dinheiro</p>
          </div>
          <div class="step-number">02</div>
        </div>
        <div class="what-step">
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div class="step-text">
            <h3>Garantir lucro desde o início</h3>
            <p>Só lance quando tiver certeza que vai dar certo</p>
          </div>
          <div class="step-number">03</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 9. Metodologia MAPS -->
<FunnelMethodology />

<!-- 10. Resultados Reais -->
<section class="funnel-results">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">Resultados Reais</span>
      <h2 class="section-title">Os 3 resultados que surpreendem os clientes</h2>
    </div>
    <div class="results-grid">
      <div class="result-card result-leak">
        <div class="result-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <h3>Vazamentos Identificados</h3>
        <p>Clientes descobriram que estavam <strong>perdendo dinheiro sem saber</strong> e reformularam todo o trabalho de marketing após o mapeamento.</p>
      </div>
      <div class="result-card result-scale">
        <div class="result-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h3>Escalabilidade Acelerada</h3>
        <p>Outros identificaram gargalos que impediam o crescimento e <strong>aumentaram a velocidade de escala em até 3x</strong>.</p>
      </div>
      <div class="result-card result-profit">
        <div class="result-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <h3>Lucro Previsível</h3>
        <p>Com a simulação de cenários, clientes passaram a <strong>investir com confiança</strong>, sabendo exatamente o retorno esperado.</p>
      </div>
    </div>

    <div class="section-cta section-cta-mid">
      <a href="#pricing" class="btn-primary">
