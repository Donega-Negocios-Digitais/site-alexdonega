    const INPUT_NORMAL_BG = 'rgba(255,255,255,0.05)';

    function mascaraWhatsApp(v: string): string {
      v = v.replace(/\D/g, '').slice(0, 11);
      if (v.length <= 10) return v.replace(/(\d{2})(\d{4})(\d{0,4})/, '($1) $2-$3');
      return v.replace(/(\d{2})(\d{5})(\d{0,4})/, '($1) $2-$3');
    }

    function validarNome(): boolean {
      const v = campoNome.value.trim();
      if (!v || v.length < 2) {
        setErro(campoNome, erroNome, 'Informe seu nome completo (mínimo 2 caracteres).');
        return false;
      }
      limparErro(campoNome, erroNome);
      return true;
    }

    function validarWhatsApp(): boolean {
      const digits = campoWhatsApp.value.replace(/\D/g, '');
      const ddd = parseInt(digits.slice(0, 2), 10);
      if (digits.length < 10 || digits.length > 11 || ddd < 11 || ddd > 99) {
        setErro(campoWhatsApp, erroWhatsApp, 'Informe um WhatsApp válido com DDD (ex: (45) 99999-9999).');
        return false;
      }
      limparErro(campoWhatsApp, erroWhatsApp);
      return true;
    }

    function validarEmail(): boolean {
      const v = campoEmail.value.trim();
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) {
        setErro(campoEmail, erroEmail, 'Informe um e-mail válido.');
        return false;
      }
      limparErro(campoEmail, erroEmail);
      return true;
    }

    function setErro(input: HTMLInputElement, erroEl: HTMLElement, msg: string) {
      input.style.borderColor = INPUT_ERROR_BORDER;
      input.style.background = INPUT_ERROR_BG;
      erroEl.textContent = msg;
      erroEl.classList.remove('hidden');
    }

    function limparErro(input: HTMLInputElement, erroEl: HTMLElement) {
      input.style.borderColor = INPUT_NORMAL_BORDER;
      input.style.background = INPUT_NORMAL_BG;
      erroEl.classList.add('hidden');
      erroEl.textContent = '';
    }

    function atualizarSubmit() {
      const valido = campoNome.value.trim().length >= 2
        && campoWhatsApp.value.replace(/\D/g, '').length >= 10
        && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(campoEmail.value.trim());
      submitBtn.disabled = !valido;
      submitBtn.style.opacity = valido ? '1' : '0.5';
      submitBtn.style.cursor = valido ? 'pointer' : 'not-allowed';
      if (submitHint) submitHint.style.display = valido ? 'none' : 'block';
      if (trustLine) trustLine.classList.toggle('hidden', !valido);
      if (valido && !submitBtn.dataset.pulsed) {
        submitBtn.style.animation = 'pricingCtaPulse 1s ease-out 1';
        submitBtn.dataset.pulsed = 'true';
      }
    }

    function trackFormStarted(field: string) {
      if (!formStarted) {
        formStarted = true;
        (window as any).dataLayer?.push({ event: 'pricing_form_started', pacote: pacoteAtual, first_field: field });
      }
    }

    campoNome.addEventListener('input', () => { trackFormStarted('nome'); validarNome(); atualizarSubmit(); });
    campoWhatsApp.addEventListener('input', () => {
      trackFormStarted('whatsapp');
      campoWhatsApp.value = mascaraWhatsApp(campoWhatsApp.value);
      validarWhatsApp();
      atualizarSubmit();
    });
    campoEmail.addEventListener('input', () => { trackFormStarted('email'); validarEmail(); atualizarSubmit(); });

    function renderEntregas(entregas: string[]) {
      modalEntregas.innerHTML = '';
      entregas.forEach(item => {
        const div = document.createElement('div');
        div.className = 'flex items-start gap-2';
        div.innerHTML = `
          <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="rgb(52,211,153)" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-sm" style="color: rgba(255,255,255,0.7);">${item}</span>
        `;
        modalEntregas.appendChild(div);
      });
    }

    // --- Abrir modal ---
    document.querySelectorAll<HTMLButtonElement>('[data-pacote]').forEach(btn => {
      btn.addEventListener('click', () => {
        pacoteAtual = btn.dataset.pacote || '';
        formStarted = false;
        const pacote = PACOTES[pacoteAtual];

        if (pacote) {
          titulo.textContent = pacote.titulo;
          modalPreco.textContent = pacote.preco;
          modalPrecoAvista.textContent = pacote.precoAvista;
          if (pacote.badge) {
            modalBadge.textContent = pacote.badge;
            modalBadge.classList.remove('hidden');
          } else {
            modalBadge.classList.add('hidden');
          }
          renderEntregas(pacote.entregas);
          submitText.textContent = pacote.cta;
        } else {
          titulo.textContent = pacoteAtual;
          modalPreco.textContent = '';
          modalPrecoAvista.textContent = '';
          modalBadge.classList.add('hidden');
          modalEntregas.innerHTML = '';
          submitText.textContent = 'Garantir minha vaga';
        }

        alertEl.classList.add('hidden');
        alertEl.textContent = '';
        modalSuccess.classList.add('hidden');
        form.style.display = '';
        submitBtn.dataset.pulsed = '';
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
        document.body.style.overflow = 'hidden';

        (window as any).dataLayer?.push({ event: 'pricing_modal_opened', pacote: pacoteAtual });

        setTimeout(() => campoNome.focus(), 50);
      });
    });

    // --- Fechar modal ---
    function fecharModal() {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      document.body.style.overflow = '';
      form.reset();
      [campoNome, campoWhatsApp, campoEmail].forEach(inp => {
        inp.style.borderColor = INPUT_NORMAL_BORDER;
        inp.style.background = INPUT_NORMAL_BG;
      });
      [erroNome, erroWhatsApp, erroEmail].forEach(el => {
        el.classList.add('hidden');
        el.textContent = '';
      });
      alertEl.classList.add('hidden');
      alertEl.textContent = '';
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.5';
      submitBtn.style.cursor = 'not-allowed';
      submitBtn.style.animation = '';
      if (submitHint) submitHint.style.display = 'block';
      if (trustLine) trustLine.classList.add('hidden');
    }

    closeBtn.addEventListener('click', fecharModal);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) fecharModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') fecharModal(); });

    // --- Focus trap ---
    const container = document.getElementById('modal-container') as HTMLElement;
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab' || overlay.classList.contains('hidden')) return;
      const focusable = container.querySelectorAll<HTMLElement>(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    });

    function getFriendlyError(errorMsg: string): string {
      const msg = errorMsg.toLowerCase();
      if (msg.includes('duplicate') || msg.includes('unique')) return 'Você já enviou uma solicitação. Entraremos em contato em breve.';
      if (msg.includes('network') || msg.includes('fetch')) return 'Erro de conexão. Verifique sua internet e tente novamente.';
      if (msg.includes('rate limit')) return 'Muitas tentativas. Aguarde um momento e tente novamente.';
      return 'Ocorreu um erro inesperado. Tente novamente ou entre em contato pelo WhatsApp.';
    }

    function showSuccess(nome: string) {
      form.style.display = 'none';
      if (submitHint) submitHint.style.display = 'none';
      if (trustLine) trustLine.classList.add('hidden');
      modalSuccess.classList.remove('hidden');

      const firstName = nome.split(' ')[0];
      modalSuccessTitle.textContent = `Excelente escolha, ${firstName}!`;

      let countdown = 3;
      countdownNumber.textContent = String(countdown);
      const interval = setInterval(() => {
        countdown--;
        countdownNumber.textContent = String(countdown);
        if (countdown <= 0) {
          clearInterval(interval);
          window.location.href = 'https://youtu.be/Mqfwbf3X8SA?si=_Jzi71GbFJ9mYXfL';
        }
      }, 1000);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nomeOk = validarNome();
      const waOk = validarWhatsApp();
      const emailOk = validarEmail();

      if (!nomeOk || !waOk || !emailOk) {
        alertEl.textContent = 'Corrija os campos destacados antes de continuar.';
        alertEl.classList.remove('hidden');
        return;
      }

      alertEl.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.5';
      submitBtn.style.cursor = 'not-allowed';
      spinner.classList.remove('hidden');
      const originalCta = submitText.textContent;
      submitText.textContent = 'Enviando...';

      const urlParams = new URLSearchParams(window.location.search);
      const leadData = {
        nome_completo: campoNome.value.trim(),
        email: campoEmail.value.trim(),
        whatsapp: campoWhatsApp.value.trim(),
        produto: pacoteAtual,
        formulario: 'modal_compra_mapa_funil',
        page_url: window.location.href,
        page_path: window.location.pathname,
        page_title: document.title,
        referrer: document.referrer || null,
        utm_source: urlParams.get('utm_source') || null,
        utm_medium: urlParams.get('utm_medium') || null,
        utm_campaign: urlParams.get('utm_campaign') || null,
        utm_term: urlParams.get('utm_term') || null,
        utm_content: urlParams.get('utm_content') || null,
        user_agent: navigator.userAgent,
        language: navigator.language,
        screen_width: window.screen.width,
        screen_height: window.screen.height,
        viewport_width: window.innerWidth,
        viewport_height: window.innerHeight,
      };

      const { error } = await supabase.from('leads').insert(leadData);

      spinner.classList.add('hidden');
      submitText.textContent = originalCta || 'Garantir minha vaga';

      if (error) {
        console.error('[Modal] Erro Supabase:', error);
        alertEl.textContent = getFriendlyError(error.message);
        alertEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        submitBtn.style.cursor = 'pointer';
        return;
      }

      showSuccess(campoNome.value.trim());
    });
  })();
</script>
