</style>



<!-- Modal de Captura de Leads -->
<div id="modal-overlay" class="fixed inset-0 bg-black/70 z-50 hidden flex items-center justify-center p-4">
  <div id="modal-container" class="rounded-3xl shadow-2xl max-w-lg w-full p-8 relative" style="max-height: 90vh; overflow-y: auto; background: #1a1a1a; border: 1px solid rgba(255,255,255,0.1);">
    <!-- Botão fechar -->
    <button id="modal-close" type="button" aria-label="Fechar modal" class="absolute top-4 right-4 text-gray-400 hover:text-gray-200 transition-colors">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- Header -->
    <div class="mb-6">
      <p class="text-sm font-semibold uppercase tracking-widest mb-1" style="color: rgb(249, 115, 22);">Pacote selecionado</p>
      <h2 id="modal-titulo" class="text-2xl font-bold text-white">—</h2>
      <p class="text-sm mt-1" style="color: rgba(255,255,255,0.6);">Preencha seus dados e entraremos em contato para confirmar sua vaga.</p>
    </div>

    <!-- Alert de erro -->
    <div id="modal-alert" class="hidden rounded-xl p-3 mb-4 text-sm" style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: rgb(248,113,113);"></div>

    <!-- Formulário -->
    <form id="modal-form" novalidate>
      <!-- Nome -->
      <div class="mb-4">
        <label for="campo-nome" class="block text-sm font-medium mb-1" style="color: rgba(255,255,255,0.8);">Nome completo</label>
        <input
          id="campo-nome"
          type="text"
          autocomplete="name"
          placeholder="Seu nome completo"
          class="w-full rounded-xl px-4 py-3 text-white transition-colors"
          style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15);"
          onfocus="this.style.borderColor='rgb(249,115,22)'; this.style.boxShadow='0 0 0 2px rgba(249,115,22,0.2)';"
          onblur="this.style.borderColor='rgba(255,255,255,0.15)'; this.style.boxShadow='none';"
        />
        <p id="erro-nome" class="hidden text-xs mt-1" style="color: rgb(248,113,113);"></p>
      </div>

      <!-- WhatsApp -->
      <div class="mb-4">
        <label for="campo-whatsapp" class="block text-sm font-medium mb-1" style="color: rgba(255,255,255,0.8);">WhatsApp</label>
        <input
          id="campo-whatsapp"
          type="tel"
          autocomplete="tel"
          placeholder="(11) 99999-9999"
          maxlength="15"
          class="w-full rounded-xl px-4 py-3 text-white transition-colors"
          style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15);"
          onfocus="this.style.borderColor='rgb(249,115,22)'; this.style.boxShadow='0 0 0 2px rgba(249,115,22,0.2)';"
          onblur="this.style.borderColor='rgba(255,255,255,0.15)'; this.style.boxShadow='none';"
        />
        <p id="erro-whatsapp" class="hidden text-xs mt-1" style="color: rgb(248,113,113);"></p>
      </div>

      <!-- E-mail -->
      <div class="mb-6">
        <label for="campo-email" class="block text-sm font-medium mb-1" style="color: rgba(255,255,255,0.8);">E-mail</label>
        <input
          id="campo-email"
          type="email"
          autocomplete="email"
          placeholder="seu@email.com"
          class="w-full rounded-xl px-4 py-3 text-white transition-colors"
          style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15);"
          onfocus="this.style.borderColor='rgb(249,115,22)'; this.style.boxShadow='0 0 0 2px rgba(249,115,22,0.2)';"
          onblur="this.style.borderColor='rgba(255,255,255,0.15)'; this.style.boxShadow='none';"
        />
        <p id="erro-email" class="hidden text-xs mt-1" style="color: rgb(248,113,113);"></p>
      </div>

      <!-- Botão submit -->
      <button
        id="modal-submit"
        type="submit"
        disabled
        class="w-full flex items-center justify-center gap-2 text-white font-semibold py-3 px-6 rounded-xl transition-all cursor-not-allowed"
        style="background: linear-gradient(135deg, rgb(249,115,22), rgb(234,88,12)); opacity: 0.5;"
      >
        <svg id="modal-spinner" class="hidden animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
        </svg>
        <span id="modal-submit-text">Solicitar Acesso</span>
      </button>
      <p id="modal-submit-hint" class="text-center text-xs mt-2" style="color: rgba(255,255,255,0.4);">Preencha todos os campos para continuar</p>
    </form>

    <!-- Success State (hidden by default) -->
    <div id="modal-success" class="hidden text-center py-8">
      <div class="w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center" style="background: rgba(52,211,153,0.15);">
        <svg width="32" height="32" fill="none" stroke="rgb(52,211,153)" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">Solicitação enviada!</h3>
      <p class="text-sm mb-1" style="color: rgba(255,255,255,0.7);">Entraremos em contato em breve.</p>
      <p id="modal-redirect-countdown" class="text-xs" style="color: rgba(255,255,255,0.4);">Redirecionando em <span id="countdown-number">3</span>s...</p>
    </div>
  </div>
</div>

<!-- Toast de sucesso -->
<div id="toast-sucesso" class="hidden fixed bottom-6 right-6 bg-green-600 text-white rounded-xl px-5 py-3 z-50 shadow-lg flex items-center gap-2 text-sm font-medium">
  <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
  </svg>
  Lead enviado com sucesso! Entraremos em contato em breve.
</div>

<script>
  import { supabase } from '../../../lib/supabase';

  (function () {
    let pacoteAtual = '';

    const overlay = document.getElementById('modal-overlay') as HTMLElement;
    const container = document.getElementById('modal-container') as HTMLElement;
    const titulo = document.getElementById('modal-titulo') as HTMLElement;
    const closeBtn = document.getElementById('modal-close') as HTMLButtonElement;
    const form = document.getElementById('modal-form') as HTMLFormElement;
    const alertEl = document.getElementById('modal-alert') as HTMLElement;
    const submitBtn = document.getElementById('modal-submit') as HTMLButtonElement;
    const submitText = document.getElementById('modal-submit-text') as HTMLElement;
    const submitHint = document.getElementById('modal-submit-hint') as HTMLElement;
    const spinner = document.getElementById('modal-spinner') as HTMLElement;
    const toastSucesso = document.getElementById('toast-sucesso') as HTMLElement;
    const modalSuccess = document.getElementById('modal-success') as HTMLElement;
    const countdownNumber = document.getElementById('countdown-number') as HTMLElement;

    const campoNome = document.getElementById('campo-nome') as HTMLInputElement;
    const campoWhatsApp = document.getElementById('campo-whatsapp') as HTMLInputElement;
    const campoEmail = document.getElementById('campo-email') as HTMLInputElement;
    const erroNome = document.getElementById('erro-nome') as HTMLElement;
    const erroWhatsApp = document.getElementById('erro-whatsapp') as HTMLElement;
    const erroEmail = document.getElementById('erro-email') as HTMLElement;

    const INPUT_ERROR_BORDER = 'rgb(239, 68, 68)';
    const INPUT_NORMAL_BORDER = 'rgba(255,255,255,0.15)';
    const INPUT_ERROR_BG = 'rgba(239,68,68,0.08)';
    const INPUT_NORMAL_BG = 'rgba(255,255,255,0.05)';

    // --- Máscara WhatsApp ---
    function mascaraWhatsApp(v: string): string {
      v = v.replace(/\D/g, '').slice(0, 11);
      if (v.length <= 10) return v.replace(/(\d{2})(\d{4})(\d{0,4})/, '($1) $2-$3');
      return v.replace(/(\d{2})(\d{5})(\d{0,4})/, '($1) $2-$3');
    }

    // --- Validações ---
    function validarNome(): boolean {
      const v = campoNome.value.trim();
      if (!v || v.length < 2) {
        setErro(campoNome, erroNome, 'Informe seu nome completo (mínimo 2 caracteres).');
        return false;
      }
      limparErro(campoNome, erroNome);
      return true;
    }

    function validarWhatsApp(): boolean {
      const digits = campoWhatsApp.value.replace(/\D/g, '');
      const ddd = parseInt(digits.slice(0, 2), 10);
      if (digits.length < 10 || digits.length > 11 || ddd < 11 || ddd > 99) {
        setErro(campoWhatsApp, erroWhatsApp, 'Informe um WhatsApp válido com DDD (ex: (45) 99999-9999).');
        return false;
      }
      limparErro(campoWhatsApp, erroWhatsApp);
      return true;
    }

    function validarEmail(): boolean {
      const v = campoEmail.value.trim();
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) {
        setErro(campoEmail, erroEmail, 'Informe um e-mail válido.');
        return false;
      }
      limparErro(campoEmail, erroEmail);
      return true;
    }

    function setErro(input: HTMLInputElement, erroEl: HTMLElement, msg: string) {
      input.style.borderColor = INPUT_ERROR_BORDER;
      input.style.background = INPUT_ERROR_BG;
      erroEl.textContent = msg;
      erroEl.classList.remove('hidden');
    }

    function limparErro(input: HTMLInputElement, erroEl: HTMLElement) {
      input.style.borderColor = INPUT_NORMAL_BORDER;
      input.style.background = INPUT_NORMAL_BG;
      erroEl.classList.add('hidden');
      erroEl.textContent = '';
    }

    function atualizarSubmit() {
      const valido = campoNome.value.trim().length >= 2
        && campoWhatsApp.value.replace(/\D/g, '').length >= 10
        && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(campoEmail.value.trim());
      submitBtn.disabled = !valido;
      submitBtn.style.opacity = valido ? '1' : '0.5';
      submitBtn.style.cursor = valido ? 'pointer' : 'not-allowed';
      if (submitHint) submitHint.style.display = valido ? 'none' : 'block';
    }

    // --- Eventos de input ---
    campoNome.addEventListener('input', () => { validarNome(); atualizarSubmit(); });
    campoWhatsApp.addEventListener('input', () => {
      campoWhatsApp.value = mascaraWhatsApp(campoWhatsApp.value);
      validarWhatsApp();
      atualizarSubmit();
    });
    campoEmail.addEventListener('input', () => { validarEmail(); atualizarSubmit(); });

    // --- Abrir modal ---
    document.querySelectorAll<HTMLButtonElement>('[data-pacote]').forEach(btn => {
      btn.addEventListener('click', () => {
        pacoteAtual = btn.dataset.pacote || '';
        titulo.textContent = pacoteAtual;
        alertEl.classList.add('hidden');
        alertEl.textContent = '';
        modalSuccess.classList.add('hidden');
        form.style.display = '';
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
        setTimeout(() => campoNome.focus(), 50);
      });
    });

    // --- Fechar modal ---
    function fecharModal() {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      form.reset();
      [campoNome, campoWhatsApp, campoEmail].forEach(inp => {
        inp.style.borderColor = INPUT_NORMAL_BORDER;
        inp.style.background = INPUT_NORMAL_BG;
      });
      [erroNome, erroWhatsApp, erroEmail].forEach(el => {
        el.classList.add('hidden');
        el.textContent = '';
      });
      alertEl.classList.add('hidden');
      alertEl.textContent = '';
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.5';
      submitBtn.style.cursor = 'not-allowed';
      if (submitHint) submitHint.style.display = 'block';
    }

    closeBtn.addEventListener('click', fecharModal);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) fecharModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') fecharModal(); });

    // --- Friendly error messages ---
    function getFriendlyError(errorMsg: string): string {
      const msg = errorMsg.toLowerCase();
      if (msg.includes('duplicate') || msg.includes('unique')) return 'Você já enviou uma solicitação. Entraremos em contato em breve.';
      if (msg.includes('network') || msg.includes('fetch')) return 'Erro de conexão. Verifique sua internet e tente novamente.';
      if (msg.includes('rate limit')) return 'Muitas tentativas. Aguarde um momento e tente novamente.';
      return 'Ocorreu um erro inesperado. Tente novamente ou entre em contato pelo WhatsApp.';
    }

    // --- Success with countdown ---
    function showSuccess() {
      form.style.display = 'none';
      modalSuccess.classList.remove('hidden');
      let countdown = 3;
      countdownNumber.textContent = String(countdown);
      const interval = setInterval(() => {
        countdown--;
        countdownNumber.textContent = String(countdown);
        if (countdown <= 0) {
          clearInterval(interval);
          window.location.href = 'https://youtu.be/Mqfwbf3X8SA?si=_Jzi71GbFJ9mYXfL';
        }
      }, 1000);
    }

    // --- Submit ---
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nomeOk = validarNome();
      const waOk = validarWhatsApp();
      const emailOk = validarEmail();

      if (!nomeOk || !waOk || !emailOk) {
        alertEl.textContent = 'Corrija os campos destacados antes de continuar.';
        alertEl.classList.remove('hidden');
        return;
      }

      alertEl.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.5';
      submitBtn.style.cursor = 'not-allowed';
      spinner.classList.remove('hidden');
      submitText.textContent = 'Enviando...';

      const urlParams = new URLSearchParams(window.location.search);
      const leadData = {
        nome_completo: campoNome.value.trim(),
        email: campoEmail.value.trim(),
        whatsapp: campoWhatsApp.value.trim(),
        produto: pacoteAtual,
        page_url: window.location.href,
        page_path: window.location.pathname,
        page_title: document.title,
        referrer: document.referrer || null,
        utm_source: urlParams.get('utm_source') || null,
        utm_medium: urlParams.get('utm_medium') || null,
        utm_campaign: urlParams.get('utm_campaign') || null,
        utm_term: urlParams.get('utm_term') || null,
        utm_content: urlParams.get('utm_content') || null,
        user_agent: navigator.userAgent,
        language: navigator.language,
        screen_width: window.screen.width,
        screen_height: window.screen.height,
        viewport_width: window.innerWidth,
        viewport_height: window.innerHeight,
      };

      const { error } = await supabase.from('leads').insert(leadData);

      spinner.classList.add('hidden');
      submitText.textContent = 'Solicitar Acesso';

      if (error) {
        console.error('[Modal] Erro Supabase:', error);
        alertEl.textContent = getFriendlyError(error.message);
        alertEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        submitBtn.style.cursor = 'pointer';
        return;
      }

      showSuccess();
    });
  })();
</script>
