                        <div class="modals-list">
                            <div class="modal-item">
                                <strong>Suspensão de Medicamento:</strong> Pop-up vermelho de tela cheia para urgências.
                            </div>
                            <div class="modal-item">
                                <strong>Importação em Lote:</strong> Geração automática de IDs via planilhas.
                            </div>
                            <div class="modal-item">
