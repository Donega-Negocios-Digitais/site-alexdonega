---
/**
 * /previews/badge.astro
 * Preview do componente Badge
 */
import Badge from '../../components/ui/Badge.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Preview - Badge</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      --bg-main: #0a0a0a;
      --bg-card: #141414;
      --text-primary: #ffffff;
      --text-secondary: #a3a3a3;
      --text-muted: #737373;
      --accent: #f97316;
      --border: #262626;
    }
    
    html, body {
      min-height: 100vh;
      background: var(--bg-main);
      color: var(--text-primary);
      font-family: system-ui, -apple-system, sans-serif;
    }
    
    body {
      padding: 2rem;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
      transition: color 0.2s;
    }
    
    .back-link:hover {
      color: var(--accent);
    }
    
    header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }
    
    h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    
    .description {
      color: var(--text-secondary);
      font-size: 1rem;
    }
    
    .section {
      margin-bottom: 3rem;
    }
    
    .section-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
    }
    
    .badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      margin-bottom: 1.5rem;
    }
    
    .preview-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 1.5rem;
    }
    
    .preview-card-title {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    
    .context-example {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem;
      background: #000;
      border-radius: 8px;
      margin-bottom: 1rem;
    }
    
    .context-example h3 {
      font-size: 1rem;
      font-weight: 600;
    }
    
    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    
    .code-block {
      background: #000;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-top: 1rem;
      font-family: 'Fira Code', 'Monaco', monospace;
      font-size: 0.875rem;
      color: var(--text-secondary);
      overflow-x: auto;
    }
    
    .props-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }
    
    .props-table th,
    .props-table td {
      padding: 0.75rem 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }
    
    .props-table th {
      color: var(--text-muted);
      font-weight: 500;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    
    .props-table td {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }
    
    .props-table code {
      background: rgba(249, 115, 22, 0.15);
      color: var(--accent);
      padding: 0.125rem 0.375rem;
      border-radius: 4px;
      font-size: 0.8125rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <a href="/previews/" class="back-link">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Voltar para componentes
    </a>
    
    <header>
      <h1>Badge</h1>
      <p class="description">Componente de badge/tag estilo shadcn/ui</p>
    </header>
    
    <!-- Variantes -->
    <section class="section">
      <h2 class="section-title">Variantes <code>variant</code></h2>
      
      <div class="preview-card">
        <div class="preview-card-title">Todas as variantes</div>
        <div class="badge-row">
          <Badge variant="default">Default</Badge>
          <Badge variant="secondary">Secondary</Badge>
          <Badge variant="outline">Outline</Badge>
          <Badge variant="destructive">Destructive</Badge>
        </div>
      </div>
    </section>
    
    <!-- Em Contexto -->
    <section class="section">
      <h2 class="section-title">Em Contexto</h2>
      
      <div class="preview-card">
        <div class="preview-card-title">Tags de artigo</div>
        <div class="context-example">
          <h3>Como criar componentes reutilizáveis</h3>
          <Badge variant="default">Astro</Badge>
          <Badge variant="secondary">Frontend</Badge>
        </div>
        
        <div class="context-example">
          <h3>Estado do projeto</div>
          <Badge variant="outline">Em Andamento</Badge>
          <Badge variant="destructive">Urgente</Badge>
        </div>
      </div>
    </section>
    
    <!-- Lista de Tags -->
    <section class="section">
      <h2 class="section-title">Lista de Tags</h2>
      
      <div class="preview-card">
        <div class="preview-card-title">Tags de um post</div>
        <div class="tag-list">
          <Badge>Astro</Badge>
          <Badge>React</Badge>
          <Badge>TypeScript</Badge>
          <Badge variant="secondary">Tailwind</Badge>
          <Badge variant="secondary">CSS</Badge>
          <Badge variant="outline">Performance</Badge>
        </div>
      </div>
    </section>
    
    <!-- Props -->
    <section class="section">
      <h2 class="section-title">Props</h2>
      
      <table class="props-table">
        <thead>
          <tr>
            <th>Prop</th>
            <th>Tipo</th>
            <th>Default</th>
            <th>Descrição</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>variant</code></td>
            <td><code>'default' | 'secondary' | 'outline' | 'destructive'</code></td>
            <td><code>'default'</code></td>
            <td>Estilo visual do badge</td>
          </tr>
          <tr>
            <td><code>class</code></td>
            <td><code>string</code></td>
            <td><code>''</code></td>
            <td>Classes CSS adicionais</td>
          </tr>
        </tbody>
      </table>
    </section>
    
    <!-- Código de Exemplo -->
    <section class="section">
      <h2 class="section-title">Exemplo de Uso</h2>
      
      <div class="code-block">
        <pre>---
import Badge from '../../components/ui/Badge.astro';
---

&lt;Badge&gt;Default&lt;/Badge&gt;
&lt;Badge variant="secondary"&gt;Secondary&lt;/Badge&gt;
&lt;Badge variant="outline"&gt;Outline&lt;/Badge&gt;
&lt;Badge variant="destructive"&gt;Destructive&lt;/Badge&gt;</pre>
      </div>
    </section>
  </div>
</body>
</html>
