---
/**
 * /previews/card.astro
 * Preview do componente Card
 */
import Card from '../../components/ui/Card.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Preview - Card</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      --bg-main: #0a0a0a;
      --bg-card: #141414;
      --text-primary: #ffffff;
      --text-secondary: #a3a3a3;
      --text-muted: #737373;
      --accent: #f97316;
      --border: #262626;
    }
    
    html, body {
      min-height: 100vh;
      background: var(--bg-main);
      color: var(--text-primary);
      font-family: system-ui, -apple-system, sans-serif;
    }
    
    body {
      padding: 2rem;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
      transition: color 0.2s;
    }
    
    .back-link:hover {
      color: var(--accent);
    }
    
    header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }
    
    h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    
    .description {
      color: var(--text-secondary);
      font-size: 1rem;
    }
    
    .section {
      margin-bottom: 3rem;
    }
    
    .section-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
    }
    
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    
    .card-content {
      padding: 1.5rem;
    }
    
    .card-content h3 {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }
    
    .card-content p {
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.6;
    }
    
    .code-block {
      background: #000;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-top: 1rem;
      font-family: 'Fira Code', 'Monaco', monospace;
      font-size: 0.875rem;
      color: var(--text-secondary);
      overflow-x: auto;
    }
    
    .props-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }
    
    .props-table th,
    .props-table td {
      padding: 0.75rem 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }
    
    .props-table th {
      color: var(--text-muted);
      font-weight: 500;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    
    .props-table td {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }
    
    .props-table code {
      background: rgba(249, 115, 22, 0.15);
      color: var(--accent);
      padding: 0.125rem 0.375rem;
      border-radius: 4px;
      font-size: 0.8125rem;
    }
  </style>
  <style is:inline>
    body.in-iframe .back-link,
    body.in-iframe header,
    body.in-iframe .section:has(.props-table),
    body.in-iframe .section:has(.code-block) { display: none !important; }
    body.in-iframe .container { max-width: 100%; }
    body.in-iframe body { padding: 1rem !important; }
    body.in-iframe .section { margin-bottom: 1rem !important; }
    body.in-iframe .card-grid { gap: 0.75rem !important; }
    body.in-iframe .card-content { padding: 0.75rem !important; }
    body.in-iframe .card-content h3 { font-size: 0.8rem !important; }
    body.in-iframe .card-content p { font-size: 0.7rem !important; }
  </style>
</head>
<body>
  <div class="container">
    <a href="/previews/" class="back-link">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Voltar para componentes
    </a>
    
    <header>
      <h1>Card</h1>
      <p class="description">Componente de card container estilo shadcn/ui</p>
    </header>
    
    <!-- Cards Básicos -->
    <section class="section">
      <h2 class="section-title">Cards sem Hover</h2>
      
      <div class="card-grid">
        <Card>
          <div class="card-content">
            <h3>Card Simples</h3>
            <p>Este é um card básico sem efeito de hover. Ideal para conteúdo estático.</p>
          </div>
        </Card>
        
        <Card>
          <div class="card-content">
            <h3>Card com Mais Conteúdo</h3>
            <p>Os cards podem conter qualquer tipo de conteúdo: texto, imagens, formulários, etc.</p>
          </div>
        </Card>
        
        <Card class="p-6">
          <h3>Card com Classe Customizada</h3>
          <p>Este card usa a prop class para adicionar padding customizado.</p>
        </Card>
      </div>
    </section>
    
    <!-- Cards com Hover -->
    <section class="section">
      <h2 class="section-title">Cards com Hover <code>hover={true}</code></h2>
      
      <div class="card-grid">
        <Card hover>
          <div class="card-content">
            <h3>Card Interativo</h3>
            <p>Passe o mouse para ver o efeito de hover. Ideal para cards clicáveis.</p>
          </div>
        </Card>
        
        <Card hover>
          <div class="card-content">
            <h3>Outro Card Hover</h3>
            <p>O efeito inclui elevação suave e mudança de sombra.</p>
          </div>
        </Card>
        
        <Card hover>
          <div class="card-content">
            <h3>Terceiro Card</h3>
            <p>Perfeito para grids de produtos, posts ou qualquer elemento interativo.</p>
          </div>
        </Card>
      </div>
    </section>
    
    <!-- Props -->
    <section class="section">
      <h2 class="section-title">Props</h2>
      
      <table class="props-table">
        <thead>
          <tr>
            <th>Prop</th>
            <th>Tipo</th>
            <th>Default</th>
            <th>Descrição</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>hover</code></td>
            <td><code>boolean</code></td>
            <td><code>false</code></td>
            <td>Ativa efeito de hover (elevação e sombra)</td>
          </tr>
          <tr>
            <td><code>class</code></td>
            <td><code>string</code></td>
            <td><code>''</code></td>
            <td>Classes CSS adicionais</td>
          </tr>
        </tbody>
      </table>
    </section>
    
    <!-- Código de Exemplo -->
    <section class="section">
      <h2 class="section-title">Exemplo de Uso</h2>
      
      <div class="code-block">
        <pre>---
import Card from '../../components/ui/Card.astro';
---

&lt;Card&gt;
  &lt;h3&gt;Conteúdo do Card&lt;/h3&gt;
  &lt;p&gt;Descrição aqui...&lt;/p&gt;
&lt;/Card&gt;

&lt;Card hover class="p-6"&gt;
  &lt;h3&gt;Card Interativo&lt;/h3&gt;
&lt;/Card&gt;</pre>
      </div>
    </section>
  </div>
  <script>
    if (window.self !== window.top) document.body.classList.add('in-iframe');
  </script>
</body>
</html>
