---
/**
 * /previews/index.astro
 * Página índice com grid de cards para todos os componentes reutilizáveis
 */

interface ComponentItem {
  name: string;
  slug: string;
  category: 'ui' | 'layout' | 'course' | 'blog';
  description: string;
  icon: string;
}

const components: ComponentItem[] = [
  // UI Components
  {
    name: 'Button',
    slug: 'button',
    category: 'ui',
    description: 'Botão com 6 variantes, 4 tamanhos e efeito shimmer',
    icon: 'button'
  },
  {
    name: 'Card',
    slug: 'card',
    category: 'ui',
    description: 'Card container com efeito hover opcional',
    icon: 'card'
  },
  {
    name: 'Badge',
    slug: 'badge',
    category: 'ui',
    description: 'Badge/tag com 4 variantes de estilo',
    icon: 'badge'
  },
  {
    name: 'Animated Background',
    slug: 'animated-background',
    category: 'ui',
    description: 'Fundo animado com linhas SVG em movimento',
    icon: 'animation'
  },
  // Layout Components
  {
    name: 'Header',
    slug: 'header',
    category: 'layout',
    description: 'Navegação responsiva com menu mobile',
    icon: 'header'
  },
  {
    name: 'Footer Principal',
    slug: 'footer',
    category: 'layout',
    description: 'Footer completo com links e informações',
    icon: 'footer'
  },
  {
    name: 'Footer Ads',
    slug: 'footer-ads',
    category: 'layout',
    description: 'Footer com área para anúncios',
    icon: 'ads'
  },
  {
    name: 'Footer Simples',
    slug: 'footer-simples',
    category: 'layout',
    description: 'Footer minimalista para páginas de conversão',
    icon: 'footer'
  },
  // Course Components
  {
    name: 'Course FAQ Section',
    slug: 'course-faq',
    category: 'course',
    description: 'Seção de perguntas frequentes com acordeão',
    icon: 'faq'
  },
  {
    name: 'Course Final CTA',
    slug: 'course-final-cta',
    category: 'course',
    description: 'CTA final com variantes de cor (default, obsidian, gsd)',
    icon: 'cta'
  },
  // Blog Components
  {
    name: 'Post Card',
    slug: 'post-card',
    category: 'blog',
    description: 'Card de post do blog com imagem, título e metadata',
    icon: 'post'
  },
];

const categoryLabels = {
  ui: 'UI',
  layout: 'Layout',
  course: 'Course',
  blog: 'Blog'
};

const categoryColors = {
  ui: '#f97316',
  layout: '#3b82f6',
  course: '#10b981',
  blog: '#8b5cf6'
};

const categoryIcons = {
  ui: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  layout: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`,
  course: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
  blog: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`
};

const stats = [
  { value: components.length.toString(), label: 'Componentes' },
  { value: '4', label: 'Categorias' },
  { value: '11', label: 'Arquivos' },
  { value: '100%', label: 'Reutilizável' }
];
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Componentes Reutilizáveis - Preview</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      --bg-main: #0a0a0a;
      --bg-card: #1a1a1a;
      --bg-card-hover: #222222;
      --text-primary: #ffffff;
      --text-secondary: rgba(255, 255, 255, 0.7);
      --text-muted: rgba(255, 255, 255, 0.5);
      --accent: #d87757;
      --accent-hover: #e8866a;
      --border: #2a2a2a;
      --border-hover: #3a3a3a;
    }
    
    html {
      scroll-behavior: smooth;
    }
    
    body {
      min-height: 100vh;
      background: var(--bg-main);
      color: var(--text-primary);
      font-family: 'Geist', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.5;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 100px 24px 60px;
    }
    
    /* Header */
    .page-header {
      text-align: center;
      margin-bottom: 60px;
    }
    
    .page-title {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 12px;
      line-height: 1.2;
    }
    
    .page-subtitle {
      color: var(--text-secondary);
      font-size: 1.1rem;
      max-width: 500px;
      margin: 0 auto 24px;
    }
    
    .version-badge {
      display: inline-block;
      background: rgba(216, 119, 87, 0.15);
      color: var(--accent);
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 0.875rem;
      font-weight: 500;
    }
    
    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 16px;
      margin-bottom: 40px;
    }
    
    .stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      transition: all 0.2s;
    }
    
    .stat-card:hover {
      border-color: var(--border-hover);
      transform: translateY(-2px);
    }
    
    .stat-value {
      font-size: 2rem;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 4px;
    }
    
    .stat-label {
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    
    /* Sticky Navigation */
    .nav-sticky {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
      margin-bottom: 40px;
      padding: 16px 20px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      position: sticky;
      top: 80px;
      z-index: 100;
    }
    
    .nav-item {
      padding: 8px 16px;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-secondary);
      background: var(--bg-main);
      border: 1px solid var(--border);
      border-radius: 6px;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s;
    }
    
    .nav-item:hover,
    .nav-item.active {
      color: var(--accent);
      border-color: var(--accent);
      background: rgba(216, 119, 87, 0.1);
    }
    
    /* Section */
    .section {
      margin-bottom: 60px;
    }
    
    .section-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }
    
    .section-icon {
      width: 28px;
      height: 28px;
      color: var(--accent);
    }
    
    .section-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
    }
    
    .section-count {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-left: auto;
    }
    
    /* Components Grid */
    .components-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
    }
    
    .component-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      text-decoration: none;
      color: inherit;
      transition: all 0.2s;
      display: flex;
      flex-direction: column;
    }
    
    .component-card:hover {
      background: var(--bg-card-hover);
      border-color: var(--accent);
      transform: translateY(-2px);
    }
    
    .card-icon {
      width: 48px;
      height: 48px;
      background: rgba(216, 119, 87, 0.1);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
      color: var(--accent);
    }
    
    .card-icon svg {
      width: 24px;
      height: 24px;
    }
    
    .card-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 8px;
    }
    
    .card-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text-primary);
    }
    
    .card-category {
      font-size: 0.7rem;
      font-weight: 500;
      padding: 4px 10px;
      border-radius: 100px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    
    .card-category.ui { background: rgba(249, 115, 22, 0.15); color: #f97316; }
    .card-category.layout { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
    .card-category.course { background: rgba(16, 185, 129, 0.15); color: #10b981; }
    .card-category.blog { background: rgba(139, 92, 246, 0.15); color: #8b5cf6; }
    
    .card-description {
      color: var(--text-secondary);
      font-size: 0.9rem;
      line-height: 1.5;
      flex: 1;
    }
    
    .card-footer {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
      color: var(--accent);
      font-size: 0.875rem;
      font-weight: 500;
    }
    
    .card-footer svg {
      width: 16px;
      height: 16px;
      transition: transform 0.2s;
    }
    
    .component-card:hover .card-footer svg {
      transform: translateX(4px);
    }
    
    /* Back Link */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.875rem;
      margin-bottom: 20px;
      padding: 8px 16px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      transition: all 0.2s;
    }
    
    .back-link:hover {
      color: var(--accent);
      border-color: var(--accent);
    }
    
    /* Hidden utility */
    .hidden {
      display: none !important;
    }
    
    /* Responsive */
    @media (min-width: 768px) {
      .page-title {
        font-size: 3rem;
      }
      
      .stats-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }
    
    @media (min-width: 1024px) {
      .page-title {
        font-size: 3.5rem;
      }
    }
    
    @media (max-width: 640px) {
      .container {
        padding: 80px 16px 40px;
      }
      
      .nav-sticky {
        top: 60px;
      }
      
      .components-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="page-header">
      <h1 class="page-title">Componentes</h1>
      <p class="page-subtitle">
        Biblioteca de componentes UI reutilizáveis do site Alex Donega
      </p>
      <span class="version-badge">v2.0</span>
    </div>
    
    <!-- Stats Grid -->
    <div class="stats-grid">
      {stats.map((stat) => (
        <div class="stat-card">
          <div class="stat-value">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
    
    <!-- Sticky Navigation -->
    <nav class="nav-sticky">
      <a href="#ui" class="nav-item active" data-filter="all">Todos</a>
      <a href="#ui" class="nav-item" data-filter="ui">UI</a>
      <a href="#layout" class="nav-item" data-filter="layout">Layout</a>
      <a href="#course" class="nav-item" data-filter="course">Course</a>
      <a href="#blog" class="nav-item" data-filter="blog">Blog</a>
    </nav>
    
    <!-- UI Section -->
    <section class="section" id="ui">
      <div class="section-header">
        <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        <h2 class="section-title">UI Components</h2>
        <span class="section-count">{components.filter(c => c.category === 'ui').length} itens</span>
      </div>
      <div class="components-grid">
        {components.filter(c => c.category === 'ui').map((component) => (
          <a href={`/previews/${component.slug}`} class="component-card" data-category={component.category} target="_blank" rel="noopener noreferrer">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
              </svg>
            </div>
            <div class="card-header">
              <span class="card-title">{component.name}</span>
              <span class={`card-category ${component.category}`}>{categoryLabels[component.category]}</span>
            </div>
            <p class="card-description">{component.description}</p>
            <div class="card-footer">
              Ver preview
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>
    
    <!-- Layout Section -->
    <section class="section" id="layout">
      <div class="section-header">
        <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <path d="M3 9h18"/>
          <path d="M9 21V9"/>
        </svg>
        <h2 class="section-title">Layout Components</h2>
        <span class="section-count">{components.filter(c => c.category === 'layout').length} itens</span>
      </div>
      <div class="components-grid">
        {components.filter(c => c.category === 'layout').map((component) => (
          <a href={`/previews/${component.slug}`} class="component-card" data-category={component.category} target="_blank" rel="noopener noreferrer">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
              </svg>
            </div>
            <div class="card-header">
              <span class="card-title">{component.name}</span>
              <span class={`card-category ${component.category}`}>{categoryLabels[component.category]}</span>
            </div>
            <p class="card-description">{component.description}</p>
            <div class="card-footer">
              Ver preview
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>
    
    <!-- Course Section -->
    <section class="section" id="course">
      <div class="section-header">
        <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
        <h2 class="section-title">Course Components</h2>
        <span class="section-count">{components.filter(c => c.category === 'course').length} itens</span>
      </div>
      <div class="components-grid">
        {components.filter(c => c.category === 'course').map((component) => (
          <a href={`/previews/${component.slug}`} class="component-card" data-category={component.category} target="_blank" rel="noopener noreferrer">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
              </svg>
            </div>
            <div class="card-header">
              <span class="card-title">{component.name}</span>
              <span class={`card-category ${component.category}`}>{categoryLabels[component.category]}</span>
            </div>
            <p class="card-description">{component.description}</p>
            <div class="card-footer">
              Ver preview
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>
    
    <!-- Blog Section -->
    <section class="section" id="blog">
      <div class="section-header">
        <svg class="section-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        <h2 class="section-title">Blog Components</h2>
        <span class="section-count">{components.filter(c => c.category === 'blog').length} itens</span>
      </div>
      <div class="components-grid">
        {components.filter(c => c.category === 'blog').map((component) => (
          <a href={`/previews/${component.slug}`} class="component-card" data-category={component.category} target="_blank" rel="noopener noreferrer">
            <div class="card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
              </svg>
            </div>
            <div class="card-header">
              <span class="card-title">{component.name}</span>
              <span class={`card-category ${component.category}`}>{categoryLabels[component.category]}</span>
            </div>
            <p class="card-description">{component.description}</p>
            <div class="card-footer">
              Ver preview
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
  
  <script>
    const navItems = document.querySelectorAll('.nav-item');
    const sections = document.querySelectorAll('.section');
    
    navItems.forEach(item => {
      item.addEventListener('click', () => {
        const filter = item.getAttribute('data-filter');
        
        // Update active nav
        navItems.forEach(n => n.classList.remove('active'));
        item.classList.add('active');
        
        // Show/hide sections
        sections.forEach(section => {
          const sectionId = section.getAttribute('id');
          if (filter === 'all' || sectionId === filter) {
            section.classList.remove('hidden');
          } else {
            section.classList.add('hidden');
          }
        });
      });
    });
  </script>
</body>
</html>
