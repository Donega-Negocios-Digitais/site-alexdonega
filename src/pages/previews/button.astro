---
/**
 * /previews/button.astro
 * Preview do componente Button com todas as variantes e tamanhos
 */
import Button from '../../components/ui/Button.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Preview - Button</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      --bg-main: #0a0a0a;
      --bg-card: #141414;
      --text-primary: #ffffff;
      --text-secondary: #a3a3a3;
      --text-muted: #737373;
      --accent: #f97316;
      --border: #262626;
    }
    
    html, body {
      min-height: 100vh;
      background: var(--bg-main);
      color: var(--text-primary);
      font-family: system-ui, -apple-system, sans-serif;
    }
    
    body {
      padding: 2rem;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
      transition: color 0.2s;
    }
    
    .back-link:hover {
      color: var(--accent);
    }
    
    header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }
    
    h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    
    .description {
      color: var(--text-secondary);
      font-size: 1rem;
    }
    
    .section {
      margin-bottom: 3rem;
    }
    
    .section-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
    }
    
    .section-title code {
      background: rgba(249, 115, 22, 0.15);
      color: var(--accent);
      padding: 0.125rem 0.5rem;
      border-radius: 4px;
      font-size: 0.875rem;
      margin-left: 0.5rem;
    }
    
    .button-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
    }
    
    .size-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: flex-end;
    }
    
    .preview-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 1.5rem;
    }
    
    .preview-card-title {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    
    .code-block {
      background: #000;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-top: 1rem;
      font-family: 'Fira Code', 'Monaco', monospace;
      font-size: 0.875rem;
      color: var(--text-secondary);
      overflow-x: auto;
    }
    
    .props-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }
    
    .props-table th,
    .props-table td {
      padding: 0.75rem 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }
    
    .props-table th {
      color: var(--text-muted);
      font-weight: 500;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    
    .props-table td {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }
    
    .props-table code {
      background: rgba(249, 115, 22, 0.15);
      color: var(--accent);
      padding: 0.125rem 0.375rem;
      border-radius: 4px;
      font-size: 0.8125rem;
    }
  </style>
  <style is:inline>
    body.in-iframe .back-link,
    body.in-iframe header,
    body.in-iframe .section:has(.props-table),
    body.in-iframe .section:has(.code-block) { display: none !important; }
    body.in-iframe .container { max-width: 100%; }
    body.in-iframe body { padding: 1rem !important; }
    body.in-iframe .section { margin-bottom: 1rem !important; }
    body.in-iframe .preview-card { padding: 1rem !important; }
    body.in-iframe h2.section-title { font-size: 0.85rem !important; margin-bottom: 0.75rem !important; }
    body.in-iframe .preview-card-title { font-size: 0.7rem !important; margin-bottom: 0.5rem !important; }
  </style>
</head>
<body>
  <div class="container">
    <a href="/previews/" class="back-link">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Voltar para componentes
    </a>
    
    <header>
      <h1>Button</h1>
      <p class="description">Componente de botão estilo shadcn/ui com múltiplas variantes e tamanhos</p>
    </header>
    
    <!-- Variantes -->
    <section class="section">
      <h2 class="section-title">Variantes <code>variant</code></h2>
      
      <div class="preview-card">
        <div class="preview-card-title">Default</div>
        <div class="button-grid">
          <Button variant="default">Default</Button>
          <Button variant="secondary">Secondary</Button>
          <Button variant="outline">Outline</Button>
          <Button variant="ghost">Ghost</Button>
          <Button variant="link">Link</Button>
          <Button variant="destructive">Destructive</Button>
        </div>
      </div>
    </section>
    
    <!-- Tamanhos -->
    <section class="section">
      <h2 class="section-title">Tamanhos <code>size</code></h2>
      
      <div class="preview-card">
        <div class="preview-card-title">Sizes</div>
        <div class="size-grid">
          <Button variant="default" size="sm">Small</Button>
          <Button variant="default" size="default">Default</Button>
          <Button variant="default" size="lg">Large</Button>
          <Button variant="default" size="icon">🔍</Button>
        </div>
      </div>
    </section>
    
    <!-- Shimmer Effect -->
    <section class="section">
      <h2 class="section-title">Efeito Shimmer <code>shimmer</code></h2>
      
      <div class="preview-card">
        <div class="preview-card-title">Com animação shimmer</div>
        <div class="button-grid">
          <Button variant="default" shimmer>Com Shimmer</Button>
          <Button variant="default" size="lg" shimmer>Large com Shimmer</Button>
        </div>
      </div>
    </section>
    
    <!-- Como Link -->
    <section class="section">
      <h2 class="section-title">Como Link <code>href</code></h2>
      
      <div class="preview-card">
        <div class="preview-card-title">Botão como link</div>
        <div class="button-grid">
          <Button href="https://google.com" variant="default">Link Externo</Button>
          <Button href="/previews/" variant="outline">Link Interno</Button>
        </div>
      </div>
    </section>
    
    <!-- Props -->
    <section class="section">
      <h2 class="section-title">Props</h2>
      
      <table class="props-table">
        <thead>
          <tr>
            <th>Prop</th>
            <th>Tipo</th>
            <th>Default</th>
            <th>Descrição</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>variant</code></td>
            <td><code>'default' | 'secondary' | 'outline' | 'ghost' | 'link' | 'destructive'</code></td>
            <td><code>'default'</code></td>
            <td>Estilo visual do botão</td>
          </tr>
          <tr>
            <td><code>size</code></td>
            <td><code>'default' | 'sm' | 'lg' | 'icon'</code></td>
            <td><code>'default'</code></td>
            <td>Tamanho do botão</td>
          </tr>
          <tr>
            <td><code>href</code></td>
            <td><code>string</code></td>
            <td><code>undefined</code></td>
            <td>Se definido, renderiza como &lt;a&gt;</td>
          </tr>
          <tr>
            <td><code>shimmer</code></td>
            <td><code>boolean</code></td>
            <td><code>false</code></td>
            <td>Ativa efeito de brilho animado</td>
          </tr>
          <tr>
            <td><code>disabled</code></td>
            <td><code>boolean</code></td>
            <td><code>false</code></td>
            <td>Desabilita o botão</td>
          </tr>
          <tr>
            <td><code>class</code></td>
            <td><code>string</code></td>
            <td><code>''</code></td>
            <td>Classes CSS adicionais</td>
          </tr>
        </tbody>
      </table>
    </section>
    
    <!-- Código de Exemplo -->
    <section class="section">
      <h2 class="section-title">Exemplo de Uso</h2>
      
      <div class="code-block">
        <pre>---
import Button from '../../components/ui/Button.astro';
---

&lt;Button variant="default"&gt;Clique aqui&lt;/Button&gt;
&lt;Button variant="outline" size="lg"&gt;Outline Large&lt;/Button&gt;
&lt;Button href="/contato" shimmer&gt;CTA com Shimmer&lt;/Button&gt;</pre>
      </div>
    </section>
  </div>
  <script>
    if (window.self !== window.top) document.body.classList.add('in-iframe');
  </script>
</body>
</html>
