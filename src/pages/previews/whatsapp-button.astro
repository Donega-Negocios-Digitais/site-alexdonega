---
/**
 * /previews/whatsapp-button.astro
 * Preview do componente WhatsAppButton
 */
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Preview - WhatsApp Button</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg-main: #0a0a0a;
      --bg-card: #141414;
      --text-primary: #ffffff;
      --text-secondary: #a3a3a3;
      --text-muted: #737373;
      --accent: #f97316;
      --border: #262626;
    }

    html, body {
      min-height: 100vh;
      background: var(--bg-main);
      color: var(--text-primary);
      font-family: system-ui, -apple-system, sans-serif;
    }

    body {
      padding: 2rem;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: var(--accent);
    }

    header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .description {
      color: var(--text-secondary);
      font-size: 1rem;
    }

    .section {
      margin-bottom: 3rem;
    }

    .section-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
    }

    .section-title code {
      background: rgba(249, 115, 22, 0.15);
      color: var(--accent);
      padding: 0.125rem 0.5rem;
      border-radius: 4px;
      font-size: 0.875rem;
      margin-left: 0.5rem;
    }

    .preview-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 1.5rem;
      position: relative;
    }

    .preview-card-title {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .demo-area {
      min-height: 300px;
      background: #080808;
      border-radius: 8px;
      border: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }

    .demo-content {
      padding: 2rem;
      color: var(--text-secondary);
      font-size: 0.9rem;
    }

    .demo-spacer {
      height: 600px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      font-size: 0.85rem;
      text-align: center;
      line-height: 1.6;
    }

    .props-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }

    .props-table th,
    .props-table td {
      padding: 0.75rem 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    .props-table th {
      color: var(--text-muted);
      font-weight: 500;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .props-table td {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }

    .props-table code {
      background: rgba(249, 115, 22, 0.15);
      color: var(--accent);
      padding: 0.125rem 0.375rem;
      border-radius: 4px;
      font-size: 0.8125rem;
    }

    .code-block {
      background: #000;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-top: 1rem;
      font-family: 'Fira Code', 'Monaco', monospace;
      font-size: 0.875rem;
      color: var(--text-secondary);
      overflow-x: auto;
    }

    .notes {
      background: rgba(37, 211, 102, 0.06);
      border: 1px solid rgba(37, 211, 102, 0.15);
      border-radius: 8px;
      padding: 1.25rem;
      margin-top: 1.5rem;
    }

    .notes-title {
      font-size: 0.875rem;
      font-weight: 600;
      color: #25D366;
      margin-bottom: 0.5rem;
    }

    .notes ul {
      list-style: none;
      padding: 0;
    }

    .notes li {
      font-size: 0.85rem;
      color: var(--text-secondary);
      padding: 0.25rem 0;
    }

    .notes li::before {
      content: "→ ";
      color: #25D366;
    }
  </style>
  <style is:inline>
    body.in-iframe .back-link,
    body.in-iframe header,
    body.in-iframe .section:has(.props-table),
    body.in-iframe .section:has(.code-block),
    body.in-iframe .section:has(.notes) { display: none !important; }
    body.in-iframe .container { max-width: 100%; }
    body.in-iframe body { padding: 1rem !important; }
    body.in-iframe .section { margin-bottom: 1rem !important; }
    body.in-iframe .preview-card { padding: 1rem !important; }
    body.in-iframe h2.section-title { font-size: 0.85rem !important; margin-bottom: 0.75rem !important; }
    body.in-iframe .preview-card-title { font-size: 0.7rem !important; margin-bottom: 0.5rem !important; }
  </style>
</head>
<body>
  <div class="container">
    <a href="/previews/" class="back-link">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Voltar para componentes
    </a>

    <header>
      <h1>WhatsApp Button</h1>
      <p class="description">Botão flutuante de WhatsApp com animação de pulso e aparição por scroll</p>
    </header>

    <!-- Preview ao vivo -->
    <section class="section">
      <h2 class="section-title">Preview ao Vivo</h2>

      <div class="preview-card">
        <div class="preview-card-title">Comportamento: aparece após scroll (threshold: 100px)</div>
        <div class="demo-area">
          <div class="demo-spacer">
            Role para baixo para ver o botão aparecer<br>
            ↓ O botão fica fixo no canto inferior direito
          </div>
        </div>
      </div>
    </section>

    <!-- Props -->
    <section class="section">
      <h2 class="section-title">Props</h2>

      <table class="props-table">
        <thead>
          <tr>
            <th>Prop</th>
            <th>Tipo</th>
            <th>Default</th>
            <th>Descrição</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>number</code></td>
            <td><code>string</code></td>
            <td><code>env.PUBLIC_WHATSAPP_NUMBER</code></td>
            <td>Número de telefone com código do país</td>
          </tr>
          <tr>
            <td><code>message</code></td>
            <td><code>string</code></td>
            <td><code>"Alex, estou com a seguinte dúvida: "</code></td>
            <td>Mensagem pré-preenchida</td>
          </tr>
          <tr>
            <td><code>scrollThreshold</code></td>
            <td><code>number</code></td>
            <td><code>100</code></td>
            <td>Scroll Y mínimo para exibir o botão</td>
          </tr>
        </tbody>
      </table>
    </section>

    <!-- Código de Exemplo -->
    <section class="section">
      <h2 class="section-title">Exemplo de Uso</h2>

      <div class="code-block">
        <pre>---
import WhatsAppButton from '../../components/ui/WhatsAppButton.astro';
---

&lt;!-- Padrão (usa env vars) --&gt;
&lt;WhatsAppButton /&gt;

&lt;!-- Customizado --&gt;
&lt;WhatsAppButton
  number="5511999999999"
  message="Olá, quero saber mais sobre o serviço!"
  scrollThreshold={200}
/&gt;</pre>
      </div>
    </section>

    <!-- Notas -->
    <section class="section">
      <div class="notes">
        <div class="notes-title">Notas</div>
        <ul>
          <li>Posição fixa no canto inferior direito</li>
          <li>Animação de pulso (ping ring) enquanto visível</li>
          <li>Hover com scale e sombra ampliada</li>
          <li>Fallback noscript para sempre exibir</li>
          <li>Cleanup automático no <code>astro:before-swap</code></li>
          <li>Responsivo: posição ajustada em mobile (&lt;640px)</li>
        </ul>
      </div>
    </section>
  </div>

  <WhatsAppButton />
  <script>
    if (window.self !== window.top) document.body.classList.add('in-iframe');
  </script>
</body>
</html>
