---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Brand Book"
  description="Guia completo de identidade visual do site Alex Donega - Cores, tipografia, componentes e assets."
>

<style>
  .brand-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 24px 60px;
  }

  .brand-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .brand-title {
    font-size: 3rem;
    font-weight: 700;
    color: white;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .brand-subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin: 0 auto 24px;
  }

  .brand-version {
    display: inline-block;
    background: rgba(216, 119, 87, 0.15);
    color: #d87757;
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Sections */
  .brand-section {
    margin-bottom: 80px;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: white;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid #2a2a2a;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-icon {
    width: 28px;
    height: 28px;
    color: #d87757;
  }

  /* Color Palette */
  .colors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
  }

  .color-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
  }

  .color-card:hover {
    transform: translateY(-2px);
    border-color: #3a3a3a;
  }

  .color-preview {
    height: 80px;
    position: relative;
  }

  .color-preview::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: #2a2a2a;
  }

  .color-info {
    padding: 16px;
  }

  .color-name {
    font-weight: 600;
    color: white;
    margin-bottom: 4px;
    font-size: 0.95rem;
  }

  .color-value {
    font-family: 'Geist Mono', monospace;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .color-var {
    font-size: 0.75rem;
    color: #d87757;
    margin-top: 4px;
  }

  /* Typography */
  .typo-section {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    padding: 32px;
    margin-bottom: 24px;
  }

  .typo-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .typo-name {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
  }

  .typo-meta {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    font-family: 'Geist Mono', monospace;
  }

  .typo-samples {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .typo-sample {
    display: flex;
    align-items: baseline;
    gap: 20px;
    padding: 12px 0;
    border-bottom: 1px solid #2a2a2a;
  }

  .typo-sample:last-child {
    border-bottom: none;
  }

  .typo-size-label {
    min-width: 100px;
    font-size: 0.75rem;
    color: #d87757;
    font-family: 'Geist Mono', monospace;
  }

  .typo-sample-text {
    color: white;
  }

  .typo-weight-label {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.4);
    margin-left: auto;
  }

  /* Components Grid */
  .components-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .component-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    padding: 24px;
    transition: all 0.2s;
  }

  .component-card:hover {
    border-color: #d87757;
  }

  .component-name {
    font-weight: 600;
    color: white;
    margin-bottom: 8px;
    font-size: 1.1rem;
  }

  .component-file {
    font-family: 'Geist Mono', monospace;
    font-size: 0.8rem;
    color: #d87757;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .component-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
  }

  /* Assets Grid */
  .assets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 16px;
  }

  .asset-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: all 0.2s;
  }

  .asset-card:hover {
    border-color: #3a3a3a;
    transform: translateY(-2px);
  }

  .asset-preview {
    width: 64px;
    height: 64px;
    margin: 0 auto 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a0a0a;
    border-radius: 8px;
    overflow: hidden;
  }

  .asset-preview img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .asset-name {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.7);
    word-break: break-all;
  }

  /* Icons Grid */
  .icons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 16px;
  }

  .icon-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    padding: 24px 16px;
    text-align: center;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .icon-card:hover {
    border-color: #d87757;
    transform: translateY(-2px);
  }

  .icon-preview {
    width: 48px;
    height: 48px;
    color: #d87757;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-preview svg {
    width: 100%;
    height: 100%;
  }

  .icon-name {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.3;
  }

  .icon-source {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.4);
    font-family: 'Geist Mono', monospace;
  }

  /* Code Block */
  .code-block {
    background: #0a0a0a;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    padding: 20px;
    overflow-x: auto;
    margin-bottom: 24px;
  }

  .code-block code {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.85rem;
    color: #e5e5e5;
    line-height: 1.6;
  }

  .code-block .comment {
    color: #6b7280;
  }

  .code-block .property {
    color: #d87757;
  }

  .code-block .value {
    color: #a5d6ff;
  }

  .code-block .string {
    color: #7ee787;
  }

  /* Info Cards */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }

  .info-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    padding: 20px;
    text-align: center;
  }

  .info-value {
    font-size: 2rem;
    font-weight: 700;
    color: #d87757;
    margin-bottom: 4px;
  }

  .info-label {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
  }

  /* Table */
  .brand-table {
    width: 100%;
    border-collapse: collapse;
    background: #1a1a1a;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #2a2a2a;
    margin-bottom: 24px;
  }

  .brand-table th,
  .brand-table td {
    padding: 16px 20px;
    text-align: left;
    border-bottom: 1px solid #2a2a2a;
  }

  .brand-table th {
    background: #0a0a0a;
    font-weight: 600;
    color: white;
    font-size: 0.9rem;
  }

  .brand-table td {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
  }

  .brand-table tr:last-child td {
    border-bottom: none;
  }

  .brand-table code {
    background: #0a0a0a;
    padding: 4px 8px;
    border-radius: 4px;
    font-family: 'Geist Mono', monospace;
    font-size: 0.8rem;
    color: #d87757;
  }

  /* Gradient Preview */
  .gradient-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .gradient-preview {
    height: 60px;
  }

  .gradient-info {
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .gradient-name {
    font-weight: 600;
    color: white;
  }

  .gradient-code {
    font-family: 'Geist Mono', monospace;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* Subsection */
  .subsection {
    margin-bottom: 40px;
  }

  .subsection-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: white;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .subsection-title::before {
    content: '';
    width: 4px;
    height: 16px;
    background: #d87757;
    border-radius: 2px;
  }

  /* Video Grid */
  .videos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .video-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s;
  }

  .video-card:hover {
    border-color: #d87757;
    transform: translateY(-2px);
  }

  .video-preview {
    aspect-ratio: 16/9;
    background: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .video-preview video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-info {
    padding: 16px;
  }

  .video-name {
    font-weight: 600;
    color: white;
    font-size: 0.9rem;
    margin-bottom: 4px;
  }

  .video-path {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    font-family: 'Geist Mono', monospace;
  }

  /* Structure Tree */
  .structure-tree {
    background: #0a0a0a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    padding: 24px;
    font-family: 'Geist Mono', monospace;
    font-size: 0.85rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.8);
    overflow-x: auto;
  }

  .structure-tree .folder {
    color: #d87757;
  }

  .structure-tree .file {
    color: #7ee787;
  }

  .structure-tree .comment {
    color: #6b7280;
  }

  /* Pages Table */
  .pages-table {
    width: 100%;
    border-collapse: collapse;
    background: #1a1a1a;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #2a2a2a;
  }

  .pages-table th,
  .pages-table td {
    padding: 14px 16px;
    text-align: left;
    border-bottom: 1px solid #2a2a2a;
  }

  .pages-table th {
    background: #0a0a0a;
    font-weight: 600;
    color: white;
    font-size: 0.85rem;
  }

  .pages-table td {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.85rem;
  }

  .pages-table tr:last-child td {
    border-bottom: none;
  }

  .pages-table a {
    color: #d87757;
    text-decoration: none;
  }

  .pages-table a:hover {
    text-decoration: underline;
  }

  .pages-table code {
    background: #0a0a0a;
    padding: 3px 6px;
    border-radius: 4px;
    font-family: 'Geist Mono', monospace;
    font-size: 0.75rem;
    color: #7ee787;
  }

  /* Download CTA */
  .download-cta {
    background: linear-gradient(135deg, rgba(216, 119, 87, 0.1) 0%, rgba(216, 119, 87, 0.05) 100%);
    border: 1px solid rgba(216, 119, 87, 0.3);
    border-radius: 12px;
    padding: 32px;
    text-align: center;
    margin-top: 40px;
  }

  .download-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 12px;
  }

  .download-desc {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 20px;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(to right, rgb(249, 115, 22), rgb(234, 88, 12));
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .download-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(249, 115, 22, 0.3);
  }

  /* Brand Navigation */
  .brand-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: 60px;
    padding: 20px;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    position: sticky;
    top: 80px;
    z-index: 100;
  }

  .nav-item {
    padding: 8px 16px;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    background: #0a0a0a;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .nav-item:hover {
    color: #d87757;
    border-color: #d87757;
    background: rgba(216, 119, 87, 0.1);
  }

  /* Price Tag Component */
  .pricetag-demo {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .pricing-card {
    background: linear-gradient(135deg, rgba(216, 119, 87, 0.1) 0%, rgba(216, 119, 87, 0.05) 100%);
    border: 1px solid rgba(216, 119, 87, 0.3);
    border-radius: 16px;
    padding: 40px;
    text-align: center;
    max-width: 400px;
  }

  .pricing-card .price {
    font-size: 3rem;
    font-weight: 700;
    color: #d87757;
    line-height: 1;
    margin-bottom: 8px;
  }

  .pricing-card .price-subtitle {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 16px;
  }

  .pricing-card .price-note {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 24px;
  }

  .pricing-card .btn-buy {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(to right, rgb(249, 115, 22), rgb(234, 88, 12));
    color: white;
    padding: 14px 28px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .pricing-card .btn-buy:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(249, 115, 22, 0.3);
  }

  .pricing-card .btn-buy svg {
    width: 18px;
    height: 18px;
  }

  .external-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #d87757;
    text-decoration: none;
    font-size: 0.85rem;
    padding: 8px 16px;
    background: rgba(216, 119, 87, 0.1);
    border-radius: 6px;
    transition: background 0.2s;
  }

  .external-link:hover {
    background: rgba(216, 119, 87, 0.2);
  }

  @media (min-width: 768px) {
    .brand-title {
      font-size: 3.5rem;
    }
  }

  @media (min-width: 1024px) {
    .brand-title {
      font-size: 4rem;
    }
  }
</style>

<div class="brand-container">
  <!-- Header -->
  <div class="brand-header">
    <h1 class="brand-title">Brand Book</h1>
    <p class="brand-subtitle">
      Guia completo de identidade visual do site alexdonega.com.br
    </p>
    <span class="brand-version">v2.0 - Validado</span>
  </div>

  <!-- Navigation Filter -->
  <nav class="brand-nav">
