---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Políticas"
  description="Políticas e termos do site Alex Donega - Privacidade, Cookies e Termos de Uso."
>

<style>
  .politicas-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 120px 24px 60px;
  }

  .politicas-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .politicas-title {
    font-size: 3rem;
    font-weight: 700;
    color: white;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .politicas-subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin: 0 auto;
  }

  .politicas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-bottom: 60px;
  }

  .politica-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    padding: 40px;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .politica-card:hover {
    border-color: #fb923c;
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(251, 146, 60, 0.1);
  }

  .politica-icon {
    font-size: 3rem;
    margin-bottom: 8px;
  }

  .politica-card-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: white;
    transition: color 0.2s ease;
  }

  .politica-card:hover .politica-card-title {
    color: #fb923c;
  }

  .politica-description {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    flex-grow: 1;
  }

  .politica-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #fb923c;
    font-weight: 600;
    margin-top: 16px;
    transition: gap 0.2s ease;
  }

  .politica-card:hover .politica-cta {
    gap: 12px;
  }

  .info-box {
    background: rgba(251, 146, 60, 0.05);
    border-left: 4px solid #fb923c;
    padding: 24px;
    border-radius: 8px;
    margin-top: 40px;
  }

  .info-box-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #fb923c;
    margin-bottom: 12px;
  }

  .info-box-text {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
  }

  .info-box-text a {
    color: #fb923c;
    text-decoration: none;
    font-weight: 500;
  }

  .info-box-text a:hover {
    text-decoration: underline;
  }

  @media (min-width: 768px) {
    .politicas-title {
      font-size: 3.5rem;
    }

    .politicas-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .politica-card {
      padding: 36px;
    }
  }

  @media (min-width: 1024px) {
    .politicas-title {
      font-size: 4rem;
    }

    .politicas-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<div class="politicas-container">
  <div class="politicas-header">
    <h1 class="politicas-title">Políticas</h1>
    <p class="politicas-subtitle">
      Conheça nossas políticas de privacidade, cookies e termos de uso
    </p>
  </div>

  <div class="politicas-grid">
    <!-- Política de Privacidade -->
    <a href="/politica-de-privacidade" class="politica-card">
      <div class="politica-icon">🔒</div>
      <h2 class="politica-card-title">Política de Privacidade</h2>
      <p class="politica-description">
        Entenda como coletamos, usamos e protegemos seus dados pessoais. Sua privacidade é importante para nós.
      </p>
      <div class="politica-cta">Ler Política →</div>
    </a>

    <!-- Política de Cookies -->
    <a href="/politica-de-cookies" class="politica-card">
      <div class="politica-icon">🍪</div>
      <h2 class="politica-card-title">Política de Cookies</h2>
      <p class="politica-description">
        Saiba como usamos cookies e tecnologias similares para melhorar sua experiência no site.
      </p>
      <div class="politica-cta">Ler Política →</div>
    </a>

    <!-- Termos de Uso -->
    <a href="/termos-de-uso" class="politica-card">
      <div class="politica-icon">⚖️</div>
      <h2 class="politica-card-title">Termos de Uso</h2>
      <p class="politica-description">
        Conheça os termos e condições para o uso do site Alex Donega e seus serviços.
      </p>
      <div class="politica-cta">Ler Termos →</div>
    </a>
  </div>

  <div class="info-box">
    <div class="info-box-title">📞 Dúvidas sobre nossas políticas?</div>
    <div class="info-box-text">
      Se você tiver qualquer dúvida sobre nossas políticas ou como tratamos seus dados, entre em contato conosco através do WhatsApp: <a href="https://wa.me/5545999506444" target="_blank">+55 45 99950-6444</a>
    </div>
  </div>
</div>

</Layout>
