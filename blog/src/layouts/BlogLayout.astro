---
import PostCard from '../components/PostCard.astro';

interface RelatedPost {
  slug: string;
  data: {
    title: string;
    description?: string;
    image?: string;
    tags?: string[];
    pubDate: Date;
  };
}

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  author?: string;
  content?: string;
  image?: string;
  relatedPosts?: RelatedPost[];
}

const { title, description, pubDate, tags = [], author = 'Alex Donega', image, relatedPosts = [] } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric'
}).format(pubDate);

// Calcular tempo de leitura estimado (assumindo 200 palavras por minuto)
const calculateReadingTime = (content: string) => {
  const wordsPerMinute = 200;
  const wordCount = content.trim().split(/\s+/).length;
  const readingTime = Math.ceil(wordCount / wordsPerMinute);
  return readingTime;
};

// Tentar obter o conteúdo do slot para calcular tempo de leitura
// Por enquanto, vamos usar um placeholder e calcular no client-side
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Alex Donega</title>
  {description && <meta name="description" content={description} />}

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Barra de Progresso de Leitura -->
  <div class="reading-progress-container">
    <div class="reading-progress-bar" id="reading-progress"></div>
  </div>

  <header class="header">
    <nav class="nav">
      <a href="/" class="nav-logo">Alex Donega</a>
      <div class="nav-links">
        <a href="/">Início</a>
        <a href="/blog">Blog</a>
      </div>
    </nav>
  </header>

  <main class="container">
    <!-- Botão Voltar -->
    <a href="/blog" class="back-button">
      ← Voltar
    </a>

    <div class="post-layout">
      <article class="blog-post">
        <header class="post-header">
          {tags.length > 0 && (
            <div class="post-category">{tags[0]}</div>
          )}
          <h1 class="post-title">{title}</h1>
          <div class="post-meta">
            <img
              src="/images/alex-donega-autor-blog.webp"
              alt={author}
              class="author-avatar-img"
            />
            <div class="author-details">
              <span class="author-name">{author}</span>
              <div class="post-meta-info">
                <time datetime={pubDate.toISOString()}>{formattedDate}</time>
                <span class="meta-separator">•</span>
                <span id="reading-time">Calculando...</span>
              </div>
            </div>
          </div>
        </header>

        {image && (
          <div class="post-cover-image">
            <img src={image} alt={title} />
          </div>
        )}

        <div class="post-content" id="post-content">
          <slot />
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="post-sidebar">
        <!-- Acesso Rápido (Table of Contents) -->
        <div class="sidebar-section toc-section">
          <h3>Acesso Rápido</h3>
          <nav id="table-of-contents" class="table-of-contents">
            <p class="toc-empty">Gerando sumário...</p>
          </nav>
        </div>

        <div class="sidebar-section author-card">
          <div class="author-info-compact">
            <img
              src="/images/alex-donega-autor-blog.webp"
              alt={author}
              class="author-avatar-compact"
            />
            <div class="author-details-compact">
              <p class="author-name-compact">{author}</p>
              <p class="author-role">Diretor de Relacionamento do Novo Envio</p>
            </div>
          </div>

          <div class="share-section">
            <p class="share-label">Compartilhe:</p>
            <div class="share-buttons-compact">
              <button class="share-btn-compact" data-share="whatsapp" title="WhatsApp">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
              </button>
              <button class="share-btn-compact" data-share="linkedin" title="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </button>
              <button class="share-btn-compact" data-share="facebook" title="Facebook">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </button>
              <button class="share-btn-compact" data-share="twitter" title="X (Twitter)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        {tags.length > 0 && (
          <div class="sidebar-section">
            <h3>Tags</h3>
            <div class="sidebar-tags">
              {tags.map(tag => (
                <a href={`/blog?tag=${tag}`} class="sidebar-tag">#{tag}</a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>

    {relatedPosts.length > 0 && (
      <section class="related-posts">
        <h2>Veja também</h2>
        <div class="related-posts-grid">
          {relatedPosts.map(post => (
            <PostCard
              slug={post.slug}
              title={post.data.title}
              description={post.data.description}
              image={post.data.image}
              tags={post.data.tags}
              pubDate={post.data.pubDate}
            />
          ))}
        </div>
      </section>
    )}
  </main>

  <style>
    :root {
      --bg-main: #0a0a0a;
      --bg-secondary: #111111;
      --bg-card: #1a1a1a;
      --bg-card-hover: #222222;
      --text-white: #ffffff;
      --text-light: #e5e5e5;
      --text-gray: #a3a3a3;
      --text-muted: #737373;
      --accent: #d87757;
      --accent-hover: #e8866a;
      --border: #2a2a2a;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background-color: var(--bg-main);
      color: var(--text-light);
      font-size: 16px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* Reading Progress Bar */
    .reading-progress-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: transparent;
      z-index: 9999;
      pointer-events: none;
    }

    .reading-progress-bar {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, var(--accent) 0%, var(--accent-hover) 100%);
      box-shadow: 0 0 10px rgba(216, 119, 87, 0.5);
      transition: width 0.1s ease-out;
      border-radius: 0 2px 2px 0;
    }

    @media (min-width: 768px) {
      .reading-progress-container {
        height: 5px;
      }
    }

    @media (min-width: 1024px) {
      .reading-progress-container {
        height: 6px;
      }
    }

    .header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: var(--bg-main);
      border-bottom: 1px solid var(--border);
    }

    .nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .nav-logo {
      font-family: 'Source Serif 4', Georgia, serif;
      font-size: 18px;
      font-weight: 500;
      color: var(--text-white);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 24px;
    }

    .nav-links a {
      color: var(--text-gray);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: var(--accent);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 48px 16px;
    }

    .back-button {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--accent);
      color: var(--bg-main);
      padding: 10px 20px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
      margin-bottom: 32px;
      transition: all 0.2s;
    }

    .back-button:hover {
      background: var(--accent-hover);
      transform: translateX(-4px);
    }

    .post-layout {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 48px;
    }

    .blog-post {
      background: var(--bg-card);
      border-radius: 16px;
      padding: 48px;
      border: 1px solid var(--border);
    }

    .post-header {
      margin-bottom: 40px;
    }

    .post-category {
      display: inline-block;
      background: rgba(216, 119, 87, 0.1);
      color: var(--accent);
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 16px;
    }

    .post-title {
      font-family: 'Source Serif 4', Georgia, serif;
      font-size: 42px;
      font-weight: 600;
      color: var(--text-white);
      line-height: 1.2;
      margin-bottom: 24px;
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .author-avatar-img {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }

    .author-details {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .author-name {
      color: var(--text-white);
      font-weight: 600;
      font-size: 16px;
    }

    .post-meta-info {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text-muted);
      font-size: 14px;
    }

    .meta-separator {
      color: var(--border);
    }

    .post-sidebar {
      position: sticky;
      top: 100px;
      align-self: start;
      max-height: calc(100vh - 120px);
      overflow-y: auto;
    }

    .post-sidebar::-webkit-scrollbar {
      width: 6px;
    }

    .post-sidebar::-webkit-scrollbar-track {
      background: var(--bg-card);
      border-radius: 3px;
    }

    .post-sidebar::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 3px;
    }

    .post-sidebar::-webkit-scrollbar-thumb:hover {
      background: var(--accent);
    }

    .sidebar-section {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 24px;
    }

    .sidebar-section h3 {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-white);
      margin-bottom: 16px;
    }

    /* Table of Contents */
    .table-of-contents {
      font-size: 14px;
    }

    .toc-empty {
      color: var(--text-muted);
      font-size: 14px;
    }

    .toc-link {
      display: block;
      color: var(--text-gray);
      text-decoration: none;
      padding: 6px 0;
      transition: color 0.2s;
      border-left: 2px solid transparent;
      padding-left: 12px;
      margin-left: -12px;
    }

    .toc-link:hover {
      color: var(--accent);
    }

    .toc-link.active {
      color: var(--accent);
      border-left-color: var(--accent);
    }

    .toc-link.level-3 {
      padding-left: 24px;
      margin-left: 0;
      font-size: 13px;
    }

    /* Author Card - Compact & Discrete */
    .author-card {
      padding: 20px !important;
    }

    .author-info-compact {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    .author-avatar-compact {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }

    .author-details-compact {
      flex: 1;
      min-width: 0;
    }

    .author-name-compact {
      font-weight: 600;
      color: var(--text-white);
      font-size: 15px;
      margin-bottom: 4px;
      line-height: 1.3;
    }

    .author-role {
      color: var(--text-muted);
      font-size: 13px;
      line-height: 1.4;
    }

    /* Share Section - Minimal */
    .share-section {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .share-label {
      font-weight: 600;
      color: var(--text-white);
      font-size: 14px;
      margin: 0;
    }

    .share-buttons-compact {
      display: flex;
      gap: 8px;
    }

    .share-btn-compact {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-muted);
      padding: 10px;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 1;
    }

    .share-btn-compact:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(216, 119, 87, 0.05);
    }

    .share-btn-compact svg {
      opacity: 0.7;
      transition: opacity 0.2s;
    }

    .share-btn-compact:hover svg {
      opacity: 1;
    }

    .sidebar-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .sidebar-tag {
      display: inline-block;
      padding: 6px 12px;
      background: rgba(216, 119, 87, 0.1);
      color: var(--accent);
      border-radius: 6px;
      font-size: 12px;
      text-decoration: none;
      transition: background 0.2s;
    }

    .sidebar-tag:hover {
      background: rgba(216, 119, 87, 0.2);
    }

    .post-cover-image {
      margin: 32px 0;
      border-radius: 12px;
      overflow: hidden;
    }

    .post-cover-image img {
      width: 100%;
      height: auto;
      display: block;
    }

    .post-content {
      font-size: 18px;
      line-height: 1.8;
      color: var(--text-light);
    }

    .post-content :global(h2) {
      font-family: 'Source Serif 4', Georgia, serif;
      font-size: 32px;
      font-weight: 600;
      color: var(--text-white);
      margin: 48px 0 24px;
      line-height: 1.3;
      scroll-margin-top: 100px;
    }

    .post-content :global(h3) {
      font-family: 'Source Serif 4', Georgia, serif;
      font-size: 24px;
      font-weight: 600;
      color: var(--text-white);
      margin: 36px 0 16px;
      scroll-margin-top: 100px;
    }

    .post-content :global(h4) {
      font-family: 'Source Serif 4', Georgia, serif;
      font-size: 20px;
      font-weight: 600;
      color: var(--text-white);
      margin: 24px 0 12px;
      scroll-margin-top: 100px;
    }

    .post-content :global(p) {
      margin-bottom: 24px;
    }

    .post-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
      margin: 32px 0;
    }

    .post-content :global(a) {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s;
    }

    .post-content :global(a:hover) {
      border-bottom-color: var(--accent);
    }

    .post-content :global(ul),
    .post-content :global(ol) {
      margin-bottom: 24px;
      padding-left: 32px;
    }

    .post-content :global(li) {
      margin-bottom: 8px;
    }

    .post-content :global(code) {
      background: var(--bg-secondary);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.9em;
      font-family: 'Courier New', monospace;
    }

    .post-content :global(pre) {
      background: var(--bg-secondary);
      padding: 24px;
      border-radius: 8px;
      overflow-x: auto;
      margin-bottom: 24px;
    }

    .post-content :global(pre code) {
      background: none;
      padding: 0;
    }

    .post-content :global(blockquote) {
      border-left: 4px solid var(--accent);
      padding-left: 24px;
      margin: 24px 0;
      color: var(--text-gray);
      font-style: italic;
    }

    @media (max-width: 1024px) {
      .post-layout {
        grid-template-columns: 1fr;
      }

      .post-sidebar {
        position: static;
        max-height: none;
      }
    }

    @media (max-width: 768px) {
      .blog-post {
        padding: 24px;
      }

      .post-title {
        font-size: 32px;
      }

      .back-button {
        width: 100%;
        justify-content: center;
      }

      .post-content {
        font-size: 16px;
      }

      .post-content :global(h2) {
        font-size: 24px;
      }

      .post-content :global(h3) {
        font-size: 20px;
      }

      .share-buttons {
        flex-wrap: wrap;
      }

      .related-posts {
        grid-column: 1 / -1;
      }

      .related-posts-grid {
        grid-template-columns: 1fr;
      }

      .related-post-card {
        flex-direction: row;
      }

      .related-post-image {
        width: 120px;
        height: 80px;
        flex-shrink: 0;
      }
    }

    /* Related Posts */
    .related-posts {
      margin-top: 64px;
      padding-top: 48px;
      border-top: 1px solid var(--border);
    }

    .related-posts h2 {
      font-family: 'Source Serif 4', Georgia, serif;
      font-size: 28px;
      font-weight: 600;
      color: var(--text-white);
      margin-bottom: 32px;
    }

    .related-posts-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }

    @media (max-width: 1024px) {
      .related-posts-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .related-posts-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    // Calcular tempo de leitura
    function calculateReadingTime() {
      const content = document.getElementById('post-content');
      if (!content) return;

      const text = content.textContent || '';
      const wordCount = text.trim().split(/\s+/).length;
      const wordsPerMinute = 200;
      const readingTime = Math.ceil(wordCount / wordsPerMinute);

      const readingTimeEl = document.getElementById('reading-time');
      if (readingTimeEl) {
        readingTimeEl.textContent = `${readingTime} min de leitura`;
      }
    }

    // Gerar Table of Contents
    function generateTableOfContents() {
      const content = document.getElementById('post-content');
      const toc = document.getElementById('table-of-contents');
      if (!content || !toc) return;

      const headings = content.querySelectorAll('h2, h3');
      if (headings.length === 0) {
        toc.innerHTML = '<p class="toc-empty">Nenhum índice disponível</p>';
        return;
      }

      // Gerar IDs para os headings que não tiverem
      headings.forEach((heading, index) => {
        if (!heading.id) {
          const text = heading.textContent || '';
          const id = text
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/(^-|-$)/g, '');
          heading.id = id || `heading-${index}`;
        }
      });

      // Criar links do TOC
      const tocLinks = Array.from(headings).map(heading => {
        const level = heading.tagName.toLowerCase();
        const text = heading.textContent || '';
        const id = heading.id;

        return `<a href="#${id}" class="toc-link level-${level.replace('h', '')}">${text}</a>`;
      }).join('');

      toc.innerHTML = tocLinks;

      // Adicionar comportamento de scroll suave
      toc.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetId = link.getAttribute('href')?.substring(1);
          const target = document.getElementById(targetId || '');
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            // Atualizar URL sem recarregar página
            history.pushState(null, '', `#${targetId}`);
          }
        });
      });

      // Highlight do link ativo baseado no scroll
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              toc.querySelectorAll('a').forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === `#${id}`) {
                  link.classList.add('active');
                }
              });
            }
          });
        },
        { rootMargin: '-100px 0px -80% 0px' }
      );

      headings.forEach(heading => observer.observe(heading));
    }

    // Funcionalidade de compartilhamento
    function setupShareButtons() {
      const shareButtons = document.querySelectorAll('.share-btn');
      const pageUrl = window.location.href;
      const pageTitle = document.querySelector('.post-title')?.textContent || '';

      shareButtons.forEach(button => {
        button.addEventListener('click', () => {
          const platform = button.getAttribute('data-share');
          let shareUrl = '';

          switch (platform) {
            case 'whatsapp':
              shareUrl = `https://wa.me/?text=${encodeURIComponent(pageTitle + ' - ' + pageUrl)}`;
              break;
            case 'linkedin':
              shareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;
              break;
            case 'facebook':
              shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`;
              break;
            case 'twitter':
              shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(pageTitle)}&url=${encodeURIComponent(pageUrl)}`;
              break;
          }

          if (shareUrl) {
            window.open(shareUrl, '_blank', 'width=600,height=400');
          }
        });
      });
    }

    // Barra de Progresso de Leitura
    function setupReadingProgress() {
      const progressBar = document.getElementById('reading-progress');
      if (!progressBar) return;

      let ticking = false;

      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight;
        const winHeight = window.innerHeight;
        const scrollPercent = (scrollTop / (docHeight - winHeight)) * 100;

        // Limitar entre 0 e 100
        const progress = Math.min(100, Math.max(0, scrollPercent));
        progressBar.style.width = `${progress}%`;

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateProgress);
          ticking = true;
        }
      }, { passive: true });

      // Atualizar no load caso a página já esteja rolada
      updateProgress();
    }

    // Executar quando a página carregar
    document.addEventListener('DOMContentLoaded', () => {
      calculateReadingTime();
      generateTableOfContents();
      setupShareButtons();
      setupReadingProgress();
    });
  </script>
</body>
</html>
